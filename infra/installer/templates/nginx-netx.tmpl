# =============================================================================
# NetX — nginx site (gerado pelo installer)
# =============================================================================
# /        → web (Next.js) em :${NETX_PORT_WEB}
# /api/    → api-gateway em :${NETX_PORT_API_GATEWAY}
# =============================================================================

upstream netx_web {
    server 127.0.0.1:${NETX_PORT_WEB};
    keepalive 32;
}

upstream netx_api {
    server 127.0.0.1:${NETX_PORT_API_GATEWAY};
    keepalive 32;
}

upstream netx_minio {
    server 127.0.0.1:9000;
    keepalive 32;
}

server {
    # default_server: este vhost atende QUALQUER Host header (domain, IP,
    # subdomain) — fundamental enquanto DNS ainda não propagou ou pra acesso
    # direto via IP. server_name fica explícito pra logs e fallback.
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name ${NETX_NGINX_SERVER_NAME} _;

    client_max_body_size 50M;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    # Logs
    access_log /var/log/nginx/netx.access.log;
    error_log  /var/log/nginx/netx.error.log warn;

    # Gateway / API
    location /api/ {
        proxy_pass http://netx_api;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
    }

    # ---------------------------------------------------------------------
    # MinIO (object storage — fotos do app mobile, anexos OS)
    # ---------------------------------------------------------------------
    # /minio/<bucket>/<key> → http://127.0.0.1:9000/<bucket>/<key>
    #
    # Mobile faz upload direto via presigned URL — o backend não trafega
    # bytes. client_max_body_size 100M acomoda fotos JPG full-res.
    # Buffering off pra upload streaming não estourar memória.
    location /minio/ {
        # Remove o prefixo /minio antes de proxy
        rewrite ^/minio/(.*)$ /$1 break;

        proxy_pass http://netx_minio;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Upload streaming — não bufferiza body inteiro em disco
        proxy_request_buffering off;
        proxy_buffering off;
        client_max_body_size 100M;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;

        # Importante: o ETag/Authorization do S3 SDK deve passar limpo
        proxy_set_header Connection "";
    }

    # ---------------------------------------------------------------------
    # Static assets do Next.js (chunks JS, CSS, fonts, images otimizadas)
    # ---------------------------------------------------------------------
    # Estes arquivos têm CONTENT HASH no nome (ex: 0wi.1kmopz0_g.js).
    # Quando o conteúdo muda, o nome muda — então cachear "pra sempre" é
    # SEGURO. `immutable` diz pro browser nem revalidar.
    #
    # Sem isso (default ~5min), depois de cada rebuild a janela curta de
    # cache cria mismatch: HTML aponta pra hash novo, browser ainda tem
    # hash antigo até o cache expirar → ChunkLoadError 500.
    location ~* ^/_next/static/ {
        proxy_pass http://netx_web;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Cache 1 ano + immutable. Hash no nome garante invalidação automática.
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        # Repete os headers de hardening (add_header herdou-NÃO entre locations
        # quando o location define qualquer add_header próprio).
        add_header X-Content-Type-Options "nosniff" always;
    }

    # ---------------------------------------------------------------------
    # Frontend (Next.js) — HTML + tudo mais
    # ---------------------------------------------------------------------
    # CRÍTICO: HTML NUNCA pode ser cacheado. O HTML referencia chunks com
    # hashes — se browser servir HTML velho do cache, vai pedir chunks que
    # não existem mais → 500. `no-cache` força revalidação a cada request
    # (browser ainda pode usar ETag pra evitar download se nada mudou).
    location / {
        proxy_pass http://netx_web;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";

        # Next.js HMR / static
        proxy_buffering off;

        # HTML sem cache — revalida sempre. Browser ainda economiza
        # transferência via ETag/304 se nada mudou.
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Pragma "no-cache" always;
        add_header X-Content-Type-Options "nosniff" always;
    }

    # Hardening
    server_tokens off;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    # HSTS: força HTTPS por 1 ano em qualquer navegador que receber a
    # resposta sobre HTTPS. Inócuo sobre HTTP (browsers ignoram). Quando
    # certbot rodar e adicionar o bloco :443, este header é preservado.
    # `includeSubDomains` é seguro pra ISP single-tenant; se algum dia
    # tenants ficarem em subdomínios em HTTP, remover essa flag.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    # CSP minimalista — só permite recursos same-origin + inline pro Next
    # (que injeta scripts inline via __NEXT_DATA__ e estilos via styled-jsx).
    # `data:` em img/font é pra ícones SVG inline + favicons embutidos.
    # `connect-src self` permite Server Actions e fetch pro /api do mesmo host.
    # Endurecer no futuro removendo `unsafe-inline` exige refactor de styled-jsx.
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'" always;
    # Permissions-Policy: opt-out explícito de APIs que NetX não usa
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()" always;
}
