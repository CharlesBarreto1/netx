# =============================================================================
# NetX — .env (gerado pelo installer)
# =============================================================================
# NÃO commitar. Permissão deve ser 640 (root:netx).
# Pra regenerar: re-rode o installer com NETX_FORCE=1 (segredos persistem em
# /etc/netx/.secrets).
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info

# --- Services -----------------------------------------------------------------
API_GATEWAY_PORT=${NETX_PORT_API_GATEWAY}
API_GATEWAY_HOST=0.0.0.0
# CORS — origins explícitos do frontend. Wildcard '*' é PROIBIDO em produção
# (gateway recusa boot). Edite se o front estiver em outro domínio/porta.
API_GATEWAY_CORS_ORIGINS=${NETX_CORS_ORIGINS}
API_GATEWAY_GLOBAL_PREFIX=api

CORE_SERVICE_PORT=${NETX_PORT_CORE_SERVICE}
CORE_SERVICE_HOST=0.0.0.0

# --- Web (Next.js) ------------------------------------------------------------
WEB_PORT=${NETX_PORT_WEB}
# URL que o BROWSER usa pra falar com o gateway. Path relativo `/api` é o
# default e funciona em qualquer host (IP ou domínio) — o nginx faz o proxy
# pro gateway interno. NUNCA use `http://localhost:...` aqui: localhost no
# browser resolve pra máquina do usuário, não pro servidor.
NEXT_PUBLIC_API_URL=/api

# --- Database -----------------------------------------------------------------
DATABASE_URL=${NETX_DATABASE_URL}

# --- Redis --------------------------------------------------------------------
REDIS_URL=${NETX_REDIS_URL}

# --- RabbitMQ -----------------------------------------------------------------
RABBITMQ_URL=${NETX_RABBITMQ_URL}

# --- JWT ----------------------------------------------------------------------
# Access curto (15min) + Refresh moderado (7d). Sem isso, um token vazado dura
# meio dia / três meses sem possibilidade real de revogação. JwtStrategy checa
# Session.revokedAt no DB, então logout/disable de user invalida access em até
# ~15min (até a próxima exchange) e refresh imediato.
JWT_ACCESS_SECRET=${NETX_JWT_ACCESS_SECRET}
JWT_REFRESH_SECRET=${NETX_JWT_REFRESH_SECRET}
# Secret separado pro Portal do Cliente — não compartilha com JWT_ACCESS_SECRET
# pra que um vazamento de portal-jwt não permita forjar token de operador.
PORTAL_JWT_SECRET=${NETX_PORTAL_JWT_SECRET}
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- KMS (cifra credenciais de NAS — API/SSH passwords) -----------------------
# Hex de 64 chars (256 bits). Gerado uma vez pelo installer e persistido em
# /etc/netx/.secrets — NÃO regere depois (torna senhas cifradas irrecuperáveis).
KMS_MASTER_KEY=${NETX_KMS_MASTER_KEY}

# --- Argon2 -------------------------------------------------------------------
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# --- Multi-tenancy ------------------------------------------------------------
TENANT_RESOLUTION_STRATEGY=jwt
TENANT_HEADER_NAME=x-tenant-id
# Slug usado quando o frontend faz /auth/login sem `tenantSlug`. Como cada
# instância NetX atende um único ISP, deixamos o slug do tenant criado pelo
# installer pra UX "uma URL, uma operação".
DEFAULT_TENANT_SLUG=${NETX_TENANT_SLUG}

# --- Chat / WhatsApp (Evolution API) ------------------------------------------
# Evolution roda em container Docker no mesmo host (network_mode=host).
# Apikey global gerada pelo installer; admin precisa no /settings/whatsapp
# pra cadastrar a primeira instância.
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=${EVOLUTION_API_KEY}

# Path do core-service onde o webhook Evolution entrega (loopback é OK).
WEBHOOK_BASE_URL=http://localhost:${NETX_PORT_CORE_SERVICE}

# Onde a mídia baixada do WhatsApp fica armazenada.
WHATSAPP_MEDIA_ROOT=/var/lib/netx/whatsapp/media

# --- SIFEN / e-Kuatiá (Fatura eletrônica Paraguay) ----------------------------
# Módulo desligado por default. Pra habilitar:
#   1) Obter Certificado Cualificado de Firma Electrónica (CCFE) com PSC certificado pelo MIC
#   2) Colocar o .p12 em /etc/netx/sifen/cert.p12 (chown root:netx, chmod 640)
#   3) Aderir como facturador electrónico em https://www.dnit.gov.py/web/e-kuatia
#   4) Preencher RUC + Timbrado abaixo
#   5) SIFEN_ENABLED=true + restart core-service
#   6) Passar pelo Plan Piloto (homologação) antes de produção
#
# Documentação: docs/sifen-integration.md (TODO) e Manual Técnico v150 da DNIT.
SIFEN_ENABLED=false
SIFEN_ENVIRONMENT=test
SIFEN_RUC=
SIFEN_TIMBRADO=
SIFEN_RAZON_SOCIAL=
SIFEN_ESTABLECIMIENTO=001
SIFEN_PUNTO_EXPEDICION=001
SIFEN_CERT_PATH=/etc/netx/sifen/cert.p12
SIFEN_CERT_PASSWORD=

# --- Observability ------------------------------------------------------------
OTEL_SERVICE_NAME=netx
