# NetX — config NPM do monorepo
#
# legacy-peer-deps=true
#   Razão: temos workspaces com peer deps incompatíveis (ex.: react-leaflet
#   declarava ^18 mas usamos React 19; algumas libs React Native do módulo
#   mobile com peer deps relaxadas). NPM 7+ é strict por default e quebra
#   o install.
#   Trade-off: peer deps reais (incompatibilidade verdadeira) não vão
#   aparecer como erro — viraria runtime error. Aceito porque o ecossistema
#   React 19 ainda tem libs com peer dep desatualizada.
#
# engine-strict=true
#   Garante node >=24 conforme package.json "engines".
legacy-peer-deps=true
engine-strict=true
