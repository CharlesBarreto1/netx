# =============================================================================

# --- Dependencies -------------------------------------------------------------
node_modules/
.pnp/
.pnp.js
.yarn/
.yarn-integrity

# IMPORTANT: package-lock.json É commitado (npm ci precisa dele em CI).
# Não adicionar package-lock.json aqui.

# --- Build outputs ------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# Next.js
.next/
.next-cache/

# Nx
.nx/cache/
.nx/workspace-data/

# Prisma generated client (regenerado por `prisma generate`)
**/generated/
packages/database/prisma/migrations/migration_lock.toml

# --- Coverage / tests ---------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# --- IDE / editor -------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# --- OS -----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Env / secrets ------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# --- Editor / agente (config LOCAL de máquina — não versionar) ----------------
# settings.local.json acumula grants de permissão por máquina/usuário; o
# launch.json (compartilhado) continua versionado.
.claude/settings.local.json

# --- Logs ---------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino-debug.log

# --- Runtime / temp -----------------------------------------------------------
*.pid
*.seed
*.tgz
.cache/
tmp/
temp/

# --- Backups locais (NetX) ----------------------------------------------------
backups/
*.dump
*.dump.gz

# --- Uploads locais (dev) -----------------------------------------------------
apps/*/uploads/
apps/*/var/

# --- Arquivos antigos / zip de migração ---------------------------------------
NetX.zip
*.bak
.DS_Store
.DS_Store
.DS_Store
apps/.DS_Store
apps/nms/.DS_Store
infra/.DS_Store
packages/.DS_Store

# Caches criados por npm/npx quando roda fora do HOME do usuário.
.config/
.npm/
.claude/worktrees/
