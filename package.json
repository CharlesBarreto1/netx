{
  "name": "netx",
  "version": "0.1.0",
  "private": true,
  "description": "NetX — Plataforma SaaS multinacional para provedores de internet (ISP)",
  "author": "NETX DESENVOLVIMENTO E TECNOLOGIA LTDA <charles@camponet.com.br>",
  "license": "UNLICENSED",
  "homepage": "https://netx.com.br",
  "workspaces": [
    "apps/*",
    "packages/*",
    "!apps/hub",
    "!apps/nms"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "npx --yes only-allow npm",
    "build": "nx run-many -t build --exclude=nms",
    "test": "nx run-many -t test --exclude=nms",
    "lint": "nx run-many -t lint --exclude=nms",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "dev": "nx run-many -t dev --parallel=5 --exclude=nms",
    "dev:api-gateway": "nx run api-gateway:dev",
    "dev:core": "nx run core-service:dev",
    "dev:web": "nx run web:dev",
    "nms:install": "nx run nms:install",
    "nms:build": "nx run nms:build",
    "nms:dev": "nx run nms:dev",
    "nms:prisma:generate": "nx run nms:prisma-generate",
    "nms:prisma:deploy": "nx run nms:prisma-deploy",
    "infra:up": "docker compose --env-file .env -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file .env -f infra/docker/docker-compose.yml down",
    "infra:logs": "docker compose --env-file .env -f infra/docker/docker-compose.yml logs -f",
    "infra:reset": "docker compose --env-file .env -f infra/docker/docker-compose.yml down -v && docker compose --env-file .env -f infra/docker/docker-compose.yml up -d",
    "db:migrate": "npm run -w apps/core-service db:migrate",
    "db:migrate:dev": "npm run -w apps/core-service db:migrate:dev",
    "db:migrate:status": "npm run -w apps/core-service db:migrate:status",
    "db:baseline": "npm run -w apps/core-service db:baseline",
    "db:adopt": "npm run -w apps/core-service db:adopt",
    "db:generate": "npm run -w apps/core-service db:generate",
    "db:seed": "npm run -w apps/core-service db:seed",
    "db:seed:fake": "npm run -w apps/core-service db:seed:fake",
    "db:studio": "npm run -w apps/core-service db:studio",
    "preflight": "bash scripts/preflight.sh",
    "preflight:web": "bash scripts/preflight.sh web",
    "preflight:core": "bash scripts/preflight.sh core-service",
    "preflight:gateway": "bash scripts/preflight.sh api-gateway",
    "prepare": "husky || true"
  },
  "overrides": {
    "react-native": "0.76.9",
    "@react-native/virtualized-lists": "0.76.9",
    "@react-native-async-storage/async-storage": "1.23.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "jest-environment-node": "30.4.1",
    "jest-mock": "30.4.1",
    "lint-staged": "^15.4.3",
    "nx": "^22.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.36.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
