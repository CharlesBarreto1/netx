# apps/api — copie para .env (NUNCA commite .env). Credenciais de EQUIPAMENTO não ficam aqui:
# vão no cofre e só o device-gateway as lê (AGENTS.md §4).

NODE_ENV=development
# Dentro do ecossistema NetX, o NMS roda em :3300 (o api-gateway aponta o
# NMS_SERVICE_PORT pra cá). Standalone, pode usar 3000.
PORT=3300

# Postgres — DENTRO do ecossistema, use a MESMA instância do NetX, mas no schema
# próprio `nms` (invariante 3: o NMS é dono exclusivo desse schema). O Prisma do
# NMS cria as tabelas em nms.* automaticamente.
DATABASE_URL=postgresql://netx:netx_dev_password@localhost:5432/netx?schema=nms

# Redis (fila BullMQ + pub/sub) — compartilhado com o NetX em dev.
REDIS_URL=redis://localhost:6379

# WS do terminal do device-gateway (a API faz proxy de bytes até aqui)
GATEWAY_TERMINAL_URL=ws://127.0.0.1:8766

# Auth / RBAC (ADR 0007). JWT_SECRET é OBRIGATÓRIO (≥32 chars). Gere com: openssl rand -base64 48
JWT_SECRET=
JWT_TTL=12h

# ── SSO do ecossistema (canal 1) ─────────────────────────────────────────────
# Aceitar o JWT de operador emitido pelo Core do NetX (mesmo HS256). Cole aqui o
# JWT_ACCESS_SECRET do Core. Vazio = só o login nativo do NMS funciona.
CORE_JWT_SECRET=
CORE_JWT_ISSUER=netx
CORE_JWT_AUDIENCE=netx-api

# ── Bus de eventos do ecossistema (canal 3) ──────────────────────────────────
# Consumidor de netx.events (RabbitMQ topic). OFF por default; ligue os dois pra
# fechar o round-trip com o Core em dev.
RABBITMQ_URL=amqp://netx:netx_dev_password@localhost:5672
EVENTBUS_CONSUME=false
EVENTBUS_EXCHANGE=netx.events
# Seed do 1º admin no boot (só cria se a tabela estiver vazia).
ADMIN_USERNAME=admin
# Se vazio, o boot gera uma senha aleatória e a imprime UMA vez no log.
ADMIN_PASSWORD=

# Repositório git de backups de config (Pilar 4). Em dev aponta pro infra/ (gitignored).
BACKUP_REPO_DIR=../../infra/config-backups
# Cron do backup automático (padrão diário 03:00)
BACKUP_CRON=0 3 * * *

# IA (Fase 4). Sem a chave, anomalia (4.1) funciona; resumo de diff (4.2) e copiloto (4.3) ficam off.
ANTHROPIC_API_KEY=
LLM_MODEL_SUMMARY=claude-haiku-4-5
LLM_MODEL_COPILOT=claude-sonnet-4-6
# Cron da varredura de anomalias (padrão a cada 10 min)
ANOMALY_CRON=*/10 * * * *
