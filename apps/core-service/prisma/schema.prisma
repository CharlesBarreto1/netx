generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto, citext, pg_trgm]
}

// -----------------------------------------------------------------------------
// TENANT
// -----------------------------------------------------------------------------
enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
}

/// O `Tenant` representa **a empresa (ISP) inteira** atendida por esta
/// instância NetX. Cada instalação atende **exatamente um Tenant**.
///
/// Por que existe a abstração mesmo sendo singleton na prática?
///   1. Isolamento futuro: se um dia oferecermos NetX hosted (multi-ISP em
///      um VPS gerenciado pela NetX), o código já está pronto.
///   2. Cooperativas/revenda: pequenos ISPs em coop podem compartilhar
///      hardware mantendo dados separados (caso real no Brasil).
///   3. RBAC limpo: todas as queries já carregam tenantId, evita bugs de
///      vazamento entre dados de um futuro segundo tenant.
///
/// O modelo SaaS multi-tenant compartilhado **foi descartado** como
/// produto principal porque:
///   - RADIUS exige baixa latência (Mikrotik time-out 200ms)
///   - LGPD/soberania de dados (ISP não compartilha DB com concorrente)
///   - Blast radius (1 bug afeta 1 ISP, não todas)
///
/// Veja `docs/architecture/tenancy.md` pra contexto completo.
model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  slug        String       @unique @db.VarChar(63) // used in subdomain
  name        String       @db.VarChar(255)
  legalName   String?      @map("legal_name") @db.VarChar(255)
  taxId       String?      @map("tax_id") @db.VarChar(32) // CNPJ, RFC, EIN, etc.
  country     String       @db.Char(2) // ISO 3166-1 alpha-2
  locale      String       @default("pt-BR") @db.VarChar(10)
  timezone    String       @default("America/Sao_Paulo") @db.VarChar(64)
  currency    String       @default("BRL") @db.Char(3) // ISO 4217
  status      TenantStatus @default(TRIAL)
  domains     String[]     @default([]) // custom domains
  logoUrl     String?      @map("logo_url")
  primaryColor String?     @map("primary_color") @db.VarChar(7)
  trialEndsAt DateTime?    @map("trial_ends_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  settings    TenantSetting[]
  features    TenantFeature[]
  users       User[]
  roles       Role[]
  sessions    Session[]
  apiKeys     ApiKey[]
  auditLogs   AuditLog[]
  customers   Customer[]
  customerTags CustomerTag[]
  pipelines   Pipeline[]
  deals       Deal[]
  activities  Activity[]
  contracts   Contract[]
  contractInvoices ContractInvoice[]
  radiusEvents RadiusEvent[]
  serviceOrders        ServiceOrder[]
  serviceOrderReasons  ServiceOrderReason[]
  cashRegisters        CashRegister[]
  oneTimeCharges       OneTimeCharge[]
  cashMovements        CashMovement[]
  backups              Backup[]
  networkPops          NetworkPop[]
  networkEquipment     NetworkEquipment[]

  // WhatsApp / Atendimento
  whatsappInstances    WhatsappInstance[]
  whatsappContacts     WhatsappContact[]
  whatsappConversations WhatsappConversation[]

  // SIFEN — fatura eletrônica Paraguay (módulo opcional, ligado via env)
  sifenDocuments       SifenDocument[]

  // Estoque (Fase 1)
  suppliers            Supplier[]
  products             Product[]
  stockLocations       StockLocation[]
  purchases            Purchase[]

  // Provisionamento (Fase 1 — OLT/ONT + TR-069 ACS Fase 3)
  olts                 Olt[]
  onts                 Ont[]
  tr069Devices         Tr069Device[]
  tr069Tasks           Tr069Task[]
  provisioningEvents   ProvisioningEvent[]

  @@index([status])
  @@index([country])
  @@map("tenants")
}

model TenantSetting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String   @db.VarChar(128)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("tenant_settings")
}

model TenantFeature {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  feature   String   @db.VarChar(128) // "module.radius", "module.fiscal.br", ...
  enabled   Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature])
  @@map("tenant_features")
}

// -----------------------------------------------------------------------------
// USER
// -----------------------------------------------------------------------------
enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String     @map("tenant_id") @db.Uuid
  email          String     @db.Citext
  emailVerified  Boolean    @default(false) @map("email_verified")
  passwordHash   String?    @map("password_hash") // null for SSO-only users
  firstName      String     @map("first_name") @db.VarChar(120)
  lastName       String     @map("last_name") @db.VarChar(120)
  phone          String?    @db.VarChar(32)
  avatarUrl      String?    @map("avatar_url")
  locale         String?    @db.VarChar(10) // overrides tenant default
  timezone       String?    @db.VarChar(64)
  status         UserStatus @default(INVITED)
  lastLoginAt    DateTime?  @map("last_login_at")
  lastLoginIp    String?    @map("last_login_ip") @db.Inet
  mfaEnabled     Boolean    @default(false) @map("mfa_enabled")
  mfaSecret      String?    @map("mfa_secret")
  mfaBackupCodes String[]   @default([]) @map("mfa_backup_codes")
  /// Quando true, força redirect pra /first-login no próximo login bem-sucedido.
  /// Setado pelo seed (admin default), pelo installer (admin do tenant), e
  /// quando admin reseta a senha de outro user. Limpado pelo POST
  /// /v1/users/me/change-password ao fim do flow.
  mustChangePassword Boolean @default(false) @map("must_change_password")
  // Override de visibilidade de menus por usuário. Quando null (default), o
  // sidebar usa só permissões. Quando array (ex. ["dashboard","customers"]),
  // o sidebar intersecta com essa lista — útil pra esconder menus que o user
  // teria permissão mas o admin quer ocultar individualmente.
  menuAccess     Json?      @map("menu_access")
  invitedById    String?    @map("invited_by_id") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy    User?      @relation("UserInvites", fields: [invitedById], references: [id])
  invites      User[]     @relation("UserInvites")
  userRoles    UserRole[]
  sessions     Session[]
  auditLogs    AuditLog[]
  customersCreated Customer[] @relation("CustomerCreatedBy")
  customersUpdated Customer[] @relation("CustomerUpdatedBy")
  customerNotes    CustomerNote[]
  customerTagAssignments CustomerTagAssignment[]

  // Deals / Activities (CRM sales)
  dealsOwned       Deal[]          @relation("DealOwner")
  dealsCreated     Deal[]          @relation("DealCreatedBy")
  dealsUpdated     Deal[]          @relation("DealUpdatedBy")
  dealHistoryEvents DealHistory[]
  activitiesOwned  Activity[]      @relation("ActivityOwner")
  activitiesCreated Activity[]     @relation("ActivityCreatedBy")
  activitiesCompleted Activity[]   @relation("ActivityCompletedBy")

  // Contracts
  contractsCreated Contract[]      @relation("ContractCreatedBy")
  contractsUpdated Contract[]      @relation("ContractUpdatedBy")

  // Service Orders
  serviceOrdersAssigned ServiceOrder[] @relation("ServiceOrderAssignedTo")
  serviceOrdersCreated  ServiceOrder[] @relation("ServiceOrderCreatedBy")
  serviceOrdersUpdated  ServiceOrder[] @relation("ServiceOrderUpdatedBy")

  // Finance — caixas que o user opera + cobranças avulsas que criou
  cashRegisterMemberships CashRegisterMembership[]
  chargesCreated   OneTimeCharge[] @relation("ChargeCreatedBy")
  chargesUpdated   OneTimeCharge[] @relation("ChargeUpdatedBy")
  cashMovementsCreated CashMovement[] @relation("CashMovementCreatedBy")
  backupsCreated       Backup[]       @relation("BackupCreatedBy")
  networkPopsCreated   NetworkPop[]   @relation("NetworkPopCreatedBy")
  networkPopsUpdated   NetworkPop[]   @relation("NetworkPopUpdatedBy")
  networkEqCreated     NetworkEquipment[] @relation("NetworkEquipmentCreatedBy")
  networkEqUpdated     NetworkEquipment[] @relation("NetworkEquipmentUpdatedBy")

  // WhatsApp / Atendimento
  whatsappConversationsAssigned WhatsappConversation[] @relation("WaConversationAssignee")
  whatsappMessagesSent          WhatsappMessage[]      @relation("WaMessageFromUser")
  whatsappConversationViews     WhatsappConversationView[]

  // Estoque (Fase 1)
  stockLocationAccess  StockLocationUser[]
  stockMovementsCreated StockMovement[] @relation("StockMovementCreatedBy")
  purchasesCreated      Purchase[]      @relation("PurchaseCreatedBy")

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([email])
  @@map("users")
}

// -----------------------------------------------------------------------------
// RBAC: ROLE, PERMISSION, JOIN TABLES
// -----------------------------------------------------------------------------
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid // NULL => system role (global)
  name        String   @db.VarChar(64)
  description String?  @db.VarChar(255)
  isSystem    Boolean  @default(false) @map("is_system") // seeded/immutable
  priority    Int      @default(100) // lower = higher priority
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(128) // "users.create", "invoices.read", ...
  resource    String   @db.VarChar(64)          // "users"
  action      String   @db.VarChar(32)          // "create" | "read" | "update" | "delete" | custom
  description String?  @db.VarChar(255)
  module      String   @db.VarChar(64)          // "core", "crm", "billing", ...
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// -----------------------------------------------------------------------------
// SESSION / REFRESH TOKEN
// -----------------------------------------------------------------------------
model Session {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") // SHA-256 of refresh JWT
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  ip               String?   @db.Inet
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastUsedAt       DateTime  @default(now()) @map("last_used_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// -----------------------------------------------------------------------------
// API KEY (service-to-service / automations)
// -----------------------------------------------------------------------------
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(128)
  keyHash    String    @unique @map("key_hash") // bcrypt/argon2 of the API key
  keyPrefix  String    @map("key_prefix") @db.VarChar(12) // displayable prefix (netx_live_...)
  scopes     String[]  @default([])
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  createdBy  String?   @map("created_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

// -----------------------------------------------------------------------------
// AUDIT LOG (append-only)
// -----------------------------------------------------------------------------
enum AuditLevel {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String?    @map("tenant_id") @db.Uuid // NULL for system-level events
  userId       String?    @map("user_id") @db.Uuid
  actor        String?    @db.VarChar(128) // "api-key:xxx", "system", "webhook", etc.
  action       String     @db.VarChar(128) // "user.login.success", "invoice.created", ...
  resource     String?    @db.VarChar(64)
  resourceId   String?    @map("resource_id") @db.VarChar(64)
  level        AuditLevel @default(INFO)
  ip           String?    @db.Inet
  userAgent    String?    @map("user_agent") @db.VarChar(512)
  beforeState  Json?      @map("before_state")
  afterState   Json?      @map("after_state")
  metadata     Json?
  createdAt    DateTime   @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([resource, resourceId])
  @@index([userId])
  @@map("audit_logs")
}

// =============================================================================
// MODULE 2 — CRM
//
// Entidades:
//   - Customer            (PF ou PJ, multi-país via TaxIdType)
//   - CustomerAddress     (1..N endereços por cliente, tipados)
//   - CustomerContact     (1..N emails/fones, opt-in por canal)
//   - CustomerTag         (catálogo de tags por tenant)
//   - CustomerTagAssignment (N..N cliente↔tag)
//   - CustomerConsent     (LGPD/GDPR: propósito + status + timestamps)
//   - CustomerNote        (histórico livre, autor + pinned)
// =============================================================================

enum CustomerType {
  INDIVIDUAL   // Pessoa Física
  COMPANY      // Pessoa Jurídica
}

enum CustomerStatus {
  LEAD
  PROSPECT
  ACTIVE
  SUSPENDED
  INACTIVE
  CHURNED
}

enum TaxIdType {
  // Brasil
  CPF
  CNPJ
  // Paraguay
  CI
  RUC
  // Placeholders futuros (validators adicionados por país)
  VAT     // EU
  NIF     // Espanha/Portugal
  RFC     // México
  CUIT    // Argentina
  RUT     // Chile
  NIT     // Colômbia
  SSN     // USA (individual)
  EIN     // USA (company)
  OTHER
}

enum AddressType {
  BILLING      // faturamento
  SERVICE      // endereço de instalação do serviço
  SHIPPING     // envio de equipamentos
  OTHER
}

enum ContactType {
  EMAIL
  PHONE
  MOBILE
  WHATSAPP
  TELEGRAM
  OTHER
}

enum ConsentPurpose {
  MARKETING_EMAIL
  MARKETING_SMS
  MARKETING_WHATSAPP
  MARKETING_VOICE
  DATA_PROCESSING
  THIRD_PARTY_SHARING
  CREDIT_SCORE_QUERY
  CONTRACT_NOTIFICATION
  SUPPORT_RECORDING
  OTHER
}

enum ConsentStatus {
  GRANTED
  REVOKED
  PENDING
  EXPIRED
}

enum ConsentMethod {
  WEB_FORM
  EMAIL
  IN_PERSON
  VOICE
  API
  IMPORT
  OTHER
}

// -----------------------------------------------------------------------------
// CUSTOMER
// -----------------------------------------------------------------------------
model Customer {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  code            String?        @db.VarChar(32)                    // código humano ex. CLI-000123
  type            CustomerType
  status          CustomerStatus @default(LEAD)

  // Identificação PF
  firstName       String?        @map("first_name") @db.VarChar(120)
  lastName        String?        @map("last_name") @db.VarChar(120)
  birthDate       DateTime?      @map("birth_date") @db.Date
  gender          String?        @db.VarChar(32)
  motherName      String?        @map("mother_name") @db.VarChar(255)

  // Identificação PJ
  companyName     String?        @map("company_name") @db.VarChar(255) // razão social
  tradeName       String?        @map("trade_name") @db.VarChar(255)   // nome fantasia
  foundedAt       DateTime?      @map("founded_at") @db.Date
  stateRegistration String?      @map("state_registration") @db.VarChar(64)
  municipalRegistration String?  @map("municipal_registration") @db.VarChar(64)

  // Comum / busca
  displayName     String         @map("display_name") @db.VarChar(255) // desnormalizado para busca
  taxId           String?        @map("tax_id") @db.VarChar(32)
  taxIdType       TaxIdType?     @map("tax_id_type")
  taxIdCountry    String?        @map("tax_id_country") @db.Char(2)    // ISO 3166-1 alpha-2
  taxIdVerifiedAt DateTime?      @map("tax_id_verified_at")

  primaryEmail    String?        @map("primary_email") @db.Citext
  primaryPhone    String?        @map("primary_phone") @db.VarChar(32)

  preferredLanguage String?      @map("preferred_language") @db.VarChar(10)
  timezone          String?      @db.VarChar(64)

  shortNote       String?        @map("short_note") @db.VarChar(500)   // nota rápida (ex. "cliente VIP")
  metadata        Json?          // campo livre por tenant

  // Portal do cliente — acesso self-service.
  // Operador gera um código de 8 caracteres no detalhe do cliente; nós só
  // guardamos o hash Argon2id. O cliente entra com (taxId, código). Token
  // tem TTL configurável; após expirar, operador gera novo código.
  portalAccessHash      String?   @map("portal_access_hash") @db.VarChar(255)
  portalAccessExpiresAt DateTime? @map("portal_access_expires_at")
  portalLastLoginAt     DateTime? @map("portal_last_login_at")

  createdById     String?        @map("created_by_id") @db.Uuid
  updatedById     String?        @map("updated_by_id") @db.Uuid

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?             @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?             @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  addresses       CustomerAddress[]
  contacts        CustomerContact[]
  consents        CustomerConsent[]
  notes           CustomerNote[]
  tagAssignments  CustomerTagAssignment[]
  deals           Deal[]
  activities      Activity[]
  contracts       Contract[]
  oneTimeCharges  OneTimeCharge[]
  whatsappContacts WhatsappContact[]

  @@unique([tenantId, code])
  @@unique([tenantId, taxId, taxIdType])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, displayName])
  @@index([tenantId, primaryEmail])
  @@index([tenantId, primaryPhone])
  @@index([tenantId, createdAt])
  @@map("customers")
}

// -----------------------------------------------------------------------------
// CUSTOMER ADDRESS
// -----------------------------------------------------------------------------
model CustomerAddress {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  type        AddressType @default(BILLING)
  label       String?     @db.VarChar(64)                  // "Casa", "Escritório"

  country     String      @db.Char(2)                      // ISO alpha-2
  state       String?     @db.VarChar(120)
  city        String      @db.VarChar(120)
  district    String?     @db.VarChar(120)                 // bairro
  street      String      @db.VarChar(255)
  number      String?     @db.VarChar(32)
  complement  String?     @db.VarChar(120)
  postalCode  String?     @map("postal_code") @db.VarChar(16)

  latitude    Decimal?    @db.Decimal(9, 6)
  longitude   Decimal?    @db.Decimal(9, 6)

  isPrimary   Boolean     @default(false) @map("is_primary")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([tenantId, postalCode])
  @@index([tenantId, city])
  @@map("customer_addresses")
}

// -----------------------------------------------------------------------------
// CUSTOMER CONTACT
// -----------------------------------------------------------------------------
model CustomerContact {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  type        ContactType
  label       String?     @db.VarChar(64)                  // "Trabalho", "Pessoal"
  value       String      @db.VarChar(255)                 // normalizado (E.164 p/ telefones)

  isPrimary   Boolean     @default(false) @map("is_primary")
  isVerified  Boolean     @default(false) @map("is_verified")
  optIn       Boolean     @default(false) @map("opt_in")   // marketing opt-in específico do canal

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, type, value])
  @@index([tenantId, customerId])
  @@index([tenantId, type, value])
  @@map("customer_contacts")
}

// -----------------------------------------------------------------------------
// CUSTOMER TAG (catálogo) + ASSIGNMENT (N..N)
// -----------------------------------------------------------------------------
model CustomerTag {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  name        String      @db.VarChar(64)
  color       String?     @db.VarChar(7)                   // hex "#RRGGBB"
  description String?     @db.VarChar(255)

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments CustomerTagAssignment[]

  @@unique([tenantId, name])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId  String      @map("customer_id") @db.Uuid
  tagId       String      @map("tag_id") @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid       // denorm p/ índice
  assignedById String?    @map("assigned_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag         CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedBy  User?       @relation(fields: [assignedById], references: [id], onDelete: SetNull)

  @@id([customerId, tagId])
  @@index([tagId])
  @@index([tenantId, customerId])
  @@map("customer_tag_assignments")
}

// -----------------------------------------------------------------------------
// CUSTOMER CONSENT (LGPD / GDPR)
// -----------------------------------------------------------------------------
model CustomerConsent {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  customerId   String          @map("customer_id") @db.Uuid

  purpose      ConsentPurpose
  status       ConsentStatus   @default(PENDING)
  method       ConsentMethod   @default(WEB_FORM)

  grantedAt    DateTime?       @map("granted_at")
  revokedAt    DateTime?       @map("revoked_at")
  expiresAt    DateTime?       @map("expires_at")

  policyVersion String?        @map("policy_version") @db.VarChar(32)   // ex. "privacy-2026-01"
  sourceIp      String?        @map("source_ip") @db.Inet
  sourceUserAgent String?      @map("source_user_agent") @db.VarChar(512)
  evidenceUrl   String?        @map("evidence_url")                      // link p/ PDF/áudio da evidência
  notes         String?        @db.VarChar(500)

  metadata     Json?

  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([tenantId, purpose, status])
  @@map("customer_consents")
}

// -----------------------------------------------------------------------------
// CUSTOMER NOTE (histórico livre)
// -----------------------------------------------------------------------------
model CustomerNote {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  authorId    String?     @map("author_id") @db.Uuid

  title       String?     @db.VarChar(255)
  body        String      @db.Text
  pinned      Boolean     @default(false)

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author      User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tenantId, customerId, createdAt])
  @@index([tenantId, pinned])
  @@map("customer_notes")
}

// =============================================================================
// MODULE 2 — CRM (Sales: Pipelines, Deals, Activities)
//
// Pipeline       = funil comercial (tenant pode ter múltiplos)
// PipelineStage  = coluna do Kanban, ordenada, com probabilidade default
// Deal           = oportunidade/negócio em um estágio, com valor e dono
// DealHistory    = trilha de auditoria de mudança de estágio (p/ conversão)
// Activity       = tarefa/ligação/reunião/email associada a deal/customer
// =============================================================================

enum DealStatus {
  OPEN
  WON
  LOST
}

enum DealLostReason {
  PRICE
  COMPETITOR
  TIMING
  NO_BUDGET
  NO_DECISION
  NO_RESPONSE
  OTHER
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  TASK
  WHATSAPP
  VISIT
  OTHER
}

enum ActivityStatus {
  PENDING
  DONE
  CANCELLED
}

// -----------------------------------------------------------------------------
// PIPELINE (funil comercial)
// -----------------------------------------------------------------------------
model Pipeline {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  name        String          @db.VarChar(120)
  slug        String          @db.VarChar(64)            // para URLs: "vendas", "onboarding"
  description String?         @db.VarChar(500)
  color       String?         @db.VarChar(7)             // hex "#RRGGBB"
  isDefault   Boolean         @default(false) @map("is_default")
  isArchived  Boolean         @default(false) @map("is_archived")

  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages      PipelineStage[]
  deals       Deal[]

  @@unique([tenantId, slug])
  @@index([tenantId, isArchived])
  @@map("pipelines")
}

// -----------------------------------------------------------------------------
// PIPELINE STAGE (colunas do Kanban)
// -----------------------------------------------------------------------------
model PipelineStage {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  pipelineId   String     @map("pipeline_id") @db.Uuid
  name         String     @db.VarChar(120)
  order        Int                                         // 0-based, ordenação das colunas
  probability  Int        @default(0)                       // 0..100 — sugestão de prob. de fechamento
  color        String?    @db.VarChar(7)
  isWon        Boolean    @default(false) @map("is_won")    // estágio terminal "Ganho"
  isLost       Boolean    @default(false) @map("is_lost")   // estágio terminal "Perdido"

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  pipeline     Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@unique([pipelineId, order])
  @@index([tenantId, pipelineId])
  @@map("pipeline_stages")
}

// -----------------------------------------------------------------------------
// DEAL (oportunidade)
// -----------------------------------------------------------------------------
model Deal {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  pipelineId     String         @map("pipeline_id") @db.Uuid
  stageId        String         @map("stage_id") @db.Uuid

  title          String         @db.VarChar(255)
  description    String?        @db.Text
  value          Decimal        @default(0) @db.Decimal(14, 2)
  currency       String         @default("BRL") @db.Char(3)
  probability    Int?                                      // override do stage.probability
  expectedCloseAt DateTime?     @map("expected_close_at") @db.Date

  status         DealStatus     @default(OPEN)
  lostReason     DealLostReason? @map("lost_reason")
  lostNote       String?        @map("lost_note") @db.VarChar(500)

  // Posição dentro da coluna (para drag-drop vertical + reorder)
  position       Int            @default(0)

  customerId     String?        @map("customer_id") @db.Uuid
  ownerId        String?        @map("owner_id") @db.Uuid
  createdById    String?        @map("created_by_id") @db.Uuid
  updatedById    String?        @map("updated_by_id") @db.Uuid

  closedAt       DateTime?      @map("closed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline       Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage          PipelineStage  @relation(fields: [stageId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  owner          User?          @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("DealCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?          @relation("DealUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  history        DealHistory[]
  activities     Activity[]

  @@index([tenantId, pipelineId, stageId, position])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, customerId])
  @@index([tenantId, expectedCloseAt])
  @@map("deals")
}

// -----------------------------------------------------------------------------
// DEAL HISTORY (auditoria de mudança de estágio — funil de conversão)
// -----------------------------------------------------------------------------
model DealHistory {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  dealId       String      @map("deal_id") @db.Uuid

  fromStageId  String?     @map("from_stage_id") @db.Uuid
  toStageId    String      @map("to_stage_id") @db.Uuid
  fromStatus   DealStatus?
  toStatus     DealStatus

  changedById  String?     @map("changed_by_id") @db.Uuid
  reason       String?     @db.VarChar(500)                // motivo opcional
  metadata     Json?

  createdAt    DateTime    @default(now()) @map("created_at")

  deal         Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  changedBy    User?       @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([tenantId, dealId, createdAt])
  @@index([tenantId, toStageId])
  @@map("deal_history")
}

// -----------------------------------------------------------------------------
// ACTIVITY (tarefas, calls, reuniões, emails — liga em deal OU customer)
// -----------------------------------------------------------------------------
model Activity {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid

  type           ActivityType
  status         ActivityStatus  @default(PENDING)

  title          String          @db.VarChar(255)
  notes          String?         @db.Text
  location       String?         @db.VarChar(255)           // meetings/visits
  durationMin    Int?            @map("duration_min")

  dueAt          DateTime?       @map("due_at")
  completedAt    DateTime?       @map("completed_at")

  dealId         String?         @map("deal_id") @db.Uuid
  customerId     String?         @map("customer_id") @db.Uuid
  ownerId        String?         @map("owner_id") @db.Uuid
  createdById    String?         @map("created_by_id") @db.Uuid
  completedById  String?         @map("completed_by_id") @db.Uuid

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal           Deal?           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  owner          User?           @relation("ActivityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completedBy    User?           @relation("ActivityCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([tenantId, dealId, dueAt])
  @@index([tenantId, customerId, dueAt])
  @@index([tenantId, ownerId, status, dueAt])
  @@index([tenantId, status, dueAt])
  @@map("activities")
}

// =============================================================================
// CONTRACTS (Módulo 03) — contratos de serviço básicos
// Alimenta RADIUS (autorização PPPoE) e Financeiro interno (faturas).
// =============================================================================

enum ContractStatus {
  // Comercial criou o contrato mas ainda não foi instalado fisicamente
  // (não tem ONT autorizada na OLT, RADIUS não aplica). Visível em
  // /provisioning/pending pra técnico ativar em campo.
  PENDING_INSTALL
  ACTIVE      // libera PPPoE/IPoE
  SUSPENDED   // pool de IP "bloqueados"
  CANCELLED   // pool de IP "cancelados"
}

// Como o cliente autentica no RADIUS:
//   PPPOE — usuário/senha em PPPoE (legado e default; cobre 100% das instalações
//           de fibra com BNG Mikrotik usando concentrador PPPoE).
//   IPOE  — sem PPPoE; o BNG/OLT injeta circuit-id (DHCP option 82) e/ou MAC
//           no Access-Request, e o RADIUS aceita por identificação. Usado em
//           FTTH GPON com OLT Huawei/ZTE/Fiberhome onde se quer dispensar
//           o cliente PPPoE.
enum ContractAuthMethod {
  PPPOE
  IPOE
}

enum InvoiceStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

enum ContractSuspendReason {
  MANUAL
  OVERDUE_PAYMENT
  OTHER
}

model Contract {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @map("tenant_id") @db.Uuid
  customerId          String         @map("customer_id") @db.Uuid

  // Código humano ex. CTR-000123 (opcional, gerado pelo service)
  code                String?        @db.VarChar(32)

  // Método de autenticação no RADIUS. Default IPOE — padrão moderno em
  // FTTH GPON (99% das instalações). PPPoE fica como opt-in pra ISPs com
  // BNG legado.
  authMethod          ContractAuthMethod @default(IPOE) @map("auth_method")

  // ── Autenticação PPPoE (preenchido só se authMethod = PPPOE) ─────────────
  // Nullable porque IPoE não usa. Mantemos UNIQUE parcial via raw SQL.
  pppoeUsername       String?        @map("pppoe_username") @db.VarChar(64)
  pppoePassword       String?        @map("pppoe_password") @db.VarChar(128)

  // ── Identificação IPoE (preenchido só se authMethod = IPOE) ──────────────
  // circuitId (DHCP option 82, sub-option 1) é a chave primária quando o BNG
  // suporta. Formato livre — varia por fabricante:
  //   Huawei : "0/1/2:1.1"
  //   ZTE    : "gpon-onu_1/1/1:1"
  //   Mikrotik: "ether1/1/3" ou descritor custom
  // Decisão: campo de string livre (até 128 chars). Cada provedor cadastra
  // no formato que o NMS dele exporta.
  circuitId           String?        @map("circuit_id") @db.VarChar(128)
  // remoteId (option 82, sub-option 2) — opcional, complementa circuitId em
  // algumas vendors (geralmente identifica o switch/OLT).
  remoteId            String?        @map("remote_id") @db.VarChar(128)
  // MAC address do CPE — usado como fallback de auth quando o BNG não
  // consegue propagar circuit-id. Formato canonicalizado AA:BB:CC:DD:EE:FF.
  macAddress          String?        @map("mac_address") @db.VarChar(17)
  // IP fixo (opcional). Quando preenchido, vai como Framed-IP-Address no
  // radreply em vez de pegar do pool dinâmico.
  framedIpAddress     String?        @map("framed_ip_address") @db.VarChar(45)
  // VLAN ID (opcional) — alguns ISPs isolam cada cliente em VLAN dedicada.
  vlanId              Int?           @map("vlan_id")

  // Endereço de instalação (string simples agora; migrar depois para FK CustomerAddress)
  installationAddress String         @map("installation_address") @db.VarChar(500)
  // Link público de localização (Google Maps, OpenStreetMap, etc.) — opcional.
  installationMapsUrl String?        @map("installation_maps_url") @db.VarChar(500)

  // Comerciais
  monthlyValue        Decimal        @map("monthly_value") @db.Decimal(12, 2)
  bandwidthMbps       Int            @map("bandwidth_mbps")             // velocidade em Mbps
  dueDay              Int            @map("due_day")                    // 1..28

  // Estado
  status              ContractStatus        @default(ACTIVE)
  suspendReason       ContractSuspendReason? @map("suspend_reason")

  activatedAt         DateTime?      @map("activated_at")
  suspendedAt         DateTime?      @map("suspended_at")
  cancelledAt         DateTime?      @map("cancelled_at")

  // Religue de confiança: ao reativar um contrato suspenso por inadimplência
  // sem que o cliente tenha pago, o atendente concede um prazo. Cron diário
  // (OverdueScan) verifica e re-suspende quando este timestamp passar.
  // null = sem prazo de confiança ativo.
  trustExtensionUntil DateTime?      @map("trust_extension_until")

  notes               String?        @db.Text

  // ── Provisionamento (Fase 1 ZTP — vide modules/provisioning/) ─────────────
  // Wi-Fi configurado pelo técnico na instalação. Aplicado na ONT via TR-069
  // (Fase 3 — ACS próprio em apps/cwmp-server). Hoje só armazena pra UI/audit.
  // wifiPasswordEnc é criptografado at-rest com KMS_MASTER_KEY (LGPD: senha é
  // PII). Nunca retorna em response sem decrypt explícito + permissão.
  ssid                String?        @db.VarChar(32)
  wifiPasswordEnc     String?        @map("wifi_password_enc") @db.Text
  // ONT vinculada (1:1). Backed-by FK em Ont.contractId (Ont é o lado dono).
  // Aqui só pra navegação Prisma — não persiste coluna extra.

  createdById         String?        @map("created_by_id") @db.Uuid
  updatedById         String?        @map("updated_by_id") @db.Uuid

  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")

  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): impede deletar Customer com contratos. Admin
  // precisa explicitamente cancelar/arquivar contratos antes — preserva
  // histórico financeiro e de RADIUS. Migration: cascades_to_restrict_history.
  customer            Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy           User?          @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy           User?          @relation("ContractUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  invoices            ContractInvoice[]
  radiusEvents        RadiusEvent[]
  serviceOrders       ServiceOrder[]
  oneTimeCharges      OneTimeCharge[]
  // Estoque — Fase 2 (comodato)
  serialItems         SerialItem[]
  stockMovements      StockMovement[]
  // Provisionamento
  ont                 Ont?

  // pppoeUsername é unique por tenant quando preenchido (Postgres trata
  // múltiplos NULLs como distintos por padrão, então o unique normal funciona
  // — não precisa de index parcial). Mesmo critério vale pra circuitId/MAC.
  @@unique([tenantId, pppoeUsername])
  @@unique([tenantId, circuitId])
  @@unique([tenantId, macAddress])
  @@unique([tenantId, code])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@index([tenantId, dueDay])
  @@index([tenantId, authMethod])
  @@map("contracts")
}

model ContractInvoice {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  contractId   String         @map("contract_id") @db.Uuid

  // Denormalizado p/ histórico (cliente muda de valor, fatura mantém o valor cobrado)
  amount       Decimal        @db.Decimal(12, 2)
  dueDate      DateTime       @map("due_date") @db.Date
  issuedAt     DateTime       @default(now()) @map("issued_at")

  status       InvoiceStatus  @default(OPEN)
  paidAt       DateTime?      @map("paid_at")
  paidAmount   Decimal?       @map("paid_amount") @db.Decimal(12, 2)
  // Desconto aplicado no pagamento (positivo). Quando preenchido, paidAmount
  // = amount - discountAmount + (acréscimo, se houver). Exige perm
  // `finance.discount.apply` no service.
  discountAmount Decimal?     @map("discount_amount") @db.Decimal(12, 2)
  // Forma como o cliente pagou (independe do caixa).
  paidVia      PaymentMethod? @map("paid_via")
  // Caixa que recebeu o pagamento. Validado contra membership do user.
  cashRegisterId String?      @map("cash_register_id") @db.Uuid
  paymentNote  String?        @map("payment_note") @db.VarChar(255)

  // Referência textual p/ controle interno ex. "Mensalidade 05/2026"
  reference    String?        @db.VarChar(120)

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): faturas são histórico financeiro — não pode sumir
  // se contrato for deletado. Soft-delete no Contract é a operação correta.
  contract     Contract       @relation(fields: [contractId], references: [id], onDelete: Restrict)
  cashRegister CashRegister?  @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)

  // SIFEN — 0..N documentos (1 fatura pode ter Factura + Nota de Crédito, etc).
  sifenDocuments SifenDocument[]

  @@index([tenantId, contractId])
  @@index([tenantId, cashRegisterId])
  @@index([tenantId, status, dueDate])
  @@map("contract_invoices")
}

// Trilha de eventos de sincronização com RADIUS/Mikrotik.
// Inicialmente apenas registro em log; futuramente consumido por worker que
// aplica CoA/disconnect real e provisiona o pool correto.
enum RadiusAction {
  AUTHORIZE       // contrato ativo -> libera PPPoE
  BLOCK           // contrato suspenso -> pool bloqueados
  CANCEL          // contrato cancelado -> pool cancelados
  DISCONNECT      // força desconexão (CoA)
}

enum RadiusEventStatus {
  PENDING
  APPLIED
  FAILED
}

model RadiusEvent {
  id           String             @id @default(uuid()) @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  contractId   String             @map("contract_id") @db.Uuid
  action       RadiusAction
  status       RadiusEventStatus  @default(PENDING)
  // Identificador efetivo do contrato no RADIUS:
  //   PPPoE → username
  //   IPoE  → circuitId (ou MAC de fallback)
  // Mantemos o nome `pppoeUsername` por compat com radius-applier; novo
  // contratos IPoE armazenam o circuitId aqui.
  pppoeUsername String            @map("pppoe_username") @db.VarChar(128)
  targetPool   String?            @map("target_pool") @db.VarChar(64)
  note         String?            @db.VarChar(500)
  error        String?            @db.Text
  appliedAt    DateTime?          @map("applied_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): eventos RADIUS são histórico de auditoria —
  // não pode sumir se contrato for deletado. Útil pra reconstruir cenários
  // de fraude e compliance.
  contract     Contract           @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([tenantId, contractId, createdAt])
  @@index([tenantId, status])
  @@map("radius_events")
}

// =============================================================================
// SERVICE ORDERS (O.S — Ordens de Serviço)
// =============================================================================
// Cada O.S é uma demanda operacional vinculada a um contrato. Pode ser
// agendada, executada e finalizada com descrição. Cidade/estado são
// denormalizados pra filtros rápidos sem precisar JOIN no customer/address.
//
// Status:
//   - OPEN: criada, sem agendamento
//   - SCHEDULED: tem scheduledAt no futuro
//   - IN_PROGRESS: técnico iniciou (startedAt setado)
//   - COMPLETED: finalizada com closeDescription
//   - CANCELLED: cancelada
//   - OVERDUE: derivado em runtime (não persistido) — quando scheduledAt < now
//     e status ∈ {OPEN, SCHEDULED}.
enum ServiceOrderStatus {
  OPEN
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Cadastro de motivos para a O.S (config do tenant). O admin gerencia em
// /settings/service-order-reasons. Linha não é deletada — vira `isActive=false`
// pra preservar referências históricas.
model ServiceOrderReason {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(120)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  // Ordem de exibição em selects (asc).
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrders ServiceOrder[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive, order])
  @@map("service_order_reasons")
}

model ServiceOrder {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  contractId         String              @map("contract_id") @db.Uuid
  reasonId           String              @map("reason_id") @db.Uuid

  // Código humano (ex.: OS-000123). Gerado pelo service.
  code               String?             @db.VarChar(32)

  status             ServiceOrderStatus  @default(OPEN)

  // Datas do ciclo de vida.
  openedAt           DateTime            @default(now()) @map("opened_at")
  scheduledAt        DateTime?           @map("scheduled_at")
  startedAt          DateTime?           @map("started_at")
  completedAt        DateTime?           @map("completed_at")
  cancelledAt        DateTime?           @map("cancelled_at")

  // Descrições
  openDescription    String              @map("open_description") @db.Text
  closeDescription   String?             @map("close_description") @db.Text

  // Localização denormalizada (preenchida no create a partir do customer).
  city               String?             @db.VarChar(120)
  state              String?             @db.VarChar(120)

  // Atribuição opcional ao técnico/responsável.
  assignedToId       String?             @map("assigned_to_id") @db.Uuid

  createdById        String?             @map("created_by_id") @db.Uuid
  updatedById        String?             @map("updated_by_id") @db.Uuid

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): OS é histórico operacional/financeiro — preservar.
  contract           Contract            @relation(fields: [contractId], references: [id], onDelete: Restrict)
  reason             ServiceOrderReason  @relation(fields: [reasonId], references: [id], onDelete: Restrict)
  assignedTo         User?               @relation("ServiceOrderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy          User?               @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?               @relation("ServiceOrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  // Estoque — Fase 2 (consumo de material em OS)
  stockMovements     StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, city])
  @@index([tenantId, assignedToId, status])
  @@map("service_orders")
}

// =============================================================================
// FINANCE — Caixas, métodos de pagamento e cobranças avulsas
// =============================================================================

// Tipo do caixa. CASH = dinheiro físico (gaveta), BANK = conta bancária do
// provedor, PIX = chave PIX dedicada, CARD = maquininha. OTHER pra exceções.
enum CashRegisterType {
  CASH
  BANK
  PIX
  CARD
  OTHER
}

// Nível de acesso do usuário no caixa.
//  - OPERATOR: pode dar baixa de pagamento neste caixa.
//  - VIEWER:   só vê o saldo/histórico.
enum CashRegisterRole {
  OPERATOR
  VIEWER
}

// Forma de pagamento informada na hora de dar baixa. Independe do caixa
// (uma mesma maquininha pode ter PIX e CARD); preenchemos no Payment.
enum PaymentMethod {
  CASH
  PIX
  CARD
  BANK_TRANSFER
  OTHER
}

enum OneTimeChargeStatus {
  OPEN
  PAID
  CANCELLED
}

// Caixa do tenant. Cada um carrega um cadastro próprio (ex. "Caixa Loja
// Central", "Banco Itaú PJ", "PIX Notebook"). Permissão de visibilidade é
// via CashRegisterMembership — o user só vê os caixas em que tem entrada,
// EXCETO se tiver cash_registers.manage (admins veem todos).
model CashRegister {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid

  name           String           @db.VarChar(120)
  description    String?          @db.VarChar(500)
  type           CashRegisterType @default(CASH)
  color          String?          @db.VarChar(7) // hex (ex. #2563eb) — UI bonus
  currency       String           @db.Char(3)    // ISO 4217 — herda do tenant ao criar
  isActive       Boolean          @default(true) @map("is_active")
  // Saldo inicial — informativo. Os movimentos vêm do agregado de Payments.
  openingBalance Decimal          @default(0) @map("opening_balance") @db.Decimal(14, 2)

  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  tenant         Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships    CashRegisterMembership[]
  contractInvoices ContractInvoice[]
  oneTimeCharges OneTimeCharge[]
  movements      CashMovement[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("cash_registers")
}

model CashRegisterMembership {
  cashRegisterId String           @map("cash_register_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           CashRegisterRole @default(OPERATOR)
  createdAt      DateTime         @default(now()) @map("created_at")

  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cashRegisterId, userId])
  @@index([userId])
  @@map("cash_register_memberships")
}

// Cobrança avulsa — não vinculada a uma fatura recorrente de mensalidade.
// Casos: taxa de instalação, multa por dano, equipamento extra, taxa de
// visita técnica. Pode opcionalmente referenciar um Contract pra rastreio.
// Quando paga, registramos o caixa, método e desconto aplicado.
model OneTimeCharge {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  customerId     String              @map("customer_id") @db.Uuid
  contractId     String?             @map("contract_id") @db.Uuid

  code           String?             @db.VarChar(32) // CB-NNNNNN
  description    String              @db.VarChar(500)
  amount         Decimal             @db.Decimal(12, 2)
  dueDate        DateTime            @map("due_date") @db.Date
  issuedAt       DateTime            @default(now()) @map("issued_at")

  status         OneTimeChargeStatus @default(OPEN)

  // Pagamento (todos opcionais — preenchidos no /pay)
  paidAt         DateTime?           @map("paid_at")
  paidAmount     Decimal?            @map("paid_amount") @db.Decimal(12, 2)
  discountAmount Decimal?            @map("discount_amount") @db.Decimal(12, 2)
  paidVia        PaymentMethod?      @map("paid_via")
  cashRegisterId String?             @map("cash_register_id") @db.Uuid
  paymentNote    String?             @map("payment_note") @db.VarChar(500)

  createdById    String?             @map("created_by_id") @db.Uuid
  updatedById    String?             @map("updated_by_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): one-time charges são receita avulsa — histórico
  // financeiro idêntico a faturas; não pode sumir com delete de customer.
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("ChargeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?         @relation("ChargeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // SIFEN — 0..N documentos fiscais associados a essa cobrança avulsa.
  sifenDocuments SifenDocument[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, dueDate])
  @@index([tenantId, cashRegisterId])
  @@map("one_time_charges")
}

// Tipo do movimento financeiro num caixa.
enum CashMovementType {
  INCOME         // Entrada (pagamento recebido)
  OUTCOME        // Saída (sangria, pagamento de fornecedor)
  TRANSFER_IN    // Entrada vinda de transferência
  TRANSFER_OUT   // Saída por transferência
  ADJUSTMENT     // Ajuste manual de saldo
}

// Origem do movimento. INVOICE/CHARGE são automáticos (criados no /pay).
// TRANSFER cria 2 movements numa transação. MANUAL é criado direto pelo
// admin (sangria, ajuste).
enum CashMovementSource {
  INVOICE
  CHARGE
  TRANSFER
  MANUAL
}

model CashMovement {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  cashRegisterId  String              @map("cash_register_id") @db.Uuid

  type            CashMovementType
  source          CashMovementSource  @default(MANUAL)
  // Valor sempre positivo. O `type` define se soma ou subtrai no balance.
  amount          Decimal             @db.Decimal(14, 2)
  description     String?             @db.VarChar(500)
  occurredAt      DateTime            @default(now()) @map("occurred_at")

  // FK polimórfica simples — não vincula via Prisma relation porque a tabela
  // alvo varia (ContractInvoice ou OneTimeCharge). Indexada pra lookup.
  sourceId        String?             @map("source_id") @db.Uuid

  // Quando é uma transferência, os 2 movements (TRANSFER_OUT + TRANSFER_IN)
  // compartilham o mesmo transferGroupId pra rastreio.
  transferGroupId String?             @map("transfer_group_id") @db.Uuid

  createdById     String?             @map("created_by_id") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at")

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashRegister    CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("CashMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, cashRegisterId, occurredAt])
  @@index([transferGroupId])
  @@index([source, sourceId])
  @@map("cash_movements")
}

// =============================================================================
// BACKUPS — pg_dump on-demand (manual, sem criptografia ainda)
// =============================================================================
enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// Snapshot do banco inteiro (não por tenant — multi-tenant ainda baixo).
// O arquivo fica em BACKUP_DIR no FS do core-service. Storage S3/offsite
// é trabalho futuro.
model Backup {
  id            String       @id @default(uuid()) @db.Uuid
  // tenantId apenas pra auditoria de quem disparou — backup é do BD inteiro.
  tenantId      String       @map("tenant_id") @db.Uuid
  filename      String       @db.VarChar(255)
  status        BackupStatus @default(PENDING)
  sizeBytes     BigInt?      @map("size_bytes")
  durationMs    Int?         @map("duration_ms")
  errorMessage  String?      @map("error_message") @db.Text
  createdById   String?      @map("created_by_id") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")
  completedAt   DateTime?    @map("completed_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     User?  @relation("BackupCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([status])
  @@map("backups")
}

// =============================================================================
// MODULE — NETWORK (POPs + Equipamentos)
// =============================================================================
//
// POP (Point of Presence): site físico/lógico onde fica equipamento.
//   ex.: "POP Centro Asunción", "Datacenter Lambaré", "Torre CDE-1"
//
// Equipamento: BNG/OLT/Router/Switch que vive num POP.
//   - BNG: integra com RADIUS (radius.nas) automaticamente
//   - OLT: futuramente integra via SNMP/TR-069 pra autoconfig
//   - Router/Switch: cadastro só (CMDB enxuto)
// =============================================================================

model NetworkPop {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(120)
  code        String?  @db.VarChar(32)
  city        String?  @db.VarChar(120)
  state       String?  @db.VarChar(120)
  address     String?  @db.VarChar(500)
  notes       String?  @db.Text

  isActive    Boolean  @default(true) @map("is_active")

  createdById String?  @map("created_by_id") @db.Uuid
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?  @relation("NetworkPopCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?  @relation("NetworkPopUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  equipment   NetworkEquipment[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("network_pops")
}

enum NetworkEquipmentType {
  BNG
  OLT
  ROUTER
  SWITCH
  OTHER
}

enum NetworkEquipmentVendor {
  MIKROTIK
  HUAWEI
  ZTE
  FIBERHOME
  CISCO
  JUNIPER
  OTHER
}

/// Estratégia usada pra desconectar sessões de cliente (CoA/API/SSH).
/// AUTO escolhe baseado em vendor + authType do contrato:
///   - Mikrotik + IPoE → MIKROTIK_API (CoA não suportado pra DHCP no RouterOS)
///   - Mikrotik + PPPoE → COA
///   - Cisco/Juniper/Huawei (qualquer auth) → COA com payload do vendor
///   - Override: sshDisconnectCmd configurado → SSH (sempre vence)
enum DisconnectStrategy {
  AUTO
  COA
  MIKROTIK_API
  SSH
}

model NetworkEquipment {
  id          String                  @id @default(uuid()) @db.Uuid
  tenantId    String                  @map("tenant_id") @db.Uuid
  popId       String?                 @map("pop_id") @db.Uuid

  type        NetworkEquipmentType
  vendor      NetworkEquipmentVendor  @default(OTHER)

  name        String                  @db.VarChar(120)
  hostname    String?                 @db.VarChar(255)
  ipAddress   String                  @map("ip_address") @db.VarChar(45)

  // Específico de BNG (RADIUS) — quando preenchidos, sincronizamos com
  // radius.nas. nasType usa o vocabulário do FreeRADIUS (mikrotik, cisco,
  // juniper, other). secret é compartilhado com o equipamento.
  radiusSecret  String? @map("radius_secret") @db.VarChar(64)
  radiusNasType String? @map("radius_nas_type") @db.VarChar(30)

  // Específico de OLT/Router (SNMP futuro):
  snmpCommunity String? @map("snmp_community") @db.VarChar(64)
  snmpVersion   String? @map("snmp_version") @db.VarChar(10)

  // ───────────────────────────────────────────────────────────────────────
  // Disconnect (multi-vendor) — credenciais pra CoA/API/SSH
  // ───────────────────────────────────────────────────────────────────────
  // Strategy: AUTO infere por vendor+authType. Override quando o cenário
  // foge do padrão (ex: BNG Linux com script SSH custom).
  disconnectStrategy DisconnectStrategy @default(AUTO) @map("disconnect_strategy")
  coaPort            Int?               @map("coa_port")              // default 3799

  // RouterOS API (Mikrotik) — porta 8728 (plain) ou 8729 (TLS)
  apiHost            String?            @map("api_host")              // null → usa ipAddress
  apiPort            Int?               @map("api_port")
  apiUser            String?            @map("api_user")              @db.VarChar(64)
  apiPasswordEnc     String?            @map("api_password_enc")      @db.Text
  apiTlsEnabled      Boolean            @default(false) @map("api_tls_enabled")

  // SSH (fallback ou override) — comando customizado por equipment
  // Template aceita placeholders: {{macAddress}}, {{framedIp}}, {{username}},
  // {{acctSessionId}}, {{nasIp}}. Ex: "/ip dhcp-server lease remove [find mac-address={{macAddress}}]"
  sshHost            String?            @map("ssh_host")
  sshPort            Int?               @default(22) @map("ssh_port")
  sshUser            String?            @map("ssh_user")              @db.VarChar(64)
  sshPasswordEnc     String?            @map("ssh_password_enc")      @db.Text
  sshKeyName         String?            @map("ssh_key_name")          @db.VarChar(128)
  sshDisconnectCmd   String?            @map("ssh_disconnect_cmd")    @db.Text
  // Host key fingerprint "SHA256:<base64>" pra defesa MITM (ver migration
  // 20260517010000_equipment_ssh_host_key). NULL = strategy SSH bloqueada;
  // operador captura via test-connectivity (TOFU explícito).
  sshHostKey         String?            @map("ssh_host_key")           @db.Text

  // Última verificação de conectividade (Test connection)
  lastReachableAt    DateTime?          @map("last_reachable_at")
  lastReachError     String?            @map("last_reach_error")      @db.Text

  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")

  createdById String?  @map("created_by_id") @db.Uuid
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  pop         NetworkPop? @relation(fields: [popId], references: [id], onDelete: SetNull)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("NetworkEquipmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?       @relation("NetworkEquipmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, name])
  @@unique([tenantId, ipAddress])
  @@index([tenantId, type])
  @@index([popId])
  @@map("network_equipment")
}

// =============================================================================
// WhatsApp / Atendimento (Evolution API integration)
// =============================================================================
// Módulo de chat MVP: WhatsApp via Evolution API com multi-operador, sem URA,
// sem fluxos automáticos, sem templates. Apenas inbox compartilhada com
// atribuição manual e auditoria realtime.
//
// Webhook receiver em /v1/webhooks/evolution; SSE em /v1/whatsapp/stream.
// Mídia armazenada localmente em /var/lib/netx/whatsapp/media/.
// =============================================================================

enum WaInstanceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

enum WaConversationStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

enum WaMsgDirection {
  IN
  OUT
}

enum WaMsgType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  STICKER
  CONTACT
  UNKNOWN
}

enum WaMsgStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

/// Representa uma instância (sessão WhatsApp) gerenciada pelo Evolution API.
/// O MVP suporta múltiplas instâncias por tenant, mas a UI v1 mostra só a
/// primeira ativa — manter o `@@unique([tenantId, instanceName])` permite
/// crescer pra multi-instância depois sem schema migration.
model WhatsappInstance {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid

  name          String  @db.VarChar(120)                   // "Atendimento Principal"
  evolutionUrl  String  @map("evolution_url") @db.VarChar(255) @default("http://localhost:8080")
  apiKey        String  @map("api_key") @db.VarChar(255)   // criptografado at-rest
  instanceName  String  @map("instance_name") @db.VarChar(120) // nome no Evolution
  webhookSecret String  @map("webhook_secret") @db.VarChar(64)  // valida POST /webhooks/evolution

  phoneE164     String?  @map("phone_e164") @db.VarChar(20)  // número conectado
  status        WaInstanceStatus @default(DISCONNECTED)
  qrCode        String?  @map("qr_code") @db.Text             // base64 PNG quando aguardando scan
  lastError     String?  @map("last_error") @db.Text
  connectedAt   DateTime? @map("connected_at")

  active        Boolean @default(true)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations WhatsappConversation[]

  @@unique([tenantId, instanceName])
  @@index([tenantId, status])
  @@map("whatsapp_instances")
}

/// Contato com quem trocamos mensagens. Único por (tenant, número), não cresce
/// proporcional ao volume de mensagens. `customerId` é null até alguém linkar
/// (auto pelo `Customer.primaryPhone` ou manual no painel).
model WhatsappContact {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid

  phoneE164   String  @map("phone_e164") @db.VarChar(20)   // +595981234567
  pushName    String? @map("push_name") @db.VarChar(255)   // como aparece no WhatsApp
  customerId  String? @map("customer_id") @db.Uuid          // se reconhecido

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  conversations WhatsappConversation[]

  @@unique([tenantId, phoneE164])
  @@index([tenantId, customerId])
  @@map("whatsapp_contacts")
}

/// Thread de conversa entre uma instância e um contato. Status OPEN é o
/// inbox; RESOLVED some do inbox principal; ARCHIVED some de tudo. Apenas
/// uma conversa OPEN por (instance, contact) — re-abre a existente se nova
/// mensagem chegar de contato com conversa RESOLVED.
model WhatsappConversation {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  instanceId     String  @map("instance_id") @db.Uuid
  contactId      String  @map("contact_id") @db.Uuid

  status         WaConversationStatus @default(OPEN)
  assignedUserId String?  @map("assigned_user_id") @db.Uuid
  assignedAt     DateTime? @map("assigned_at")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedById   String?  @map("resolved_by_id") @db.Uuid

  lastMessageAt  DateTime  @map("last_message_at")
  lastInboundAt  DateTime? @map("last_inbound_at")           // p/ "tem nova msg?"
  unreadCount    Int       @default(0) @map("unread_count")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance       WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  contact        WhatsappContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser   User?  @relation("WaConversationAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  messages       WhatsappMessage[]
  views          WhatsappConversationView[]

  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, assignedUserId])
  @@index([instanceId, contactId])
  @@map("whatsapp_conversations")
}

/// Mensagem individual. Direction IN = recebida do cliente; OUT = enviada
/// pelo NetX (com `fromUserId` apontando pro operador). `evolutionMsgId`
/// é único pra dedup quando o webhook do Evolution reentrega.
model WhatsappMessage {
  id              String  @id @default(uuid()) @db.Uuid
  conversationId  String  @map("conversation_id") @db.Uuid

  direction       WaMsgDirection
  type            WaMsgType
  body            String? @db.Text                         // texto ou caption
  mediaUrl        String? @map("media_url") @db.VarChar(500) // path local ou URL
  mediaMimeType   String? @map("media_mime_type") @db.VarChar(100)
  mediaSize       Int?    @map("media_size")               // bytes

  evolutionMsgId  String?  @unique @map("evolution_msg_id") @db.VarChar(120)
  fromUserId      String?  @map("from_user_id") @db.Uuid    // null se IN
  status          WaMsgStatus @default(SENT)
  errorReason     String?  @map("error_reason") @db.Text

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  conversation    WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromUser        User? @relation("WaMessageFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("whatsapp_messages")
}

/// Auditoria realtime: registra cada vez que um usuário abre uma conversa
/// que NÃO está atribuída a ele. Permite "espionar" mas deixa rastro.
/// Combinado com AuditLog (action=whatsapp.conversation.viewed) pra trail
/// completa em compliance LGPD.
model WhatsappConversationView {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  viewerUserId   String   @map("viewer_user_id") @db.Uuid

  viewedAt       DateTime @default(now()) @map("viewed_at")

  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  viewer         User @relation(fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, viewedAt])
  @@index([viewerUserId, viewedAt])
  @@map("whatsapp_conversation_views")
}

// =============================================================================
// SIFEN — Sistema Integrado de Facturación Electrónica Nacional (Paraguay)
// =============================================================================
// Cada DTE (Documento Tributario Electrónico) emitido pro SIFEN da DNIT.
// Vinculado a uma ContractInvoice (mensalidade) ou OneTimeCharge (avulsa).
// Mantém XML em 3 versões (gerado / assinado / enviado) pra audit fiscal.
//
// Veja docs/sifen-integration.md (TODO) e Manual Técnico v150:
// https://www.dnit.gov.py/documents/20123/420592/Manual+Técnico+Versión+150.pdf

enum SifenDocumentType {
  FACTURA       // Tipo 1 — mensalidade, taxa, serviço
  NOTA_CREDITO  // Tipo 5 — devolução, desconto retroativo
  NOTA_DEBITO   // Tipo 6 — juros, multa, ajuste
  AUTOFACTURA   // Tipo 4 — compra de não contribuinte (raro p/ ISP)
  NOTA_REMISION // Tipo 7 — entrega de CPE/ONU (não fiscal)
}

enum SifenDocumentStatus {
  DRAFT     // Persistido localmente, ainda não assinado
  SIGNED    // Assinado com CCFE, pronto pra enviar
  SENT      // Enviado pro SIFEN, aguarda resposta
  APPROVED  // SIFEN aprovou — vira DTE com efeito fiscal
  REJECTED  // SIFEN rejeitou — corrigir e re-emitir (CDC novo)
  CANCELLED // Cancelado via evento pós-emissão (até 48h)
}

model SifenDocument {
  id                  String              @id @default(uuid()) @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid

  // Vínculos opcionais com a origem do documento. Pelo menos um deve estar
  // preenchido. ContractInvoice = mensalidade; OneTimeCharge = avulsa.
  contractInvoiceId   String?             @map("contract_invoice_id") @db.Uuid
  oneTimeChargeId     String?             @map("one_time_charge_id") @db.Uuid

  type                SifenDocumentType
  status              SifenDocumentStatus @default(DRAFT)

  // Número fiscal — único por (tenant, establecimiento, puntoExpedicion).
  // Formato impresso: "001-001-0000001" (estab-punto-numero, padding 7).
  // Sem buracos: cancelar NÃO recicla número.
  establecimiento     String              @db.VarChar(3)
  puntoExpedicion     String              @map("punto_expedicion") @db.VarChar(3)
  numero              Int                 // contador sequencial; @@unique abaixo

  // CDC (Código de Control): 44 chars determinístico, calculado a partir de
  // RUC + timbrado + tipo + estab + punto + número + data + tipoEmissão +
  // código de segurança aleatório (9 dígitos) + DV. É o "código de barras"
  // do DTE — vai no QR e na URL de consulta pública.
  cdc                 String              @unique @db.VarChar(44)

  // Identificadores fiscais denormalizados (não dependem de relação)
  emisorRuc           String              @map("emisor_ruc") @db.VarChar(20)
  emisorTimbrado      String              @map("emisor_timbrado") @db.VarChar(8)
  receptorTaxId       String?             @map("receptor_tax_id") @db.VarChar(32)
  receptorName        String?             @map("receptor_name") @db.VarChar(255)

  // Valor total do documento (denormalizado)
  totalAmount         Decimal             @map("total_amount") @db.Decimal(14, 2)
  currency            String              @default("PYG") @db.Char(3)

  // Versões do XML (Text, podem ser grandes — ~5-10KB cada)
  xmlGenerated        String?             @map("xml_generated") @db.Text
  xmlSigned           String?             @map("xml_signed") @db.Text
  xmlSent             String?             @map("xml_sent") @db.Text

  // Resposta crua do SIFEN (envelope SOAP). Útil pra debug + audit.
  sifenResponse       Json?               @map("sifen_response")
  rejectionCode       String?             @map("rejection_code") @db.VarChar(20)
  rejectionReason     String?             @map("rejection_reason") @db.Text

  // QR code URL (consulta pública do DTE no portal SIFEN)
  qrUrl               String?             @map("qr_url") @db.Text

  // Timestamps relevantes
  issuedAt            DateTime            @map("issued_at")
  signedAt            DateTime?           @map("signed_at")
  sentAt              DateTime?           @map("sent_at")
  approvedAt          DateTime?           @map("approved_at")
  rejectedAt          DateTime?           @map("rejected_at")
  cancelledAt         DateTime?           @map("cancelled_at")

  // Retry de envio (em caso de timeout / 5xx do SIFEN)
  retryCount          Int                 @default(0) @map("retry_count")
  lastError           String?             @map("last_error") @db.Text
  nextRetryAt         DateTime?           @map("next_retry_at")

  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractInvoice     ContractInvoice?    @relation(fields: [contractInvoiceId], references: [id], onDelete: SetNull)
  oneTimeCharge       OneTimeCharge?      @relation(fields: [oneTimeChargeId], references: [id], onDelete: SetNull)

  // Numeração sequencial sem buracos por (tenant, estab, punto)
  @@unique([tenantId, establecimiento, puntoExpedicion, numero], map: "sifen_doc_numero_uniq")
  @@index([tenantId, status, issuedAt(sort: Desc)])
  @@index([tenantId, type, issuedAt(sort: Desc)])
  @@index([contractInvoiceId])
  @@index([oneTimeChargeId])
  @@index([nextRetryAt], map: "sifen_doc_retry_idx")
  @@map("sifen_documents")
}

// =============================================================================
// MÓDULO ESTOQUE — Fase 1
// =============================================================================
// Cobre: catálogo de produtos, fornecedores, locais de estoque com ACL,
// compras com seriais, saldo por (produto, local), kardex completo, custo
// médio ponderado global por produto.
//
// Fase 2 (próxima): Sale, comodato (vínculo com Contract), consumo em OS.
// =============================================================================

enum ProductType {
  PATRIMONIAL // unidade rastreada por serial (router, ONU) — comodato
  CONSUMIVEL  // qty rastreada (cabo, conector) — consumo em OS
}

enum SerialStatus {
  IN_STOCK     // disponível em algum local
  ALLOCATED    // em comodato com cliente (Fase 2: contract_id setado)
  IN_TRANSIT   // entre locais
  DEFECTIVE    // com defeito, aguardando RMA/descarte
  WRITTEN_OFF  // baixado contábil
}

enum MovementType {
  PURCHASE          // entrada — compra de fornecedor
  PURCHASE_RETURN   // saída — devolução pro fornecedor
  SALE              // saída — venda avulsa (Fase 2)
  SALE_RETURN       // entrada — devolução do cliente
  COMODATO_OUT      // saída — equipamento ao cliente (Fase 2)
  COMODATO_RETURN   // entrada — retorno de equipamento (Fase 2)
  OS_CONSUMPTION    // saída — consumo em OS (Fase 2)
  ADJUSTMENT_IN     // entrada — ajuste de inventário (achado)
  ADJUSTMENT_OUT    // saída — ajuste de inventário (perda, dano)
  TRANSFER_OUT      // saída — transferência entre locais
  TRANSFER_IN       // entrada — par do TRANSFER_OUT
}

model Supplier {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  taxId       String?  @map("tax_id") @db.VarChar(32) // CNPJ/RUC/etc
  taxIdType   String?  @map("tax_id_type") @db.VarChar(16) // CNPJ | RUC | DNI | ...
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(40)
  address     String?  @db.VarChar(500)
  city        String?  @db.VarChar(120)
  state       String?  @db.VarChar(120)
  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@unique([tenantId, taxId, taxIdType])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@map("suppliers")
}

model Product {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  sku          String      @db.VarChar(64)
  name         String      @db.VarChar(255)
  description  String?     @db.Text
  brand        String?     @db.VarChar(120)
  model        String?     @db.VarChar(120)
  type         ProductType
  unit         String      @default("un") @db.VarChar(16) // un, m, kg, pç, cx
  // Custo médio ponderado global (recalculado a cada PURCHASE / ADJUSTMENT_IN).
  // Decimal(14,4) cobre cents fracionários típicos de cálculo médio
  // (ex.: 1234,5678 / unit). Saída usa este custo pra avaliar a movimentação.
  cost         Decimal     @default(0) @db.Decimal(14, 4)
  // Preço de venda (consultivo — venda real pode override). Optional.
  price        Decimal?    @db.Decimal(14, 4)
  // Alerta de estoque baixo. Quando saldo global cai abaixo, badge na UI.
  minStock     Decimal?    @default(0) @map("min_stock") @db.Decimal(14, 4)
  isActive     Boolean     @default(true) @map("is_active")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serialItems  SerialItem[]
  stockLevels  StockLevel[]
  movements    StockMovement[]
  purchaseItems PurchaseItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, type])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@map("products")
}

model StockLocation {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String   @db.VarChar(40)  // "DEP-MATRIZ", "VAN-JOAO"
  name        String   @db.VarChar(120) // "Depósito Matriz", "Caminhão João"
  address     String?  @db.VarChar(500)
  // Trava: não pode deletar local com saldo > 0 ou seriais alocados.
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userAccess   StockLocationUser[]
  stockLevels  StockLevel[]
  serialItems  SerialItem[]
  movementsFrom StockMovement[]    @relation("MovementFromLocation")
  movementsTo   StockMovement[]    @relation("MovementToLocation")
  purchaseItems PurchaseItem[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("stock_locations")
}

// ACL many-to-many: quais users operam quais locais.
// Filtro padrão das listagens: WHERE location_id IN (select location_id from
// stock_location_users where user_id = current_user).
// Roles com permissão `stock.admin` bypass — vêem todos os locais do tenant.
model StockLocationUser {
  locationId String  @map("location_id") @db.Uuid
  userId     String  @map("user_id") @db.Uuid
  canWrite   Boolean @default(true) @map("can_write") // false = read-only nesse local

  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([locationId, userId])
  @@index([userId])
  @@map("stock_location_users")
}

// Saldo de CONSUMÍVEIS por (produto, local). Patrimoniais NÃO usam esta tabela
// — saldo deles é COUNT(SerialItem WHERE status='IN_STOCK' AND location_id=X
// AND product_id=Y). Manter ambos na mesma tabela criaria desync.
model StockLevel {
  tenantId   String   @map("tenant_id") @db.Uuid // denorm pra índice
  productId  String   @map("product_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  quantity   Decimal  @default(0) @db.Decimal(14, 4)
  updatedAt  DateTime @updatedAt @map("updated_at")

  product  Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([productId, locationId])
  @@index([tenantId, productId])
  @@index([tenantId, locationId])
  @@map("stock_levels")
}

// Unidade patrimonial (1 row = 1 equipamento físico com serial).
model SerialItem {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  productId       String       @map("product_id") @db.Uuid
  serial          String       @db.VarChar(120)
  status          SerialStatus @default(IN_STOCK)
  locationId      String?      @map("location_id") @db.Uuid // null se status != IN_STOCK e != IN_TRANSIT

  // Vínculo com contrato — preenchido em Fase 2 (operação ALLOCATE = comodato).
  // FK em migration 20260520000000_stock_phase2_comodato_consumption.
  contractId      String?      @map("contract_id") @db.Uuid

  acquisitionCost Decimal?     @map("acquisition_cost") @db.Decimal(14, 4)
  acquisitionDate DateTime?    @map("acquisition_date")
  allocatedAt     DateTime?    @map("allocated_at")
  returnedAt      DateTime?    @map("returned_at")
  notes           String?      @db.Text

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  location  StockLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  // SetNull: se contrato for deletado (hoje bloqueado por Restrict em Contract→
  // Customer; defensive aqui), serial volta ao "limbo" sem contrato. Status NÃO
  // muda automaticamente — operador deve devolver via UI/comodato.return.
  contract  Contract?       @relation(fields: [contractId], references: [id], onDelete: SetNull)
  movements StockMovement[]

  @@unique([tenantId, productId, serial])
  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([tenantId, locationId, status])
  @@map("serial_items")
}

// Kardex completo — every stock-affecting operation gera linhas aqui.
// Fonte da verdade pra reconciliação e auditoria. Saldo é derivado mas
// cacheado em StockLevel/SerialItem pra performance.
model StockMovement {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  type           MovementType
  productId      String         @map("product_id") @db.Uuid
  serialItemId   String?        @map("serial_item_id") @db.Uuid // se patrimonial

  // Direção:
  //   Entradas (PURCHASE, ADJ_IN, TRANSFER_IN, etc): toLocationId setado, fromLocationId null
  //   Saídas:                                       fromLocationId setado, toLocationId null
  //   Transfer cria PAR: TRANSFER_OUT (from setado) + TRANSFER_IN (to setado)
  fromLocationId String?        @map("from_location_id") @db.Uuid
  toLocationId   String?        @map("to_location_id") @db.Uuid

  quantity       Decimal        @db.Decimal(14, 4)
  unitCost       Decimal        @map("unit_cost") @db.Decimal(14, 4)
  totalCost      Decimal        @map("total_cost") @db.Decimal(14, 4)

  // Referências polimórficas — só uma é populada conforme o type:
  //   PURCHASE / PURCHASE_RETURN   → purchaseId
  //   COMODATO_OUT / COMODATO_RETURN → contractId (Fase 2)
  //   OS_CONSUMPTION                → serviceOrderId (Fase 2)
  //   ADJUSTMENT_IN/OUT, TRANSFER_* → todas null
  //   SALE / SALE_RETURN            → dormente (não usado; operação só faz comodato)
  purchaseId     String?        @map("purchase_id") @db.Uuid
  contractId     String?        @map("contract_id") @db.Uuid
  serviceOrderId String?        @map("service_order_id") @db.Uuid

  notes          String?        @db.Text
  createdById    String         @map("created_by_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")

  product      Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  serialItem   SerialItem?    @relation(fields: [serialItemId], references: [id], onDelete: SetNull)
  fromLocation StockLocation? @relation("MovementFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation   StockLocation? @relation("MovementToLocation",   fields: [toLocationId],   references: [id], onDelete: SetNull)
  purchase     Purchase?      @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  contract     Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)
  serviceOrder ServiceOrder?  @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  createdBy    User           @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, productId, createdAt(sort: Desc)])
  @@index([tenantId, type, createdAt(sort: Desc)])
  @@index([purchaseId])
  @@index([serialItemId])
  @@index([contractId])
  @@index([serviceOrderId])
  @@map("stock_movements")
}

model Purchase {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  supplierId    String         @map("supplier_id") @db.Uuid
  // Número da NF-e/factura do fornecedor (texto livre pra suportar vários formatos)
  invoiceNumber String?        @map("invoice_number") @db.VarChar(64)
  date          DateTime
  totalCost     Decimal        @map("total_cost") @db.Decimal(14, 4)
  notes         String?        @db.Text
  createdById   String         @map("created_by_id") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier  Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User            @relation("PurchaseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items     PurchaseItem[]
  movements StockMovement[]

  @@unique([tenantId, supplierId, invoiceNumber])
  @@index([tenantId, date(sort: Desc)])
  @@index([supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid // denorm
  purchaseId   String   @map("purchase_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  locationId   String   @map("location_id") @db.Uuid // onde foi recebido
  quantity     Decimal  @db.Decimal(14, 4)
  unitCost     Decimal  @map("unit_cost") @db.Decimal(14, 4)
  totalCost    Decimal  @map("total_cost") @db.Decimal(14, 4)
  // Seriais cadastrados nesta entrada (1 array de N strings, N = quantity pra patrimonial).
  // Pra consumível, fica vazio. Validado no service.
  serials      String[] @default([]) // será desnormalizado em SerialItem rows
  notes        String?  @db.Text

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

// =============================================================================
// PROVISIONAMENTO (OLT/ONT + TR-069 ACS) — Fase 1
// =============================================================================
// Modela o fluxo de ativação de cliente em campo:
//   1. Vendedor cria Contract com status=PENDING_INSTALL (sem ONT vinculada)
//   2. Técnico abre /provisioning/install/:contractId no celular, escolhe OLT,
//      digita SN GPON da ONT, preenche SSID + senha Wi-Fi
//   3. ProvisioningService chama OltDriver.authorize() → cria Ont row
//   4. (Fase 3) Tr069Task enfileira SET_PARAMS + REBOOT pro ACS aplicar Wi-Fi
//   5. RadiusSyncService enfileira AUTHORIZE → cliente online no pool ativos
//
// Multi-provider: Olt.providerMode discrimina entre OLT direta (Parks/Huawei
// SSH) e orquestrador externo (Ufinet API). Driver-pattern em
// modules/provisioning/drivers/* esconde a diferença.

enum OltVendor {
  HUAWEI       // MA5800-X2/X7/X17, MA5608T, EA5800 — SSH CLI
  ZTE          // C300, C320, C600, C610, C650 — SSH CLI
  DATACOM      // DM4610, DM4615, DM4170 — NETCONF
  FIBERHOME    // AN5516-01/04/06 — SSH CLI
  NOKIA        // 7360 FX, ISAM — NETCONF
  PARKS        // OLT 4830-G, 4840-G — SSH CLI
  UFINET       // rede neutra PY — API orquestrador, não OLT direta
  GENERIC      // fallback / dev
}

// DIRECT: NetX fala direto com a OLT (SSH/NETCONF) — operação BR típica.
// ORCHESTRATOR: NetX chama API de um terceiro (Ufinet, wholesale) que abstrai
// a OLT física. Operação PY hoje.
enum OltProviderMode {
  DIRECT
  ORCHESTRATOR
}

enum OltStatus {
  ONLINE       // testConnection() OK na última checagem
  OFFLINE      // testConnection() falhou
  UNREACHABLE  // sem rota / timeout
  UNKNOWN      // ainda não testou
}

model Olt {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @map("tenant_id") @db.Uuid
  name                String          @db.VarChar(128)         // "OLT POP-Centro"
  vendor              OltVendor
  model               String          @db.VarChar(64)          // "MA5800-X7", "C320"
  providerMode        OltProviderMode @default(DIRECT) @map("provider_mode")

  // ── DIRECT mode (SSH/NETCONF) ────────────────────────────────────────────
  managementIp        String?         @map("management_ip") @db.Inet
  sshPort             Int             @default(22) @map("ssh_port")
  sshUser             String?         @map("ssh_user") @db.VarChar(64)
  // Senha SSH criptografada com KMS_MASTER_KEY (mesma chave que .secrets).
  // Nunca retorna em response sem decrypt explícito + permissão olts.admin.
  sshPasswordEnc      String?         @map("ssh_password_enc") @db.Text
  // Pra Huawei: senha do modo `enable` (privileged exec).
  enableSecretEnc     String?         @map("enable_secret_enc") @db.Text

  // ── ORCHESTRATOR mode (API REST) ─────────────────────────────────────────
  apiEndpoint         String?         @map("api_endpoint") @db.VarChar(255)
  apiAuthType         String?         @map("api_auth_type") @db.VarChar(32)  // "OAUTH2"|"API_KEY"|"MTLS"
  apiCredentialsEnc   String?         @map("api_credentials_enc") @db.Text   // JSON encrypted
  apiWebhookSecret    String?         @map("api_webhook_secret") @db.VarChar(128)

  // ── Defaults aplicados nas provisões (override por contrato possível) ────
  serviceVlanId       Int?            @map("service_vlan_id")
  defaultUpProfile    String?         @map("default_up_profile") @db.VarChar(64)
  defaultDownProfile  String?         @map("default_down_profile") @db.VarChar(64)

  // ── Telemetria ───────────────────────────────────────────────────────────
  status              OltStatus       @default(UNKNOWN)
  lastSeenAt          DateTime?       @map("last_seen_at")
  lastError           String?         @map("last_error") @db.Text

  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")

  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  onts                Ont[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("olts")
}

// Estado da ONT no ciclo de vida:
//   PENDING_AUTH: criada no NetX mas authorize() na OLT ainda não rodou
//   AUTHORIZED  : OLT aceitou o SN, esperando ONT registrar/sincronizar
//   ONLINE      : ONT registrada e operacional (lastSeenAt recente)
//   OFFLINE     : ONT estava ONLINE mas parou de reportar (lastSeenAt antigo)
//   LOS         : Loss of Signal — fibra caiu fisicamente
//   FAULT       : erro persistente reportado pela OLT (firmware/hardware)
enum OntStatus {
  PENDING_AUTH
  AUTHORIZED
  ONLINE
  OFFLINE
  LOS
  FAULT
}

model Ont {
  id                  String       @id @default(uuid()) @db.Uuid
  tenantId            String       @map("tenant_id") @db.Uuid
  contractId          String       @unique @map("contract_id") @db.Uuid
  oltId               String       @map("olt_id") @db.Uuid

  // SN GPON da ONT — identificador único entregue pela Huawei no preset.
  // Formato típico: "HWTC12AB34CD" (Huawei), "ZTEG..." (ZTE), "ALCL..." (Nokia).
  // Case-insensitive na consulta (citext seria ideal mas mantemos varchar
  // pra compat — comparação UPPER() no service).
  snGpon              String       @map("sn_gpon") @db.VarChar(32)
  // MAC da WAN da ONT — pode chegar via Inform TR-069 ou via Accounting
  // RADIUS. Usado como identificador RADIUS (Contract.macAddress).
  macAddress          String?      @map("mac_address") @db.VarChar(17)
  // Serial físico (etiqueta na carcaça) — opcional, pra inventário.
  serialPhysical      String?      @map("serial_physical") @db.VarChar(64)

  // Posicionamento na OLT (frame/slot/onu-index). Em ORCHESTRATOR mode pode
  // ficar null se o provider não expõe.
  ponFrame            Int?         @map("pon_frame")
  ponSlot             Int?         @map("pon_slot")
  ponOnuIndex         Int?         @map("pon_onu_index")

  status              OntStatus    @default(PENDING_AUTH)
  // Métricas ópticas (atualizadas por driver poll ou webhook). dBm.
  lastRxPower         Decimal?     @map("last_rx_power") @db.Decimal(6, 2)
  lastTxPower         Decimal?     @map("last_tx_power") @db.Decimal(6, 2)

  authorizedAt        DateTime?    @map("authorized_at")
  lastSeenAt          DateTime?    @map("last_seen_at")
  lastError           String?      @map("last_error") @db.Text

  // Notas livres do técnico (ex.: "ONT colada atrás do quadro").
  notes               String?      @db.Text

  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict: ONT é histórico — cancelamento do contrato deve fazer soft-delete
  // ou desautorizar via driver, mas não sumir a row.
  contract            Contract     @relation(fields: [contractId], references: [id], onDelete: Restrict)
  // Restrict tb na OLT — não dá pra deletar OLT com ONTs vinculadas.
  olt                 Olt          @relation(fields: [oltId], references: [id], onDelete: Restrict)
  tr069Device         Tr069Device?

  // SN único por OLT (não global — duas OLTs podem ter SNs iguais em
  // ambientes de teste, embora real-world seja improvável).
  @@unique([oltId, snGpon])
  @@unique([oltId, ponFrame, ponSlot, ponOnuIndex])
  @@index([tenantId, status])
  @@index([tenantId, macAddress])
  @@map("onts")
}

// =============================================================================
// TR-069 / CWMP — registro de devices ACS
// =============================================================================
// Fase 1: schema + stubs. apps/cwmp-server (Fase 3) vai popular essa tabela
// quando CPEs fazem Inform na porta 7547. Por hora as rows são criadas pelo
// ProvisioningService como placeholder pra UI mostrar "aguardando Inform".

model Tr069Device {
  id                       String   @id @default(uuid()) @db.Uuid
  tenantId                 String   @map("tenant_id") @db.Uuid
  // ONT vinculada (1:1 quando o device é uma ONT GPON gerenciada pelo NetX).
  // Pode ser null se cadastrarmos CPEs sem ONT (ex.: roteador downstream
  // BYOD no futuro).
  ontId                    String?  @unique @map("ont_id") @db.Uuid

  // OUI-Serial — chave de identificação CWMP. Formato: "<OUI>-<SerialNumber>".
  // Ex.: Huawei "00259E-HWTC12AB34CD". Único globalmente por TR-069 spec.
  deviceId                 String   @unique @map("device_id") @db.VarChar(128)

  // Atributos reportados no Inform (cacheados pra UI/filtro):
  manufacturer             String?  @db.VarChar(64)
  oui                      String?  @db.VarChar(6)
  productClass             String?  @map("product_class") @db.VarChar(64)
  hardwareVersion          String?  @map("hardware_version") @db.VarChar(32)
  softwareVersion          String?  @map("software_version") @db.VarChar(32)
  provisioningCode         String?  @map("provisioning_code") @db.VarChar(128)

  // Connection Request — endpoint do CPE que aceita trigger (NetX → CPE) pra
  // forçar sessão imediata. Em rede neutra com NAT geralmente é unreachable;
  // confiamos no Periodic Inform.
  connectionRequestUrl     String?  @map("connection_request_url") @db.VarChar(255)
  connectionRequestUser    String?  @map("connection_request_user") @db.VarChar(64)
  connectionRequestPwdEnc  String?  @map("connection_request_pwd_enc") @db.Text

  // Snapshot completo dos parameters lidos no último GetParameterValues
  // (JSON). Útil pra debug e dashboards. Caro pra storage — TTL implícito
  // (overwrite a cada Inform).
  parametersSnapshot       Json?    @map("parameters_snapshot")

  // Estado:
  status                   String   @default("UNKNOWN") @db.VarChar(32)
                                    // "UNKNOWN"|"ONLINE"|"OFFLINE"|"PROVISIONING"
  lastInformAt             DateTime? @map("last_inform_at")
  lastInformReason         String?   @map("last_inform_reason") @db.VarChar(64)
                                    // "0 BOOTSTRAP"|"1 BOOT"|"2 PERIODIC"|...

  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ont                      Ont?     @relation(fields: [ontId], references: [id], onDelete: SetNull)
  tasks                    Tr069Task[]

  @@index([tenantId, status])
  @@index([tenantId, lastInformAt])
  @@map("tr069_devices")
}

enum Tr069TaskAction {
  SET_PARAMS       // SetParameterValues
  GET_PARAMS       // GetParameterValues
  REBOOT           // Reboot()
  FACTORY_RESET    // FactoryReset()
  DOWNLOAD         // Download() — firmware upgrade (futuro)
  ADD_OBJECT       // AddObject() — criar instância (ex.: nova WLAN)
  DELETE_OBJECT
}

enum Tr069TaskStatus {
  PENDING          // aguardando próximo Inform
  RUNNING          // entregue ao CPE no fim do session, aguardando ack
  DONE             // CPE confirmou aplicação
  FAILED           // CPE retornou fault ou timeout
  CANCELLED        // operador cancelou antes de aplicar
}

model Tr069Task {
  id           String           @id @default(uuid()) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  deviceId     String           @map("device_id") @db.Uuid
  // Acrescenta rastreabilidade pro contrato — facilita debug ("qual task
  // criou esse Wi-Fi?")
  contractId   String?          @map("contract_id") @db.Uuid

  action       Tr069TaskAction
  // Payload depende da action:
  //   SET_PARAMS: { params: [{ name, value, type }] }
  //   GET_PARAMS: { names: string[] }
  //   REBOOT/FACTORY_RESET: {}
  //   DOWNLOAD: { url, fileType, targetFileName, ... }
  payload      Json
  // Response do CPE (faults + parameter snapshots).
  result       Json?

  status       Tr069TaskStatus  @default(PENDING)
  attempts     Int              @default(0)
  error        String?          @db.Text

  // FIFO por device: applier processa em ordem de createdAt ASC.
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  startedAt    DateTime?        @map("started_at")
  completedAt  DateTime?        @map("completed_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device       Tr069Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, status])
  @@index([tenantId, status, createdAt])
  @@map("tr069_tasks")
}

// =============================================================================
// PROVISIONING_EVENT — trilha de auditoria do orquestrador
// =============================================================================
// Cada chamada de driver (authorize, deauthorize, status poll) gera 1 evento.
// Histórico imutável pra debug ("por que cliente X não subiu?"). Separado de
// audit_log pq tem retenção/cardinalidade diferentes — provisioning gera muito
// volume e merece índice próprio.

enum ProvisioningEventStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
}

enum ProvisioningEventAction {
  OLT_AUTHORIZE
  OLT_DEAUTHORIZE
  OLT_STATUS_POLL
  OLT_TEST_CONNECTION
  TR069_TASK_ENQUEUE
  TR069_INFORM_RECEIVED
  RADIUS_ENQUEUE
  CONTRACT_ACTIVATE
}

model ProvisioningEvent {
  id           String                  @id @default(uuid()) @db.Uuid
  tenantId     String                  @map("tenant_id") @db.Uuid
  contractId   String?                 @map("contract_id") @db.Uuid
  ontId        String?                 @map("ont_id") @db.Uuid
  oltId        String?                 @map("olt_id") @db.Uuid

  action       ProvisioningEventAction
  status       ProvisioningEventStatus @default(PENDING)
  // Detalhes da chamada (input, response, fault). JSON pra flexibilidade
  // entre drivers — cada driver loga seu próprio formato.
  payload      Json?
  error        String?                 @db.Text
  durationMs   Int?                    @map("duration_ms")

  // Quem disparou (técnico em campo, cron, webhook).
  actorUserId  String?                 @map("actor_user_id") @db.Uuid
  actorKind    String                  @default("user") @map("actor_kind") @db.VarChar(32)
                                       // "user"|"cron"|"webhook"|"system"

  createdAt    DateTime                @default(now()) @map("created_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, contractId, createdAt])
  @@index([tenantId, ontId])
  @@index([tenantId, status, createdAt])
  @@map("provisioning_events")
}
