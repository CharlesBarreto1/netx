generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto, citext, pg_trgm, postgis]
}

// -----------------------------------------------------------------------------
// TENANT
// -----------------------------------------------------------------------------
enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CHURNED
}

/// O `Tenant` representa **a empresa (ISP) inteira** atendida por esta
/// instância NetX. Cada instalação atende **exatamente um Tenant**.
///
/// Por que existe a abstração mesmo sendo singleton na prática?
///   1. Isolamento futuro: se um dia oferecermos NetX hosted (multi-ISP em
///      um VPS gerenciado pela NetX), o código já está pronto.
///   2. Cooperativas/revenda: pequenos ISPs em coop podem compartilhar
///      hardware mantendo dados separados (caso real no Brasil).
///   3. RBAC limpo: todas as queries já carregam tenantId, evita bugs de
///      vazamento entre dados de um futuro segundo tenant.
///
/// O modelo SaaS multi-tenant compartilhado **foi descartado** como
/// produto principal porque:
///   - RADIUS exige baixa latência (Mikrotik time-out 200ms)
///   - LGPD/soberania de dados (ISP não compartilha DB com concorrente)
///   - Blast radius (1 bug afeta 1 ISP, não todas)
///
/// Veja `docs/architecture/tenancy.md` pra contexto completo.
model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  slug        String       @unique @db.VarChar(63) // used in subdomain
  name        String       @db.VarChar(255)
  legalName   String?      @map("legal_name") @db.VarChar(255)
  taxId       String?      @map("tax_id") @db.VarChar(32) // CNPJ, RFC, EIN, etc.
  country     String       @db.Char(2) // ISO 3166-1 alpha-2
  locale      String       @default("pt-BR") @db.VarChar(10)
  timezone    String       @default("America/Sao_Paulo") @db.VarChar(64)
  currency    String       @default("BRL") @db.Char(3) // ISO 4217
  // Prefixo de 3 letras pro código sequencial de contrato ({prefix}-{seq},
  // ex.: ZUX-1). Configurável pela operação. Null = derivado do slug.
  contractPrefix String?   @map("contract_prefix") @db.VarChar(3)
  // Prefixo do código de patrimônio ({prefix}-{seq}, ex.: PAT-000123).
  // Null = derivado do slug, mesmo helper do contractPrefix. Mais folga que o
  // contractPrefix porque etiqueta de patrimônio costuma carregar o setor
  // ("ZUXPAT"), não só a sigla do tenant.
  assetPrefix String?   @map("asset_prefix") @db.VarChar(8)
  status      TenantStatus @default(TRIAL)
  domains     String[]     @default([]) // custom domains
  logoUrl     String?      @map("logo_url")
  primaryColor String?     @map("primary_color") @db.VarChar(7)
  trialEndsAt DateTime?    @map("trial_ends_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  settings    TenantSetting[]
  features    TenantFeature[]
  users       User[]
  roles       Role[]
  sessions    Session[]
  apiKeys     ApiKey[]
  oidcSigningKeys OidcSigningKey[]
  oidcPayloads    OidcPayload[]
  auditLogs   AuditLog[]
  customers   Customer[]
  customerTags CustomerTag[]
  pipelines   Pipeline[]
  deals       Deal[]
  activities  Activity[]
  contracts   Contract[]
  plans       Plan[]
  contractInvoices ContractInvoice[]
  radiusEvents RadiusEvent[]
  serviceOrders        ServiceOrder[]
  serviceOrderReasons  ServiceOrderReason[]
  serviceOrderPhotos   ServiceOrderPhoto[]
  serviceOrderMessages    ServiceOrderMessage[]
  serviceOrderAttachments ServiceOrderAttachment[]
  cashRegisters        CashRegister[]
  oneTimeCharges       OneTimeCharge[]
  cashMovements        CashMovement[]
  cashMovementAttachments CashMovementAttachment[]
  backups              Backup[]
  networkPops          NetworkPop[]
  networkEquipment     NetworkEquipment[]
  opticalEnclosures    OpticalEnclosure[]
  opticalPorts         OpticalPort[]
  fiberCables          FiberCable[]
  fiberSplices         FiberSplice[]
  fiberEvents          FiberEvent[]
  networkFolders       NetworkFolder[]
  ponPorts             PonPort[]

  // FiberMap (OSP v2 — FIBERMAP-SPEC.md)
  fibermapFolders             FibermapFolder[]
  fibermapProducts            FibermapProduct[]
  fibermapCableModels         FibermapCableModel[]
  fibermapElements            FibermapElement[]
  fibermapElementPhotos       FibermapElementPhoto[]
  fibermapCables              FibermapCable[]
  fibermapCableSegments       FibermapCableSegment[]
  fibermapFibers              FibermapFiber[]
  fibermapCableSlacks         FibermapCableSlack[]
  fibermapDevices             FibermapDevice[]
  fibermapOpticalPorts        FibermapOpticalPort[]
  fibermapFiberCuts           FibermapFiberCut[]
  fibermapOpticalConnections  FibermapOpticalConnection[]
  fibermapConnectionEndpoints FibermapConnectionEndpoint[]
  fibermapOtdrReadings        FibermapOtdrReading[]
  fibermapPowerMeasurements   FibermapPowerMeasurement[]
  fibermapAttenuationDefaults FibermapAttenuationDefault[]

  // WhatsApp / Atendimento
  whatsappInstances    WhatsappInstance[]
  whatsappContacts     WhatsappContact[]
  whatsappConversations WhatsappConversation[]
  nexusOperators       NexusOperator[]
  whatsappTemplates    WhatsappTemplate[]
  whatsappBotConfig    WhatsappBotConfig?
  whatsappQuickReplies WhatsappQuickReply[]
  notifications        Notification[]
  billingReminderConfig BillingReminderConfig?
  billingReminderRules BillingReminderRule[]

  // SIFEN — fatura eletrônica Paraguay (módulo opcional, ligado via env)
  sifenDocuments       SifenDocument[]

  // NFCom — fatura de serviço de comunicação BR (modelo 62, módulo opcional)
  nfcomConfig          NfcomConfig?
  nfcomDocuments       NfcomDocument[]

  // Estoque (Fase 1)
  suppliers            Supplier[]
  products             Product[]
  stockLocations       StockLocation[]
  purchases            Purchase[]

  // Provisionamento (Fase 1 — OLT/ONT + TR-069 ACS Fase 3)
  olts                 Olt[]
  onts                 Ont[]
  oltProvisioningProfiles OltProvisioningProfile[]
  alarmEvents          AlarmEvent[]
  incidents            Incident[]
  alarmPolicy          AlarmPolicy?
  tr069Devices         Tr069Device[]
  tr069Firmwares       Tr069Firmware[]
  tr069Tasks           Tr069Task[]
  tr069Diagnostics     Tr069Diagnostic[]
  tr069Alerts          Tr069Alert[]
  tr069DiagRuns        Tr069DiagnosticRun[]
  tr069Profiles        Tr069Profile[]
  tr069Drifts          Tr069Drift[]
  tr069DeviceNotes     Tr069DeviceNote[]
  provisioningEvents   ProvisioningEvent[]
  ufinetServices       UfinetService[]
  wifiOptWaves         WifiOptWave[]
  wifiOptWaveDevices   WifiOptWaveDevice[]

  // Mobile
  mobileDevices        MobileDevice[]

  // Frota (Fleet)
  vehicles             Vehicle[]
  drivers              Driver[]
  fleetExpenses        FleetExpense[]
  maintenancePlans     MaintenancePlan[]
  maintenanceRecords   MaintenanceRecord[]
  vehiclePositions     VehiclePosition[]

  // RH (Recursos Humanos / colaboradores)
  employees            Employee[]
  employeeDocuments    EmployeeDocument[]
  documentSignatures   DocumentSignature[]
  timeEntries          TimeEntry[]
  timeCorrectionRequests TimeCorrectionRequest[]
  payslips             Payslip[]
  salaryPayments       SalaryPayment[]
  supplierPayables     SupplierPayable[]
  companyPosts         CompanyPost[]

  // EFI (pagamentos BR — Pix imediato + Bolix)
  efiConfig            EfiConfig?
  efiCharges           EfiCharge[]

  // BTG (pagamentos BR — boleto + Pix cobrança + Pix Automático)
  btgConfig            BtgConfig?
  tr069Config          Tr069TenantConfig?
  hubsoftConfig        HubsoftConfig?
  btgCharges           BtgCharge[]
  btgRecurrences       BtgRecurrence[]

  // IA (motor de IA por tenant — pacote @netx/ai)
  aiConfig             AiConfig?
  aiUsageLogs          AiUsageLog[]
  aiInsights          AiInsight[]

  // IPAM (documentação de IPs + CGNAT determinístico)
  ipamVrfs             IpamVrf[]
  ipamPrefixes         IpamPrefix[]
  ipamAddresses        IpamAddress[]
  ipamPools            IpamPool[]
  ipamCgnatPlans       IpamCgnatPlan[]
  ipamCgnatEntries     IpamCgnatEntry[]

  // NMS (série temporal do painel — baseline dos alarmes de tendência)
  networkSnapshots     NetworkSnapshot[]

  @@index([status])
  @@index([country])
  @@map("tenants")
}

// =============================================================================
// LICENCIAMENTO — estado local da licença desta INSTALAÇÃO com a NetX (nós).
// Singleton: 1 linha (id fixo "singleton"). Não tem tenantId — é sobre a
// instalação inteira, não sobre um tenant. O token é renovado pelo heartbeat
// diário; o guard valida a assinatura localmente. Ver docs/licensing.md.
// =============================================================================
model LicenseState {
  id              String    @id @default("singleton")
  // Token JWS Ed25519 atual (assinado pelo Hub). Null = nunca recebeu.
  token           String?   @db.Text
  // Espelho desnormalizado das claims pra consulta rápida / painel.
  status          String?   @db.VarChar(16) // ACTIVE | BLOCKED | SUSPENDED
  expiresAt       DateTime? @map("expires_at")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at")
  lastError       String?   @map("last_error") @db.VarChar(500)
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("license_state")
}

model TenantSetting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String   @db.VarChar(128)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("tenant_settings")
}

model TenantFeature {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  feature   String   @db.VarChar(128) // "module.radius", "module.fiscal.br", ...
  enabled   Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature])
  @@map("tenant_features")
}

// -----------------------------------------------------------------------------
// USER
// -----------------------------------------------------------------------------
enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String     @map("tenant_id") @db.Uuid
  email          String     @db.Citext
  emailVerified  Boolean    @default(false) @map("email_verified")
  passwordHash   String?    @map("password_hash") // null for SSO-only users
  firstName      String     @map("first_name") @db.VarChar(120)
  lastName       String     @map("last_name") @db.VarChar(120)
  phone          String?    @db.VarChar(32)
  avatarUrl      String?    @map("avatar_url")
  locale         String?    @db.VarChar(10) // overrides tenant default
  timezone       String?    @db.VarChar(64)
  status         UserStatus @default(INVITED)
  lastLoginAt    DateTime?  @map("last_login_at")
  lastLoginIp    String?    @map("last_login_ip") @db.Inet
  mfaEnabled     Boolean    @default(false) @map("mfa_enabled")
  mfaSecret      String?    @map("mfa_secret")
  mfaBackupCodes String[]   @default([]) @map("mfa_backup_codes")
  /// Quando true, força redirect pra /first-login no próximo login bem-sucedido.
  /// Setado pelo seed (admin default), pelo installer (admin do tenant), e
  /// quando admin reseta a senha de outro user. Limpado pelo POST
  /// /v1/users/me/change-password ao fim do flow.
  mustChangePassword Boolean @default(false) @map("must_change_password")
  // Override de visibilidade de menus por usuário. Quando null (default), o
  // sidebar usa só permissões. Quando array (ex. ["dashboard","customers"]),
  // o sidebar intersecta com essa lista — útil pra esconder menus que o user
  // teria permissão mas o admin quer ocultar individualmente.
  menuAccess     Json?      @map("menu_access")
  // Preferências do operador no Chat/Atendimento: { greeting: string,
  // showName: boolean }. greeting = saudação automática disparada ao "Assumir"
  // (placeholders {cliente}/{operador}); showName = exibir o nome do operador
  // nas mensagens enviadas. Null = padrões (sem saudação, mostra nome).
  chatPrefs      Json?      @map("chat_prefs")
  invitedById    String?    @map("invited_by_id") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy    User?      @relation("UserInvites", fields: [invitedById], references: [id])
  invites      User[]     @relation("UserInvites")
  nexusOperators NexusOperator[]
  userRoles    UserRole[]
  sessions     Session[]
  auditLogs    AuditLog[]
  customersCreated Customer[] @relation("CustomerCreatedBy")
  customersUpdated Customer[] @relation("CustomerUpdatedBy")
  customerNotes    CustomerNote[]
  customerTagAssignments CustomerTagAssignment[]

  // Deals / Activities (CRM sales)
  dealsOwned       Deal[]          @relation("DealOwner")
  dealsCreated     Deal[]          @relation("DealCreatedBy")
  dealsUpdated     Deal[]          @relation("DealUpdatedBy")
  dealHistoryEvents DealHistory[]
  activitiesOwned  Activity[]      @relation("ActivityOwner")
  activitiesCreated Activity[]     @relation("ActivityCreatedBy")
  activitiesCompleted Activity[]   @relation("ActivityCompletedBy")

  // Contracts
  contractsCreated Contract[]      @relation("ContractCreatedBy")
  contractsUpdated Contract[]      @relation("ContractUpdatedBy")

  // Service Orders
  serviceOrdersAssigned ServiceOrder[] @relation("ServiceOrderAssignedTo")
  serviceOrdersCreated  ServiceOrder[] @relation("ServiceOrderCreatedBy")
  serviceOrdersUpdated  ServiceOrder[] @relation("ServiceOrderUpdatedBy")
  serviceOrderMessages    ServiceOrderMessage[]    @relation("ServiceOrderMessageAuthor")
  serviceOrderAttachments ServiceOrderAttachment[] @relation("ServiceOrderAttachmentBy")

  // Finance — caixas que o user opera + cobranças avulsas que criou
  cashRegisterMemberships CashRegisterMembership[]
  chargesCreated   OneTimeCharge[] @relation("ChargeCreatedBy")
  chargesUpdated   OneTimeCharge[] @relation("ChargeUpdatedBy")
  cashMovementsCreated CashMovement[] @relation("CashMovementCreatedBy")
  cashMovementAttachmentsCreated CashMovementAttachment[] @relation("CashMovementAttachmentBy")
  backupsCreated       Backup[]       @relation("BackupCreatedBy")
  networkPopsCreated   NetworkPop[]   @relation("NetworkPopCreatedBy")
  networkPopsUpdated   NetworkPop[]   @relation("NetworkPopUpdatedBy")
  networkEqCreated     NetworkEquipment[] @relation("NetworkEquipmentCreatedBy")
  networkEqUpdated     NetworkEquipment[] @relation("NetworkEquipmentUpdatedBy")
  opticalEnclosuresCreated OpticalEnclosure[] @relation("OpticalEnclosureCreatedBy")
  opticalEnclosuresUpdated OpticalEnclosure[] @relation("OpticalEnclosureUpdatedBy")
  fiberCablesCreated   FiberCable[]   @relation("FiberCableCreatedBy")
  fiberCablesUpdated   FiberCable[]   @relation("FiberCableUpdatedBy")
  fiberSplicesCreated  FiberSplice[]  @relation("FiberSpliceCreatedBy")
  fiberSplicesUpdated  FiberSplice[]  @relation("FiberSpliceUpdatedBy")
  fiberSplicesMeasured FiberSplice[]  @relation("FiberSpliceMeasuredBy")
  networkFoldersCreated NetworkFolder[] @relation("NetworkFolderCreatedBy")
  fiberEventsReported   FiberEvent[]    @relation("FiberEventReportedBy")
  fiberEventsResolved   FiberEvent[]    @relation("FiberEventResolvedBy")

  // FiberMap (OSP v2)
  fibermapFoldersCreated  FibermapFolder[]  @relation("FibermapFolderCreatedBy")
  fibermapProductsCreated FibermapProduct[] @relation("FibermapProductCreatedBy")
  fibermapProductsUpdated FibermapProduct[] @relation("FibermapProductUpdatedBy")
  fibermapElementsCreated FibermapElement[] @relation("FibermapElementCreatedBy")
  fibermapElementsUpdated FibermapElement[] @relation("FibermapElementUpdatedBy")
  fibermapCablesCreated   FibermapCable[]   @relation("FibermapCableCreatedBy")
  fibermapCablesUpdated   FibermapCable[]   @relation("FibermapCableUpdatedBy")
  fibermapDevicesCreated  FibermapDevice[]  @relation("FibermapDeviceCreatedBy")
  fibermapDevicesUpdated  FibermapDevice[]  @relation("FibermapDeviceUpdatedBy")
  fibermapConnsCreated    FibermapOpticalConnection[] @relation("FibermapConnCreatedBy")
  fibermapConnsUpdated    FibermapOpticalConnection[] @relation("FibermapConnUpdatedBy")

  // WhatsApp / Atendimento
  whatsappConversationsAssigned WhatsappConversation[] @relation("WaConversationAssignee")
  whatsappMessagesSent          WhatsappMessage[]      @relation("WaMessageFromUser")
  whatsappConversationViews     WhatsappConversationView[]
  whatsappConversationMembers   WhatsappConversationMember[] @relation("WaConversationMember")
  whatsappQuickReplies          WhatsappQuickReply[]   @relation("WaQuickReplyOwner")
  notifications                 Notification[]

  // Estoque (Fase 1)
  stockLocationAccess  StockLocationUser[]
  stockMovementsCreated StockMovement[] @relation("StockMovementCreatedBy")
  purchasesCreated      Purchase[]      @relation("PurchaseCreatedBy")
  purchasesUpdated      Purchase[]      @relation("PurchaseUpdatedBy")
  supplierPayablesCreated SupplierPayable[] @relation("SupplierPayableCreatedBy")

  // Mobile (app do técnico em campo)
  mobileDevices       MobileDevice[]

  // Frota (Fleet)
  driverProfiles            Driver[]            @relation("DriverUser")
  vehiclesCreated           Vehicle[]           @relation("VehicleCreatedBy")
  vehiclesUpdated           Vehicle[]           @relation("VehicleUpdatedBy")
  driversCreated            Driver[]            @relation("DriverCreatedBy")
  driversUpdated            Driver[]            @relation("DriverUpdatedBy")
  fleetExpensesCreated      FleetExpense[]      @relation("FleetExpenseCreatedBy")
  maintenancePlansCreated   MaintenancePlan[]   @relation("MaintenancePlanCreatedBy")
  maintenanceRecordsCreated MaintenanceRecord[] @relation("MaintenanceRecordCreatedBy")

  // RH — vínculo do login ao colaborador + autoria/aprovação de registros
  employeeProfile           Employee?           @relation("EmployeeUser")
  employeesCreated          Employee[]          @relation("EmployeeCreatedBy")
  employeesUpdated          Employee[]          @relation("EmployeeUpdatedBy")
  employeeDocumentsUploaded EmployeeDocument[]  @relation("EmployeeDocumentUploadedBy")
  timeEntriesCreated        TimeEntry[]         @relation("TimeEntryCreatedBy")
  timeCorrectionsReviewed   TimeCorrectionRequest[] @relation("TimeCorrectionReviewedBy")
  payslipsCreated           Payslip[]           @relation("PayslipCreatedBy")
  salaryPaymentsCreated     SalaryPayment[]     @relation("SalaryPaymentCreatedBy")
  companyPostsAuthored      CompanyPost[]       @relation("CompanyPostAuthor")

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([email])
  @@map("users")
}

// -----------------------------------------------------------------------------
// RBAC: ROLE, PERMISSION, JOIN TABLES
// -----------------------------------------------------------------------------
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid // NULL => system role (global)
  name        String   @db.VarChar(64)
  description String?  @db.VarChar(255)
  isSystem    Boolean  @default(false) @map("is_system") // seeded/immutable
  priority    Int      @default(100) // lower = higher priority
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(128) // "users.create", "invoices.read", ...
  resource    String   @db.VarChar(64)          // "users"
  action      String   @db.VarChar(32)          // "create" | "read" | "update" | "delete" | custom
  description String?  @db.VarChar(255)
  module      String   @db.VarChar(64)          // "core", "crm", "billing", ...
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// -----------------------------------------------------------------------------
// SESSION / REFRESH TOKEN
// -----------------------------------------------------------------------------
model Session {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") // SHA-256 of refresh JWT
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  ip               String?   @db.Inet
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastUsedAt       DateTime  @default(now()) @map("last_used_at")

  // Step-up (reautenticação) pra ações privilegiadas do NetX Field (ex.:
  // desbloqueio de cliente). elevatedUntil = janela curta (5min) em que a
  // sessão está "elevada". Sobrevive a refresh (a flag mora na sessão, não no
  // token — o claim mfa decai no refresh). Ver StepUpGuard.
  elevatedAt       DateTime? @map("elevated_at")
  elevatedUntil    DateTime? @map("elevated_until")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// -----------------------------------------------------------------------------
// API KEY (service-to-service / automations)
// -----------------------------------------------------------------------------
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String    @db.VarChar(128)
  keyHash    String    @unique @map("key_hash") // bcrypt/argon2 of the API key
  keyPrefix  String    @map("key_prefix") @db.VarChar(12) // displayable prefix (netx_live_...)
  scopes     String[]  @default([])
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  createdBy  String?   @map("created_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

// -----------------------------------------------------------------------------
// OIDC — CHAVES DE ASSINATURA
// -----------------------------------------------------------------------------

enum OidcKeyStatus {
  ACTIVE // assina tokens novos e é publicada no JWKS
  RETIRED // não assina mais, mas segue no JWKS até expiresAt (tokens em voo)
}

/// Par de chaves que assina os tokens OIDC de um tenant.
///
/// Uma chave por tenant assinando por vez — o índice parcial
/// `oidc_signing_keys_one_active_per_tenant` garante isso no banco, não só na
/// aplicação. Rotação: a chave nova entra como ACTIVE, a antiga vira RETIRED e
/// continua publicada no JWKS até `expiresAt`, senão os tokens já emitidos
/// deixariam de verificar no meio da vida útil.
///
/// A privada é PKCS#8 PEM cifrada pelo CryptoService (AES-256-GCM com
/// KMS_MASTER_KEY) — nunca em claro no banco nem em variável de ambiente.
model OidcSigningKey {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  /// JWK Thumbprint (RFC 7638) da chave pública. Vai no header dos JWT.
  kid           String        @unique @db.VarChar(64)
  alg           String        @default("RS256") @db.VarChar(10)
  /// Chave pública em JWK, servida direto no endpoint /jwks.
  publicJwk     Json          @map("public_jwk")
  privateKeyEnc String        @map("private_key_enc")
  status        OidcKeyStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  retiredAt     DateTime?     @map("retired_at")
  /// Quando some do JWKS. Só faz sentido em chave RETIRED.
  expiresAt     DateTime?     @map("expires_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("oidc_signing_keys")
}

/// Persistência dos artefatos efêmeros do oidc-provider (panva).
///
/// Uma tabela genérica em vez de uma por tipo: são ~13 tipos (AuthorizationCode,
/// RefreshToken, Grant, Session, Interaction, DeviceCode...) cujo payload é
/// opaco para nós, dura de minutos a dias, e nunca é consultado à mão. Modelar
/// 13 tabelas para dado descartável é custo sem retorno — e acompanhar mudança
/// de schema da lib viraria migration a cada upgrade.
///
/// A PK é composta porque o id do oidc-provider só é único DENTRO do tipo:
/// existe Session "abc" e Interaction "abc" ao mesmo tempo.
///
/// `sub` é desnormalizado do payload de propósito: a revogação no desligamento
/// precisa apagar tudo de um usuário sem varrer JSON de todas as linhas.
model OidcPayload {
  type       String    @db.VarChar(64)
  id         String    @db.VarChar(255)
  tenantId   String    @map("tenant_id") @db.Uuid
  payload    Json
  grantId    String?   @map("grant_id") @db.VarChar(255)
  userCode   String?   @map("user_code") @db.VarChar(64)
  uid        String?   @db.VarChar(255)
  /// User.id dono do artefato. Null em artefato que ainda não tem usuário.
  sub        String?   @db.VarChar(255)
  expiresAt  DateTime? @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([type, id])
  @@index([grantId])
  @@index([uid])
  @@index([userCode])
  @@index([tenantId, sub])
  @@index([expiresAt])
  @@map("oidc_payloads")
}



// -----------------------------------------------------------------------------
// AUDIT LOG (append-only)
// -----------------------------------------------------------------------------
enum AuditLevel {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String?    @map("tenant_id") @db.Uuid // NULL for system-level events
  userId       String?    @map("user_id") @db.Uuid
  actor        String?    @db.VarChar(128) // "api-key:xxx", "system", "webhook", etc.
  action       String     @db.VarChar(128) // "user.login.success", "invoice.created", ...
  resource     String?    @db.VarChar(64)
  resourceId   String?    @map("resource_id") @db.VarChar(64)
  level        AuditLevel @default(INFO)
  ip           String?    @db.Inet
  userAgent    String?    @map("user_agent") @db.VarChar(512)
  beforeState  Json?      @map("before_state")
  afterState   Json?      @map("after_state")
  metadata     Json?
  createdAt    DateTime   @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([resource, resourceId])
  @@index([userId])
  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// Idempotência de requisições (replay-safe) — NetX Field / offline-first.
// A outbox do app reenvia mutações com o header `Idempotency-Key`. O servidor
// dedupa por (tenant, key): se a op já completou, devolve a resposta guardada
// em vez de reaplicar (ex.: NUNCA reconsome material da van num retry). Ver
// IdempotencyInterceptor (common/interceptors). Sem FK Prisma pro tenant pra
// não exigir back-relation em Tenant — a FK/RLS moram na migration.
// -----------------------------------------------------------------------------
model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  key          String   @db.VarChar(200)
  method       String   @db.VarChar(8)
  path         String   @db.VarChar(500)
  status       String   @db.VarChar(16) // 'pending' | 'completed'
  statusCode   Int?     @map("status_code")
  responseBody Json?    @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, key])
  @@index([tenantId, createdAt])
  @@map("idempotency_keys")
}

// =============================================================================
// MODULE 2 — CRM
//
// Entidades:
//   - Customer            (PF ou PJ, multi-país via TaxIdType)
//   - CustomerAddress     (1..N endereços por cliente, tipados)
//   - CustomerContact     (1..N emails/fones, opt-in por canal)
//   - CustomerTag         (catálogo de tags por tenant)
//   - CustomerTagAssignment (N..N cliente↔tag)
//   - CustomerConsent     (LGPD/GDPR: propósito + status + timestamps)
//   - CustomerNote        (histórico livre, autor + pinned)
// =============================================================================

enum CustomerType {
  INDIVIDUAL   // Pessoa Física
  COMPANY      // Pessoa Jurídica
}

enum CustomerStatus {
  LEAD
  PROSPECT
  ACTIVE
  SUSPENDED
  INACTIVE
  CHURNED
}

enum TaxIdType {
  // Brasil
  CPF
  CNPJ
  // Paraguay
  CI
  RUC
  // Placeholders futuros (validators adicionados por país)
  VAT     // EU
  NIF     // Espanha/Portugal
  RFC     // México
  CUIT    // Argentina
  RUT     // Chile
  NIT     // Colômbia
  SSN     // USA (individual)
  EIN     // USA (company)
  OTHER
}

enum AddressType {
  BILLING      // faturamento
  SERVICE      // endereço de instalação do serviço
  SHIPPING     // envio de equipamentos
  OTHER
}

enum ContactType {
  EMAIL
  PHONE
  MOBILE
  WHATSAPP
  TELEGRAM
  OTHER
}

enum ConsentPurpose {
  MARKETING_EMAIL
  MARKETING_SMS
  MARKETING_WHATSAPP
  MARKETING_VOICE
  DATA_PROCESSING
  THIRD_PARTY_SHARING
  CREDIT_SCORE_QUERY
  CONTRACT_NOTIFICATION
  SUPPORT_RECORDING
  OTHER
}

enum ConsentStatus {
  GRANTED
  REVOKED
  PENDING
  EXPIRED
}

enum ConsentMethod {
  WEB_FORM
  EMAIL
  IN_PERSON
  VOICE
  API
  IMPORT
  OTHER
}

// -----------------------------------------------------------------------------
// CUSTOMER
// -----------------------------------------------------------------------------
model Customer {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  code            String?        @db.VarChar(32)                    // código humano ex. CLI-000123
  type            CustomerType
  status          CustomerStatus @default(LEAD)

  // Identificação PF
  firstName       String?        @map("first_name") @db.VarChar(120)
  lastName        String?        @map("last_name") @db.VarChar(120)
  birthDate       DateTime?      @map("birth_date") @db.Date
  gender          String?        @db.VarChar(32)
  motherName      String?        @map("mother_name") @db.VarChar(255)

  // Identificação PJ
  companyName     String?        @map("company_name") @db.VarChar(255) // razão social
  tradeName       String?        @map("trade_name") @db.VarChar(255)   // nome fantasia
  foundedAt       DateTime?      @map("founded_at") @db.Date
  stateRegistration String?      @map("state_registration") @db.VarChar(64)
  municipalRegistration String?  @map("municipal_registration") @db.VarChar(64)

  // Comum / busca
  displayName     String         @map("display_name") @db.VarChar(255) // desnormalizado para busca
  taxId           String?        @map("tax_id") @db.VarChar(32)
  taxIdType       TaxIdType?     @map("tax_id_type")
  taxIdCountry    String?        @map("tax_id_country") @db.Char(2)    // ISO 3166-1 alpha-2
  taxIdVerifiedAt DateTime?      @map("tax_id_verified_at")

  primaryEmail    String?        @map("primary_email") @db.Citext
  primaryPhone    String?        @map("primary_phone") @db.VarChar(32)

  preferredLanguage String?      @map("preferred_language") @db.VarChar(10)
  timezone          String?      @db.VarChar(64)

  shortNote       String?        @map("short_note") @db.VarChar(500)   // nota rápida (ex. "cliente VIP")
  metadata        Json?          // campo livre por tenant

  // Portal do cliente — acesso self-service.
  // Operador gera um código de 8 caracteres no detalhe do cliente; nós só
  // guardamos o hash Argon2id. O cliente entra com (taxId, código). Token
  // tem TTL configurável; após expirar, operador gera novo código.
  portalAccessHash      String?   @map("portal_access_hash") @db.VarChar(255)
  portalAccessExpiresAt DateTime? @map("portal_access_expires_at")
  portalLastLoginAt     DateTime? @map("portal_last_login_at")

  createdById     String?        @map("created_by_id") @db.Uuid
  updatedById     String?        @map("updated_by_id") @db.Uuid

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?             @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?             @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  addresses       CustomerAddress[]
  contacts        CustomerContact[]
  consents        CustomerConsent[]
  notes           CustomerNote[]
  tagAssignments  CustomerTagAssignment[]
  deals           Deal[]
  activities      Activity[]
  contracts       Contract[]
  oneTimeCharges  OneTimeCharge[]
  whatsappContacts WhatsappContact[]

  // IPAM — blocos/IPs corporativos atribuídos direto ao cliente
  ipamPrefixes    IpamPrefix[]
  ipamAddresses   IpamAddress[]
  ipamCgnatEntries IpamCgnatEntry[]

  @@unique([tenantId, code])
  @@unique([tenantId, taxId, taxIdType])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, displayName])
  @@index([tenantId, primaryEmail])
  @@index([tenantId, primaryPhone])
  @@index([tenantId, createdAt])
  @@map("customers")
}

// -----------------------------------------------------------------------------
// CUSTOMER ADDRESS
// -----------------------------------------------------------------------------
model CustomerAddress {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  type        AddressType @default(BILLING)
  label       String?     @db.VarChar(64)                  // "Casa", "Escritório"

  country     String      @db.Char(2)                      // ISO alpha-2
  state       String?     @db.VarChar(120)
  city        String      @db.VarChar(120)
  district    String?     @db.VarChar(120)                 // bairro
  street      String      @db.VarChar(255)
  number      String?     @db.VarChar(32)
  complement  String?     @db.VarChar(120)
  postalCode  String?     @map("postal_code") @db.VarChar(16)
  ibgeCode    String?     @map("ibge_code") @db.Char(7)        // IBGE do município (fiscal BR)

  latitude    Decimal?    @db.Decimal(9, 6)
  longitude   Decimal?    @db.Decimal(9, 6)

  isPrimary   Boolean     @default(false) @map("is_primary")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([tenantId, postalCode])
  @@index([tenantId, city])
  @@map("customer_addresses")
}

// -----------------------------------------------------------------------------
// LOCATION REGISTRY (BR) — endereço estruturado por tenant
//
// Substitui o texto livre do endereço de instalação por seleção num cadastro-
// mestre hierárquico: Cidade(IBGE) -> Bairro -> Rua(CEP), deixando livres só
// número e complemento. Habilitado só p/ tenants BR (Tenant.country = 'BR');
// PY segue em texto livre. IbgeMunicipality é referência NACIONAL (global,
// read-only, seed do IBGE) e alimenta o codMunicipio do módulo fiscal (NFCom).
// City/Neighborhood/Street são por tenant (multi-tenant estrito).
// -----------------------------------------------------------------------------

/// Município brasileiro do IBGE. Global (sem tenant). Seed via API do IBGE.
/// codigo = código IBGE de 7 dígitos.
model IbgeMunicipality {
  codigo String @id @db.Char(7)
  nome   String @db.VarChar(120)
  uf     String @db.Char(2)

  cities City[]

  @@index([uf])
  @@index([nome])
  @@map("ibge_municipalities")
}

/// Cidade operada pelo ISP. Por tenant. Carrega o código IBGE (FK pro
/// município) pra alimentar o módulo fiscal.
model City {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  ibgeCode  String   @map("ibge_code") @db.Char(7)
  name      String   @db.VarChar(120)
  uf        String   @db.Char(2)
  active    Boolean  @default(true)
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  municipality  IbgeMunicipality @relation(fields: [ibgeCode], references: [codigo])
  neighborhoods Neighborhood[]
  streets       Street[]

  @@unique([tenantId, ibgeCode])
  @@index([tenantId, name])
  @@map("cities")
}

/// Bairro de uma cidade. Por tenant.
model Neighborhood {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  cityId    String   @map("city_id") @db.Uuid
  name      String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city    City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  streets Street[]

  @@unique([tenantId, cityId, name])
  @@index([tenantId, cityId])
  @@map("neighborhoods")
}

/// Logradouro (rua/avenida) com CEP. Por tenant. Nasce do lookup ViaCEP ou de
/// cadastro manual (cidades de CEP único). O número fica livre no contrato.
model Street {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  cityId         String   @map("city_id") @db.Uuid
  neighborhoodId String?  @map("neighborhood_id") @db.Uuid
  name           String   @db.VarChar(255)
  postalCode     String?  @map("postal_code") @db.VarChar(8)   // CEP só dígitos
  kind           String?  @db.VarChar(40)                      // Rua, Avenida...
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  city         City          @relation(fields: [cityId], references: [id], onDelete: Cascade)
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  contracts    Contract[]

  @@unique([tenantId, cityId, name, postalCode])
  @@index([tenantId, postalCode])
  @@index([tenantId, cityId])
  @@map("streets")
}


// -----------------------------------------------------------------------------
// CUSTOMER CONTACT
// -----------------------------------------------------------------------------
model CustomerContact {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  type        ContactType
  label       String?     @db.VarChar(64)                  // "Trabalho", "Pessoal"
  value       String      @db.VarChar(255)                 // normalizado (E.164 p/ telefones)

  isPrimary   Boolean     @default(false) @map("is_primary")
  isVerified  Boolean     @default(false) @map("is_verified")
  optIn       Boolean     @default(false) @map("opt_in")   // marketing opt-in específico do canal

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, type, value])
  @@index([tenantId, customerId])
  @@index([tenantId, type, value])
  @@map("customer_contacts")
}

// -----------------------------------------------------------------------------
// CUSTOMER TAG (catálogo) + ASSIGNMENT (N..N)
// -----------------------------------------------------------------------------
model CustomerTag {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  name        String      @db.VarChar(64)
  color       String?     @db.VarChar(7)                   // hex "#RRGGBB"
  description String?     @db.VarChar(255)

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments CustomerTagAssignment[]

  @@unique([tenantId, name])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  customerId  String      @map("customer_id") @db.Uuid
  tagId       String      @map("tag_id") @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid       // denorm p/ índice
  assignedById String?    @map("assigned_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag         CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedBy  User?       @relation(fields: [assignedById], references: [id], onDelete: SetNull)

  @@id([customerId, tagId])
  @@index([tagId])
  @@index([tenantId, customerId])
  @@map("customer_tag_assignments")
}

// -----------------------------------------------------------------------------
// CUSTOMER CONSENT (LGPD / GDPR)
// -----------------------------------------------------------------------------
model CustomerConsent {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  customerId   String          @map("customer_id") @db.Uuid

  purpose      ConsentPurpose
  status       ConsentStatus   @default(PENDING)
  method       ConsentMethod   @default(WEB_FORM)

  grantedAt    DateTime?       @map("granted_at")
  revokedAt    DateTime?       @map("revoked_at")
  expiresAt    DateTime?       @map("expires_at")

  policyVersion String?        @map("policy_version") @db.VarChar(32)   // ex. "privacy-2026-01"
  sourceIp      String?        @map("source_ip") @db.Inet
  sourceUserAgent String?      @map("source_user_agent") @db.VarChar(512)
  evidenceUrl   String?        @map("evidence_url")                      // link p/ PDF/áudio da evidência
  notes         String?        @db.VarChar(500)

  metadata     Json?

  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([tenantId, purpose, status])
  @@map("customer_consents")
}

// -----------------------------------------------------------------------------
// CUSTOMER NOTE (histórico livre)
// -----------------------------------------------------------------------------
model CustomerNote {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  authorId    String?     @map("author_id") @db.Uuid

  title       String?     @db.VarChar(255)
  body        String      @db.Text
  pinned      Boolean     @default(false)

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author      User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tenantId, customerId, createdAt])
  @@index([tenantId, pinned])
  @@map("customer_notes")
}

// =============================================================================
// MODULE 2 — CRM (Sales: Pipelines, Deals, Activities)
//
// Pipeline       = funil comercial (tenant pode ter múltiplos)
// PipelineStage  = coluna do Kanban, ordenada, com probabilidade default
// Deal           = oportunidade/negócio em um estágio, com valor e dono
// DealHistory    = trilha de auditoria de mudança de estágio (p/ conversão)
// Activity       = tarefa/ligação/reunião/email associada a deal/customer
// =============================================================================

enum DealStatus {
  OPEN
  WON
  LOST
}

enum DealLostReason {
  PRICE
  COMPETITOR
  TIMING
  NO_BUDGET
  NO_DECISION
  NO_RESPONSE
  OTHER
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  TASK
  WHATSAPP
  VISIT
  OTHER
}

enum ActivityStatus {
  PENDING
  DONE
  CANCELLED
}

// -----------------------------------------------------------------------------
// PIPELINE (funil comercial)
// -----------------------------------------------------------------------------
model Pipeline {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  name        String          @db.VarChar(120)
  slug        String          @db.VarChar(64)            // para URLs: "vendas", "onboarding"
  description String?         @db.VarChar(500)
  color       String?         @db.VarChar(7)             // hex "#RRGGBB"
  isDefault   Boolean         @default(false) @map("is_default")
  isArchived  Boolean         @default(false) @map("is_archived")

  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages      PipelineStage[]
  deals       Deal[]

  @@unique([tenantId, slug])
  @@index([tenantId, isArchived])
  @@map("pipelines")
}

// -----------------------------------------------------------------------------
// PIPELINE STAGE (colunas do Kanban)
// -----------------------------------------------------------------------------
model PipelineStage {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  pipelineId   String     @map("pipeline_id") @db.Uuid
  name         String     @db.VarChar(120)
  order        Int                                         // 0-based, ordenação das colunas
  probability  Int        @default(0)                       // 0..100 — sugestão de prob. de fechamento
  color        String?    @db.VarChar(7)
  isWon        Boolean    @default(false) @map("is_won")    // estágio terminal "Ganho"
  isLost       Boolean    @default(false) @map("is_lost")   // estágio terminal "Perdido"

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  pipeline     Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@unique([pipelineId, order])
  @@index([tenantId, pipelineId])
  @@map("pipeline_stages")
}

// -----------------------------------------------------------------------------
// DEAL (oportunidade)
// -----------------------------------------------------------------------------
model Deal {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  pipelineId     String         @map("pipeline_id") @db.Uuid
  stageId        String         @map("stage_id") @db.Uuid

  title          String         @db.VarChar(255)
  description    String?        @db.Text
  value          Decimal        @default(0) @db.Decimal(14, 2)
  currency       String         @default("BRL") @db.Char(3)
  probability    Int?                                      // override do stage.probability
  expectedCloseAt DateTime?     @map("expected_close_at") @db.Date

  status         DealStatus     @default(OPEN)
  lostReason     DealLostReason? @map("lost_reason")
  lostNote       String?        @map("lost_note") @db.VarChar(500)

  // Posição dentro da coluna (para drag-drop vertical + reorder)
  position       Int            @default(0)

  customerId     String?        @map("customer_id") @db.Uuid
  ownerId        String?        @map("owner_id") @db.Uuid
  createdById    String?        @map("created_by_id") @db.Uuid
  updatedById    String?        @map("updated_by_id") @db.Uuid

  closedAt       DateTime?      @map("closed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline       Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage          PipelineStage  @relation(fields: [stageId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  owner          User?          @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("DealCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?          @relation("DealUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  history        DealHistory[]
  activities     Activity[]

  @@index([tenantId, pipelineId, stageId, position])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, customerId])
  @@index([tenantId, expectedCloseAt])
  @@map("deals")
}

// -----------------------------------------------------------------------------
// DEAL HISTORY (auditoria de mudança de estágio — funil de conversão)
// -----------------------------------------------------------------------------
model DealHistory {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  dealId       String      @map("deal_id") @db.Uuid

  fromStageId  String?     @map("from_stage_id") @db.Uuid
  toStageId    String      @map("to_stage_id") @db.Uuid
  fromStatus   DealStatus?
  toStatus     DealStatus

  changedById  String?     @map("changed_by_id") @db.Uuid
  reason       String?     @db.VarChar(500)                // motivo opcional
  metadata     Json?

  createdAt    DateTime    @default(now()) @map("created_at")

  deal         Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  changedBy    User?       @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([tenantId, dealId, createdAt])
  @@index([tenantId, toStageId])
  @@map("deal_history")
}

// -----------------------------------------------------------------------------
// ACTIVITY (tarefas, calls, reuniões, emails — liga em deal OU customer)
// -----------------------------------------------------------------------------
model Activity {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid

  type           ActivityType
  status         ActivityStatus  @default(PENDING)

  title          String          @db.VarChar(255)
  notes          String?         @db.Text
  location       String?         @db.VarChar(255)           // meetings/visits
  durationMin    Int?            @map("duration_min")

  dueAt          DateTime?       @map("due_at")
  completedAt    DateTime?       @map("completed_at")

  dealId         String?         @map("deal_id") @db.Uuid
  customerId     String?         @map("customer_id") @db.Uuid
  ownerId        String?         @map("owner_id") @db.Uuid
  createdById    String?         @map("created_by_id") @db.Uuid
  completedById  String?         @map("completed_by_id") @db.Uuid

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal           Deal?           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  owner          User?           @relation("ActivityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  completedBy    User?           @relation("ActivityCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([tenantId, dealId, dueAt])
  @@index([tenantId, customerId, dueAt])
  @@index([tenantId, ownerId, status, dueAt])
  @@index([tenantId, status, dueAt])
  @@map("activities")
}

// =============================================================================
// CONTRACTS (Módulo 03) — contratos de serviço básicos
// Alimenta RADIUS (autorização PPPoE) e Financeiro interno (faturas).
// =============================================================================

enum ContractStatus {
  // Comercial criou o contrato mas ainda não foi instalado fisicamente
  // (não tem ONT autorizada na OLT, RADIUS não aplica). Visível em
  // /provisioning/pending pra técnico ativar em campo.
  PENDING_INSTALL
  ACTIVE      // libera PPPoE/IPoE
  SUSPENDED   // pool de IP "bloqueados"
  CANCELLED   // pool de IP "cancelados"
}

// Como o cliente autentica no RADIUS:
//   PPPOE — usuário/senha em PPPoE (legado e default; cobre 100% das instalações
//           de fibra com BNG Mikrotik usando concentrador PPPoE).
//   IPOE  — sem PPPoE; o BNG/OLT injeta circuit-id (DHCP option 82) e/ou MAC
//           no Access-Request, e o RADIUS aceita por identificação. Usado em
//           FTTH GPON com OLT Huawei/ZTE/Fiberhome onde se quer dispensar
//           o cliente PPPoE.
enum ContractAuthMethod {
  PPPOE
  IPOE
}

enum InvoiceStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

enum ContractSuspendReason {
  MANUAL
  OVERDUE_PAYMENT
  OTHER
}

// Modo de pagamento do contrato:
//   POSTPAID — modelo clássico. Cliente usa o serviço, no `dueDay` do mês
//              recebe fatura cheia (com a primeira proporcional se ativou
//              fora do dia de vencimento). É o default histórico.
//   PREPAID  — cliente paga antes de usar. Primeira fatura vence no dia da
//              ativação; a cada pagamento, prepaidUntil avança 1 mês. Ciclo
//              ancorado em activatedAt (cycleAnchorDay), não em dueDay.
//              Cancelamento não gera cobrança — cliente usa até prepaidUntil.
enum PaymentMode {
  POSTPAID
  PREPAID
}

// Gateway de cobrança BR escolhido POR CONTRATO (trava em 1). MANUAL = sem
// gateway (carnê/dinheiro/baixa manual). EFI/BTG emitem a fatura no gateway.
// Extensível: gateway novo = +1 valor aqui + 1 case no BrBillingService.
enum BrBillingGateway {
  MANUAL
  EFI
  BTG
}

// Tipo da fatura — separa cobrança recorrente de ajustes financeiros:
//   REGULAR   — mensalidade cheia (cron diário, ciclo POSTPAID ou PREPAID).
//   INITIAL   — primeira fatura. POSTPAID: proporcional (do activatedAt até
//               o próximo dueDay). PREPAID: cheia, vencendo na ativação.
//   PRORATION — ajuste de troca de plano. Cobra a diferença entre o que o
//               cliente paga no plano novo vs no antigo pelos dias restantes
//               do ciclo. Amount sempre positivo.
//   CREDIT    — nota de crédito (amount negativo). Gerado quando troca de
//               plano resulta em delta negativo (downgrade). Operador aplica
//               manualmente como desconto na próxima REGULAR.
enum InvoiceKind {
  REGULAR
  INITIAL
  PRORATION
  CREDIT
}

// =============================================================================
// PLANO de internet — catálogo de velocidades + preços
// =============================================================================
// O contrato referencia um Plan (planId) e DENORMALIZA os valores no momento
// da criação/edição (monthlyValue, bandwidthMbps, uploadMbps). Mudar o plano
// depois não afeta contratos existentes — preserva histórico financeiro.
//
// A velocidade do plano vira a queue RADIUS: o radius-applier monta
// `Mikrotik-Rate-Limit` (rx/tx) no radreply, e o Mikrotik cria a queue
// dinâmica por cliente conectado.
model Plan {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  name          String    @db.VarChar(120)
  description   String?   @db.VarChar(500)
  // Velocidades em Mbps. download = o que o cliente baixa; upload = o que sobe.
  downloadMbps  Int       @map("download_mbps")
  uploadMbps    Int       @map("upload_mbps")
  // Preço mensal na moeda do tenant (PYG, BRL, etc).
  monthlyPrice  Decimal   @map("monthly_price") @db.Decimal(12, 2)
  // Dias após o vencimento até suspender o contrato por inadimplência.
  // Default por plano (5 = comportamento histórico hardcoded). Contract pode
  // sobrescrever via Contract.blockAfterDays; o cron OverdueScan resolve com
  // contract.blockAfterDays ?? plan.blockAfterDays ?? 5.
  blockAfterDays Int      @default(5) @map("block_after_days")
  isActive      Boolean   @default(true) @map("is_active")
  // Ordem de exibição em selects (asc).
  order         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Override de template de provisionamento por plano (Fase 2 — Zyxel ZyNOS).
  // Quando setado, vence o Olt.defaultProvisioningProfileId na hora de autorizar.
  provisioningProfileId String? @map("provisioning_profile_id") @db.Uuid

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contracts     Contract[]
  provisioningProfile OltProvisioningProfile? @relation(fields: [provisioningProfileId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("plans")
}

model Contract {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @map("tenant_id") @db.Uuid
  customerId          String         @map("customer_id") @db.Uuid

  // Código sequencial do contrato por tenant: "{Tenant.contractPrefix}-{seq}"
  // (ex.: ZUX-1, ZUX-234). Gerado SEMPRE pelo service na criação — é a
  // identidade do contrato no NetX e também o externalId/Marquilla na Ufinet.
  // `seq` é o sequencial global por tenant (todo contrato, Ufinet ou não).
  code                String?        @db.VarChar(32)
  seq                 Int?           @map("seq")

  // Método de autenticação no RADIUS. Default PPPOE — decisão de engenharia
  // (2026-05-22): pro cenário ONT-roteador + BNG Mikrotik + RADIUS local,
  // PPPoE vence em confiabilidade, ZTP determinístico (identificador nasce
  // com o contrato), segurança (credencial > MAC) e simplicidade de operação.
  // IPoE continua suportado como opt-in pra cenários carrier/exigência de rede.
  authMethod          ContractAuthMethod @default(PPPOE) @map("auth_method")

  // ── Autenticação PPPoE (preenchido só se authMethod = PPPOE) ─────────────
  // Nullable porque IPoE não usa. Mantemos UNIQUE parcial via raw SQL.
  pppoeUsername       String?        @map("pppoe_username") @db.VarChar(64)
  pppoePassword       String?        @map("pppoe_password") @db.VarChar(128)

  // ── Identificação IPoE (preenchido só se authMethod = IPOE) ──────────────
  // circuitId (DHCP option 82, sub-option 1) é a chave primária quando o BNG
  // suporta. Formato livre — varia por fabricante:
  //   Huawei : "0/1/2:1.1"
  //   ZTE    : "gpon-onu_1/1/1:1"
  //   Mikrotik: "ether1/1/3" ou descritor custom
  // Decisão: campo de string livre (até 128 chars). Cada provedor cadastra
  // no formato que o NMS dele exporta.
  circuitId           String?        @map("circuit_id") @db.VarChar(128)
  // remoteId (option 82, sub-option 2) — opcional, complementa circuitId em
  // algumas vendors (geralmente identifica o switch/OLT).
  remoteId            String?        @map("remote_id") @db.VarChar(128)
  externalRef         String?        @map("external_ref") @db.VarChar(64) // chave do sistema de origem (ex.: Hubsoft HS-SVC-<id>)
  // MAC address do CPE — usado como fallback de auth quando o BNG não
  // consegue propagar circuit-id. Formato canonicalizado AA:BB:CC:DD:EE:FF.
  macAddress          String?        @map("mac_address") @db.VarChar(17)
  // IP fixo (opcional). Quando preenchido, vai como Framed-IP-Address no
  // radreply em vez de pegar do pool dinâmico.
  framedIpAddress     String?        @map("framed_ip_address") @db.VarChar(45)
  // VLAN ID (opcional) — alguns ISPs isolam cada cliente em VLAN dedicada.
  vlanId              Int?           @map("vlan_id")

  // Endereço de instalação (string simples agora; migrar depois para FK CustomerAddress)
  installationAddress String         @map("installation_address") @db.VarChar(500)
  // Link público de localização (Google Maps, OpenStreetMap, etc.) — opcional.
  installationMapsUrl String?        @map("installation_maps_url") @db.VarChar(500)
  // Coordenadas estruturadas pra módulo Mapeamento (Leaflet).
  // Operador marca via LocationPicker no EditContractDialog. Nullable —
  // contratos antigos ficam sem coord até backfill manual. DECIMAL(9,6) =
  // erro <11cm, suficiente pra residências.
  latitude            Decimal?       @db.Decimal(9, 6)
  longitude           Decimal?       @db.Decimal(9, 6)

  // Endereço estruturado (BR): FK pro cadastro-mestre de logradouro. Null p/ PY
  // e contratos antigos; obrigatoriedade p/ BR é regra de aplicação (DTO/serviço).
  streetId            String?        @map("street_id") @db.Uuid
  addressNumber       String?        @map("address_number") @db.VarChar(32)
  addressComplement   String?        @map("address_complement") @db.VarChar(120)
  street              Street?        @relation(fields: [streetId], references: [id])

  // Comerciais
  // planId — plano de internet selecionado. Os campos abaixo (monthlyValue,
  // bandwidthMbps, uploadMbps) são DENORMALIZADOS do plano no momento da
  // criação/edição: se o plano mudar de preço/velocidade depois, contratos
  // existentes NÃO mudam (preserva histórico). O operador pode ajustar o
  // monthlyValue (desconto/acréscimo) — o planId fica como referência.
  planId              String?        @map("plan_id") @db.Uuid
  monthlyValue        Decimal        @map("monthly_value") @db.Decimal(12, 2)
  bandwidthMbps       Int            @map("bandwidth_mbps")             // download em Mbps
  uploadMbps          Int?           @map("upload_mbps")                // upload em Mbps
  dueDay              Int            @map("due_day")                    // 1..28 (POSTPAID)

  // Modo de pagamento. POSTPAID = fatura no dueDay; PREPAID = cliente paga
  // antes, ciclo ancorado em activatedAt. Default POSTPAID (compat).
  paymentMode         PaymentMode    @default(POSTPAID) @map("payment_mode")
  // Forma de cobrança deste contrato (1 só). MANUAL (default) = sem gateway;
  // EFI/BTG fazem a fatura nascer já no gateway. Padrão pré-preenchido vem do
  // TenantSetting "finance.br.gateway" no cadastro do contrato.
  brBillingGateway    BrBillingGateway @default(MANUAL) @map("br_billing_gateway")
  // Override per-contrato dos dias para bloqueio por inadimplência.
  // null = usa Plan.blockAfterDays (fallback 5). Aceita 0 (bloqueia no dia
  // do vencimento) até 60.
  blockAfterDays      Int?           @map("block_after_days")
  // PREPAID — data até onde o cliente está com mensalidade paga. Quando uma
  // fatura INITIAL/REGULAR é paga, avança 1 mês. OverdueScan suspende quando
  // prepaidUntil < now sem nova fatura paga. POSTPAID = null.
  prepaidUntil        DateTime?      @map("prepaid_until")
  // PREPAID — dia do mês usado como âncora do ciclo (clamp 28→fev). Derivado
  // de activatedAt.getDate() na 1ª ativação; persistido pra estabilidade
  // mesmo se prepaidUntil drift. POSTPAID = null.
  cycleAnchorDay      Int?           @map("cycle_anchor_day")

  // Estado
  status              ContractStatus        @default(ACTIVE)
  suspendReason       ContractSuspendReason? @map("suspend_reason")

  activatedAt         DateTime?      @map("activated_at")
  suspendedAt         DateTime?      @map("suspended_at")
  cancelledAt         DateTime?      @map("cancelled_at")

  // Religue de confiança: ao reativar um contrato suspenso por inadimplência
  // sem que o cliente tenha pago, o atendente concede um prazo. Cron diário
  // (OverdueScan) verifica e re-suspende quando este timestamp passar.
  // null = sem prazo de confiança ativo.
  trustExtensionUntil DateTime?      @map("trust_extension_until")

  notes               String?        @db.Text

  // ── Provisionamento (Fase 1 ZTP — vide modules/provisioning/) ─────────────
  // Wi-Fi configurado pelo técnico na instalação. Aplicado na ONT via TR-069
  // (Fase 3 — ACS próprio em apps/cwmp-server). Hoje só armazena pra UI/audit.
  // wifiPasswordEnc é criptografado at-rest com KMS_MASTER_KEY (LGPD: senha é
  // PII). Nunca retorna em response sem decrypt explícito + permissão.
  ssid                String?        @db.VarChar(32)
  wifiPasswordEnc     String?        @map("wifi_password_enc") @db.Text
  // ONT vinculada (1:1). Backed-by FK em Ont.contractId (Ont é o lado dono).
  // Aqui só pra navegação Prisma — não persiste coluna extra.

  createdById         String?        @map("created_by_id") @db.Uuid
  updatedById         String?        @map("updated_by_id") @db.Uuid

  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")

  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): impede deletar Customer com contratos. Admin
  // precisa explicitamente cancelar/arquivar contratos antes — preserva
  // histórico financeiro e de RADIUS. Migration: cascades_to_restrict_history.
  customer            Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy           User?          @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy           User?          @relation("ContractUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  // SetNull: deletar um plano não apaga contratos — os valores ficam
  // denormalizados no contrato, só perde a referência.
  plan                Plan?          @relation(fields: [planId], references: [id], onDelete: SetNull)

  invoices            ContractInvoice[]
  radiusEvents        RadiusEvent[]
  serviceOrders       ServiceOrder[]
  oneTimeCharges      OneTimeCharge[]
  // Estoque — Fase 2 (comodato)
  serialItems         SerialItem[]
  stockMovements      StockMovement[]
  // Provisionamento
  ont                 Ont?
  // Rede neutra Ufinet (PY) — serviço óptico provisionado via API TMF.
  ufinetService       UfinetService?
  // BTG — recorrências Pix Automático (assinatura/mensalidade).
  btgRecurrences      BtgRecurrence[]

  // Rede óptica (R2 OSP) — porta de splitter/CTO onde este contrato é
  // atendido. 1 contrato pode ocupar 1 porta (1:1). Quando contrato é
  // cancelado: relação é desfeita (SetNull no OpticalPort.contractId)
  // pra liberar a porta — mantém histórico via audit log.
  // LEGADO (OSP v1) — substituído por fibermapPort abaixo; mantido só até o
  // drop das tabelas optical_* (dados migrados em fibermap_osp_v1_migration).
  opticalPort         OpticalPort?

  // FiberMap (OSP v2) — porta de drop (splitter OUT na CTO) onde este
  // contrato é atendido. FK fica AQUI (contrato → porta) pra porta continuar
  // sendo um nó puro do grafo óptico; 1 porta atende no máximo 1 contrato
  // (unique). SetNull: excluir a porta/planta não mexe no contrato — ele só
  // perde o vínculo e o audit log guarda o histórico de quem ocupou.
  fibermapPortId      String?        @unique @map("fibermap_port_id") @db.Uuid
  fibermapPort        FibermapOpticalPort? @relation(fields: [fibermapPortId], references: [id], onDelete: SetNull)

  // IPAM — IP fixo documentado (1:1, espelha framedIpAddress) + entradas CGNAT.
  ipamAddress         IpamAddress?
  ipamCgnatEntries    IpamCgnatEntry[]

  // pppoeUsername é unique por tenant quando preenchido (Postgres trata
  // múltiplos NULLs como distintos por padrão, então o unique normal funciona
  // — não precisa de index parcial). Mesmo critério vale pra circuitId/MAC.
  @@unique([tenantId, pppoeUsername])
  @@unique([tenantId, circuitId])
  @@unique([tenantId, macAddress])
  @@unique([tenantId, code])
  @@unique([tenantId, seq])
  @@index([tenantId, customerId])
  @@index([tenantId, externalRef])
  @@index([tenantId, planId])
  @@index([tenantId, status])
  @@index([tenantId, dueDay])
  @@index([tenantId, authMethod])
  @@index([tenantId, paymentMode])
  @@index([tenantId, prepaidUntil])
  @@map("contracts")
}

model ContractInvoice {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  contractId   String         @map("contract_id") @db.Uuid

  // Denormalizado p/ histórico (cliente muda de valor, fatura mantém o valor cobrado).
  // CREDIT pode ter amount NEGATIVO (nota de crédito por downgrade de plano).
  amount       Decimal        @db.Decimal(12, 2)
  dueDate      DateTime       @map("due_date") @db.Date
  issuedAt     DateTime       @default(now()) @map("issued_at")

  // Tipo da fatura. REGULAR = mensalidade cheia (cron); INITIAL = primeira
  // (POSTPAID pro-rata, PREPAID cheia); PRORATION = ajuste de troca de plano;
  // CREDIT = nota de crédito (amount negativo). Ver enum InvoiceKind.
  kind         InvoiceKind    @default(REGULAR)
  // Range coberto pela fatura — `period_start` inclusivo, `period_end`
  // exclusivo (corresponde ao próximo dueDate). Crítico pra auditoria e
  // disputa de cobrança proporcional. Nullable pra compat com faturas antigas.
  periodStart  DateTime?      @map("period_start") @db.Date
  periodEnd    DateTime?      @map("period_end") @db.Date

  status       InvoiceStatus  @default(OPEN)
  paidAt       DateTime?      @map("paid_at")
  paidAmount   Decimal?       @map("paid_amount") @db.Decimal(12, 2)
  // Desconto aplicado no pagamento (positivo). Quando preenchido, paidAmount
  // = amount - discountAmount + (acréscimo, se houver). Exige perm
  // `finance.discount.apply` no service.
  discountAmount Decimal?     @map("discount_amount") @db.Decimal(12, 2)
  // Forma como o cliente pagou (independe do caixa).
  paidVia      PaymentMethod? @map("paid_via")
  // Caixa que recebeu o pagamento. Validado contra membership do user.
  cashRegisterId String?      @map("cash_register_id") @db.Uuid
  paymentNote  String?        @map("payment_note") @db.VarChar(255)

  // Referência textual p/ controle interno ex. "Mensalidade 05/2026"
  reference    String?        @db.VarChar(120)
  // Boleto/Pix de ORIGEM (migração): reimprime o que já está gerado no sistema
  // legado (ex.: Hubsoft) em vez de gerar nova cobrança. extSource = origem.
  extSource        String?        @map("ext_source") @db.VarChar(16)
  extBoletoUrl     String?        @map("ext_boleto_url") @db.VarChar(500)
  extDigitableLine String?        @map("ext_digitable_line") @db.VarChar(64)
  extBarcode       String?        @map("ext_barcode") @db.VarChar(64)
  extPixCode       String?        @map("ext_pix_code") @db.Text

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): faturas são histórico financeiro — não pode sumir
  // se contrato for deletado. Soft-delete no Contract é a operação correta.
  contract     Contract       @relation(fields: [contractId], references: [id], onDelete: Restrict)
  cashRegister CashRegister?  @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)

  // SIFEN — 0..N documentos (1 fatura pode ter Factura + Nota de Crédito, etc).
  sifenDocuments SifenDocument[]
  // EFI — cobranças (Pix/Bolix) geradas para esta fatura.
  efiCharges     EfiCharge[]
  // BTG — cobranças (boleto/Pix) geradas para esta fatura.
  btgCharges     BtgCharge[]
  // NFCom — documentos fiscais BR (modelo 62) emitidos para esta fatura.
  nfcomDocuments NfcomDocument[]

  @@index([tenantId, contractId])
  @@index([tenantId, cashRegisterId])
  @@index([tenantId, status, dueDate])
  @@map("contract_invoices")
}

// Trilha de eventos de sincronização com RADIUS/Mikrotik.
// Inicialmente apenas registro em log; futuramente consumido por worker que
// aplica CoA/disconnect real e provisiona o pool correto.
enum RadiusAction {
  AUTHORIZE       // contrato ativo -> libera PPPoE
  BLOCK           // contrato suspenso -> pool bloqueados
  CANCEL          // contrato cancelado -> pool cancelados
  DISCONNECT      // força desconexão (CoA)
}

enum RadiusEventStatus {
  PENDING
  APPLIED
  FAILED
}

model RadiusEvent {
  id           String             @id @default(uuid()) @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  contractId   String             @map("contract_id") @db.Uuid
  action       RadiusAction
  status       RadiusEventStatus  @default(PENDING)
  // Identificador efetivo do contrato no RADIUS:
  //   PPPoE → username
  //   IPoE  → circuitId (ou MAC de fallback)
  // Mantemos o nome `pppoeUsername` por compat com radius-applier; novo
  // contratos IPoE armazenam o circuitId aqui.
  pppoeUsername String            @map("pppoe_username") @db.VarChar(128)
  targetPool   String?            @map("target_pool") @db.VarChar(64)
  note         String?            @db.VarChar(500)
  error        String?            @db.Text
  appliedAt    DateTime?          @map("applied_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): eventos RADIUS são histórico de auditoria —
  // não pode sumir se contrato for deletado. Útil pra reconstruir cenários
  // de fraude e compliance.
  contract     Contract           @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([tenantId, contractId, createdAt])
  @@index([tenantId, status])
  @@map("radius_events")
}

// =============================================================================
// NETWORK SNAPSHOT — série temporal do painel do NMS
// =============================================================================
// Amostra periódica de "como a rede estava" — sessões PPPoE/IPoE ativas e
// tráfego agregado. Existe porque o painel precisa comparar o AGORA com um
// baseline: sem histórico, "caiu vários PPPoE" e "queda/subida brusca de
// tráfego" são indetectáveis (só dá pra mostrar o número atual).
//
// POR QUE NO CORE E NÃO NO NMS: a contagem de sessões só existe em
// `radius.radacct`, que é banco do Core. O NMS não coleta PPPoE por nenhum
// caminho — não há OID de sessão nos perfis SNMP do Telegraf nem suporte nos
// drivers (mikrotik/juniper/cisco). Coletar do lado do NMS renderia um painel
// vazio. O tráfego agregado vem do NMS via HTTP (mesma ponte do
// NmsSyncService) e é carimbado aqui junto, pra que os dois sinais partilhem o
// mesmo eixo de tempo — comparar séries de bancos diferentes com relógios
// diferentes é o que faria o alarme disparar errado.
//
// Postgres puro, sem hypertable: o Core não tem a extensão TimescaleDB. O
// volume é baixo por construção (1 linha por tenant a cada poucos minutos) e a
// retenção poda o que passa da janela — ver NetworkSnapshotService.
model NetworkSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid

  // Sessões RADIUS ativas (acctstoptime IS NULL) no instante da amostra.
  activeSessions Int      @map("active_sessions")
  // Contratos ACTIVE no mesmo instante — o denominador. Guardado junto porque
  // muda com o tempo: sem ele, não dá pra distinguir "caíram 200 sessões" de
  // "cancelaram 200 contratos" ao reler o histórico.
  activeContracts Int     @map("active_contracts")

  // Tráfego agregado da frota (bits/s) lido do NMS. Null quando o módulo
  // netx-nms não está licenciado ou a coleta falhou — o alarme de tráfego
  // simplesmente não avalia, em vez de tratar ausência como queda a zero.
  totalInBps     BigInt?  @map("total_in_bps")
  totalOutBps    BigInt?  @map("total_out_bps")

  // Frota no instante da amostra (contexto pro painel e pra correlação:
  // queda de sessões COM device offline é outra história que sem).
  devicesOnline  Int?     @map("devices_online")
  devicesTotal   Int?     @map("devices_total")

  at             DateTime @default(now())

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Índice da leitura quente do painel: "últimas N amostras deste tenant".
  @@index([tenantId, at])
  @@map("network_snapshots")
}

// =============================================================================
// SERVICE ORDERS (O.S — Ordens de Serviço)
// =============================================================================
// Cada O.S é uma demanda operacional vinculada a um contrato. Pode ser
// agendada, executada e finalizada com descrição. Cidade/estado são
// denormalizados pra filtros rápidos sem precisar JOIN no customer/address.
//
// Status:
//   - OPEN: criada, sem agendamento
//   - SCHEDULED: tem scheduledAt no futuro
//   - IN_PROGRESS: técnico iniciou (startedAt setado)
//   - COMPLETED: finalizada com closeDescription
//   - CANCELLED: cancelada
//   - OVERDUE: derivado em runtime (não persistido) — quando scheduledAt < now
//     e status ∈ {OPEN, SCHEDULED}.
enum ServiceOrderStatus {
  OPEN
  SCHEDULED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Classificação operacional do motivo da O.S — define o fluxo da tela /os.
enum ServiceOrderReasonKind {
  INSTALLATION // provisiona tudo (one-touch)
  SUPPORT // atende; opção de trocar ONT (re-provisiona só na troca)
  RETRIEVAL // recolhe equipamento + desprovisiona/encerra contrato
}

// Cadastro de motivos para a O.S (config do tenant). O admin gerencia em
// /settings/service-order-reasons. Linha não é deletada — vira `isActive=false`
// pra preservar referências históricas.
model ServiceOrderReason {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(120)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  // Marca esse motivo como "instalação". OS com reason.isInstallation = true
  // NÃO pode ser fechada (status=COMPLETED) sem ter SerialItem ALLOCATED ao
  // contrato (vínculo comodato). Trava operacional de segurança: impede o
  // técnico finalizar sem registrar equipamento entregue.
  isInstallation Boolean @default(false) @map("is_installation")
  // Classificação operacional — ramifica o fluxo da tela /os. Mantido em
  // sincronia com isInstallation (= kind == INSTALLATION) por compat.
  kind        ServiceOrderReasonKind @default(SUPPORT) @map("kind")
  // Ordem de exibição em selects (asc).
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrders ServiceOrder[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive, order])
  @@map("service_order_reasons")
}

model ServiceOrder {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  contractId         String              @map("contract_id") @db.Uuid
  reasonId           String              @map("reason_id") @db.Uuid

  // Código humano (ex.: OS-000123). Gerado pelo service.
  code               String?             @db.VarChar(32)

  status             ServiceOrderStatus  @default(OPEN)

  // Datas do ciclo de vida.
  openedAt           DateTime            @default(now()) @map("opened_at")
  scheduledAt        DateTime?           @map("scheduled_at")
  // Lifecycle de campo: técnico inicia deslocamento (EN_ROUTE) e faz check-in
  // ao chegar (IN_PROGRESS). startedAt = checkinAt (mantido por compat).
  enRouteAt          DateTime?           @map("en_route_at")
  checkinAt          DateTime?           @map("checkin_at")
  startedAt          DateTime?           @map("started_at")
  completedAt        DateTime?           @map("completed_at")
  // Etapa 1 do one-touch de instalacao: provisionado em campo, aguardando
  // o tecnico confirmar online e fechar a O.S (etapa 2). Trava a navegacao.
  fieldProvisionedAt DateTime?           @map("field_provisioned_at")
  cancelledAt        DateTime?           @map("cancelled_at")

  // Descrições
  openDescription    String              @map("open_description") @db.Text
  closeDescription   String?             @map("close_description") @db.Text

  // Localização denormalizada (preenchida no create a partir do customer).
  city               String?             @db.VarChar(120)
  state              String?             @db.VarChar(120)

  // Atribuição opcional ao técnico/responsável.
  assignedToId       String?             @map("assigned_to_id") @db.Uuid

  createdById        String?             @map("created_by_id") @db.Uuid
  updatedById        String?             @map("updated_by_id") @db.Uuid

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): OS é histórico operacional/financeiro — preservar.
  contract           Contract            @relation(fields: [contractId], references: [id], onDelete: Restrict)
  reason             ServiceOrderReason  @relation(fields: [reasonId], references: [id], onDelete: Restrict)
  assignedTo         User?               @relation("ServiceOrderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy          User?               @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?               @relation("ServiceOrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  // Estoque — Fase 2 (consumo de material em OS)
  stockMovements     StockMovement[]
  // Fotos de campo (comprovação da instalação) — keys no MinIO via StorageService.
  photos             ServiceOrderPhoto[]
  // Thread de mensagens (atendente ↔ técnico) + anexos avulsos.
  messages           ServiceOrderMessage[]
  attachments        ServiceOrderAttachment[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, city])
  @@index([tenantId, assignedToId, status])
  @@map("service_orders")
}

// Fotos de comprovação da instalação/atendimento em campo. Bytes ficam no
// MinIO (StorageService presigned); aqui guardamos só a key + metadados.
model ServiceOrderPhoto {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  serviceOrderId String   @map("service_order_id") @db.Uuid
  storageKey     String   @map("storage_key") @db.VarChar(512)
  contentType    String?  @map("content_type") @db.VarChar(120)
  sizeBytes      Int?     @map("size_bytes")
  caption        String?  @db.VarChar(255)
  // Quem anexou (escalar, sem FK relacional — basta rastreio).
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, serviceOrderId])
  @@map("service_order_photos")
}

// Thread de mensagens da O.S — comunicação atendente ↔ técnico (histórico).
model ServiceOrderMessage {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  serviceOrderId String   @map("service_order_id") @db.Uuid
  authorId       String?  @map("author_id") @db.Uuid
  body           String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  author       User?        @relation("ServiceOrderMessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tenantId, serviceOrderId, createdAt], map: "so_messages_tenant_so_created_idx")
  @@map("service_order_messages")
}

// Anexos avulsos da O.S (qualquer arquivo, a qualquer momento) — distintos das
// fotos de fechamento. Bytes no MinIO via StorageService; aqui só key + metadados.
model ServiceOrderAttachment {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  serviceOrderId String   @map("service_order_id") @db.Uuid
  storageKey     String   @map("storage_key") @db.VarChar(512)
  fileName       String   @map("file_name") @db.VarChar(255)
  contentType    String?  @map("content_type") @db.VarChar(120)
  sizeBytes      Int?     @map("size_bytes")
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ServiceOrderAttachmentBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, serviceOrderId, createdAt], map: "so_attachments_tenant_so_created_idx")
  @@map("service_order_attachments")
}

// =============================================================================
// FINANCE — Caixas, métodos de pagamento e cobranças avulsas
// =============================================================================

// Tipo do caixa. CASH = dinheiro físico (gaveta), BANK = conta bancária do
// provedor, PIX = chave PIX dedicada, CARD = maquininha. OTHER pra exceções.
enum CashRegisterType {
  CASH
  BANK
  PIX
  CARD
  OTHER
}

// Nível de acesso do usuário no caixa.
//  - OPERATOR: pode dar baixa de pagamento neste caixa.
//  - VIEWER:   só vê o saldo/histórico.
enum CashRegisterRole {
  OPERATOR
  VIEWER
}

// Forma de pagamento informada na hora de dar baixa. Independe do caixa
// (uma mesma maquininha pode ter PIX e CARD); preenchemos no Payment.
enum PaymentMethod {
  CASH
  PIX
  CARD
  BANK_TRANSFER
  BOLETO
  OTHER
}

enum OneTimeChargeStatus {
  OPEN
  PAID
  CANCELLED
}

// Caixa do tenant. Cada um carrega um cadastro próprio (ex. "Caixa Loja
// Central", "Banco Itaú PJ", "PIX Notebook"). Permissão de visibilidade é
// via CashRegisterMembership — o user só vê os caixas em que tem entrada,
// EXCETO se tiver cash_registers.manage (admins veem todos).
model CashRegister {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid

  name           String           @db.VarChar(120)
  description    String?          @db.VarChar(500)
  type           CashRegisterType @default(CASH)
  color          String?          @db.VarChar(7) // hex (ex. #2563eb) — UI bonus
  currency       String           @db.Char(3)    // ISO 4217 — herda do tenant ao criar
  isActive       Boolean          @default(true) @map("is_active")
  // Saldo inicial — informativo. Os movimentos vêm do agregado de Payments.
  openingBalance Decimal          @default(0) @map("opening_balance") @db.Decimal(14, 2)

  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  tenant         Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships    CashRegisterMembership[]
  contractInvoices ContractInvoice[]
  oneTimeCharges OneTimeCharge[]
  movements      CashMovement[]
  fleetExpenses  FleetExpense[]
  salaryPayments SalaryPayment[]
  supplierPayables SupplierPayable[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("cash_registers")
}

model CashRegisterMembership {
  cashRegisterId String           @map("cash_register_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           CashRegisterRole @default(OPERATOR)
  createdAt      DateTime         @default(now()) @map("created_at")

  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cashRegisterId, userId])
  @@index([userId])
  @@map("cash_register_memberships")
}

// Cobrança avulsa — não vinculada a uma fatura recorrente de mensalidade.
// Casos: taxa de instalação, multa por dano, equipamento extra, taxa de
// visita técnica. Pode opcionalmente referenciar um Contract pra rastreio.
// Quando paga, registramos o caixa, método e desconto aplicado.
model OneTimeCharge {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  customerId     String              @map("customer_id") @db.Uuid
  contractId     String?             @map("contract_id") @db.Uuid

  code           String?             @db.VarChar(32) // CB-NNNNNN
  description    String              @db.VarChar(500)
  amount         Decimal             @db.Decimal(12, 2)
  dueDate        DateTime            @map("due_date") @db.Date
  issuedAt       DateTime            @default(now()) @map("issued_at")

  status         OneTimeChargeStatus @default(OPEN)

  // Pagamento (todos opcionais — preenchidos no /pay)
  paidAt         DateTime?           @map("paid_at")
  paidAmount     Decimal?            @map("paid_amount") @db.Decimal(12, 2)
  discountAmount Decimal?            @map("discount_amount") @db.Decimal(12, 2)
  paidVia        PaymentMethod?      @map("paid_via")
  cashRegisterId String?             @map("cash_register_id") @db.Uuid
  paymentNote    String?             @map("payment_note") @db.VarChar(500)

  createdById    String?             @map("created_by_id") @db.Uuid
  updatedById    String?             @map("updated_by_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict (não Cascade): one-time charges são receita avulsa — histórico
  // financeiro idêntico a faturas; não pode sumir com delete de customer.
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contract       Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("ChargeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?         @relation("ChargeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // SIFEN — 0..N documentos fiscais associados a essa cobrança avulsa.
  sifenDocuments SifenDocument[]
  // NFCom — 0..N documentos fiscais BR associados a essa cobrança avulsa.
  nfcomDocuments NfcomDocument[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, dueDate])
  @@index([tenantId, cashRegisterId])
  @@map("one_time_charges")
}

// Tipo do movimento financeiro num caixa.
// =============================================================================
// CONTAS A PAGAR — parcela de pagamento a fornecedor, gerada pelo lançamento
// de compra de estoque (à vista = 1 parcela já paga; a prazo = N parcelas com
// vencimento). A baixa registra CashMovement OUTCOME (source SUPPLIER_PAYABLE).
// "Vencida" é derivada: status OPEN + dueDate < hoje (sem cron de status).
// =============================================================================
enum PayableStatus {
  OPEN
  PAID
  CANCELLED
}

model SupplierPayable {
  id                String        @id @default(uuid()) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  supplierId        String        @map("supplier_id") @db.Uuid
  // Compra que originou a parcela (null = lançamento avulso, reservado p/ fase 2)
  purchaseId        String?       @map("purchase_id") @db.Uuid
  description       String?       @db.VarChar(500)
  installmentNumber Int           @default(1) @map("installment_number")
  installmentCount  Int           @default(1) @map("installment_count")
  amount            Decimal       @db.Decimal(14, 4)
  dueDate           DateTime      @map("due_date")
  status            PayableStatus @default(OPEN)

  // Baixa (pagamento)
  paidAt         DateTime?      @map("paid_at")
  paidAmount     Decimal?       @map("paid_amount") @db.Decimal(14, 4)
  paidVia        PaymentMethod? @map("paid_via")
  cashRegisterId String?        @map("cash_register_id") @db.Uuid
  cashMovementId String?        @map("cash_movement_id") @db.Uuid
  paymentNote    String?        @map("payment_note") @db.VarChar(500)

  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier     Supplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchase     Purchase?     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  cashRegister CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: Restrict)
  createdBy    User          @relation("SupplierPayableCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, status, dueDate])
  @@index([tenantId, dueDate])
  @@index([supplierId])
  @@index([purchaseId])
  @@map("supplier_payables")
}

enum CashMovementType {
  INCOME         // Entrada (pagamento recebido)
  OUTCOME        // Saída (sangria, pagamento de fornecedor)
  TRANSFER_IN    // Entrada vinda de transferência
  TRANSFER_OUT   // Saída por transferência
  ADJUSTMENT     // Ajuste manual de saldo
}

// Origem do movimento. INVOICE/CHARGE são automáticos (criados no /pay).
// TRANSFER cria 2 movements numa transação. MANUAL é criado direto pelo
// admin (sangria, ajuste).
enum CashMovementSource {
  INVOICE
  CHARGE
  TRANSFER
  MANUAL
  FLEET_EXPENSE   // Despesa de frota (combustível, manutenção, multa, etc.)
  PAYROLL         // Pagamento de salário/holerite a colaborador (RH)
  SUPPLIER_PAYABLE // Pagamento a fornecedor (baixa de conta a pagar)
}

model CashMovement {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  cashRegisterId  String              @map("cash_register_id") @db.Uuid

  type            CashMovementType
  source          CashMovementSource  @default(MANUAL)
  // Valor sempre positivo. O `type` define se soma ou subtrai no balance.
  amount          Decimal             @db.Decimal(14, 2)
  description     String?             @db.VarChar(500)
  occurredAt      DateTime            @default(now()) @map("occurred_at")

  // FK polimórfica simples — não vincula via Prisma relation porque a tabela
  // alvo varia (ContractInvoice ou OneTimeCharge). Indexada pra lookup.
  sourceId        String?             @map("source_id") @db.Uuid

  // Quando é uma transferência, os 2 movements (TRANSFER_OUT + TRANSFER_IN)
  // compartilham o mesmo transferGroupId pra rastreio.
  transferGroupId String?             @map("transfer_group_id") @db.Uuid

  createdById     String?             @map("created_by_id") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at")

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashRegister    CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("CashMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  attachments     CashMovementAttachment[]

  @@index([tenantId, cashRegisterId, occurredAt])
  @@index([transferGroupId])
  @@index([source, sourceId])
  @@map("cash_movements")
}

// Anexo de um movimento de caixa (ex.: NF/recibo de uma sangria/despesa).
// Mesmo padrao presigned (MinIO) dos anexos de O.S. Opcional: a maioria dos
// movimentos nao tem anexo. Cascade ao apagar o movimento.
model CashMovementAttachment {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  cashMovementId String   @map("cash_movement_id") @db.Uuid
  storageKey     String   @map("storage_key") @db.VarChar(512)
  fileName       String   @map("file_name") @db.VarChar(255)
  contentType    String?  @map("content_type") @db.VarChar(120)
  sizeBytes      Int?     @map("size_bytes")
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashMovement CashMovement @relation(fields: [cashMovementId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("CashMovementAttachmentBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, cashMovementId, createdAt], map: "cash_mov_attachments_tenant_mov_created_idx")
  @@map("cash_movement_attachments")
}

// =============================================================================
// BACKUPS — pg_dump on-demand (manual, sem criptografia ainda)
// =============================================================================
enum BackupStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// Snapshot do banco inteiro (não por tenant — multi-tenant ainda baixo).
// O arquivo fica em BACKUP_DIR no FS do core-service. Storage S3/offsite
// é trabalho futuro.
model Backup {
  id            String       @id @default(uuid()) @db.Uuid
  // tenantId apenas pra auditoria de quem disparou — backup é do BD inteiro.
  tenantId      String       @map("tenant_id") @db.Uuid
  filename      String       @db.VarChar(255)
  status        BackupStatus @default(PENDING)
  sizeBytes     BigInt?      @map("size_bytes")
  durationMs    Int?         @map("duration_ms")
  errorMessage  String?      @map("error_message") @db.Text
  createdById   String?      @map("created_by_id") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")
  completedAt   DateTime?    @map("completed_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     User?  @relation("BackupCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([status])
  @@map("backups")
}

// =============================================================================
// MODULE — NETWORK (POPs + Equipamentos)
// =============================================================================
//
// POP (Point of Presence): site físico/lógico onde fica equipamento.
//   ex.: "POP Centro Asunción", "Datacenter Lambaré", "Torre CDE-1"
//
// Equipamento: BNG/OLT/Router/Switch que vive num POP.
//   - BNG: integra com RADIUS (radius.nas) automaticamente
//   - OLT: futuramente integra via SNMP/TR-069 pra autoconfig
//   - Router/Switch: cadastro só (CMDB enxuto)
// =============================================================================

model NetworkPop {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(120)
  code        String?  @db.VarChar(32)
  city        String?  @db.VarChar(120)
  state       String?  @db.VarChar(120)
  address     String?  @db.VarChar(500)
  // Geolocalização (módulo Rede/Mapeamento). DECIMAL(9,6) = <11cm erro,
  // mesmo padrão de Contract.latitude/longitude.
  latitude    Decimal? @db.Decimal(9, 6)
  longitude   Decimal? @db.Decimal(9, 6)
  notes       String?  @db.Text

  isActive    Boolean  @default(true) @map("is_active")

  createdById String?  @map("created_by_id") @db.Uuid
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?  @relation("NetworkPopCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?  @relation("NetworkPopUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  equipment   NetworkEquipment[]
  olts        Olt[]
  ipamPrefixes IpamPrefix[]
  // Presença deste POP na planta óptica (FiberMap). Lista por causa do SetNull
  // + soft delete: o único parcial garante no máximo um elemento VIVO.
  fibermapElements FibermapElement[]
  // Fase 3 — bens do patrimônio instalados neste POP, depósitos que ficam
  // dentro dele, e o rastro de movimentos de instalação/recolhimento.
  serialItems      SerialItem[]
  stockLocations   StockLocation[]
  stockMovements   StockMovement[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("network_pops")
}

enum NetworkEquipmentType {
  BNG
  OLT
  ROUTER
  SWITCH
  OTHER
}

enum NetworkEquipmentVendor {
  MIKROTIK
  HUAWEI
  ZTE
  FIBERHOME
  CISCO
  JUNIPER
  OTHER
}

/// Estratégia usada pra desconectar sessões de cliente (CoA/API/SSH).
/// AUTO escolhe baseado em vendor + authType do contrato:
///   - Mikrotik + IPoE → MIKROTIK_API (CoA não suportado pra DHCP no RouterOS)
///   - Mikrotik + PPPoE → COA
///   - Cisco/Juniper/Huawei (qualquer auth) → COA com payload do vendor
///   - Override: sshDisconnectCmd configurado → SSH (sempre vence)
enum DisconnectStrategy {
  AUTO
  COA
  MIKROTIK_API
  SSH
}

model NetworkEquipment {
  id          String                  @id @default(uuid()) @db.Uuid
  tenantId    String                  @map("tenant_id") @db.Uuid
  popId       String?                 @map("pop_id") @db.Uuid

  type        NetworkEquipmentType
  vendor      NetworkEquipmentVendor  @default(OTHER)

  name        String                  @db.VarChar(120)
  hostname    String?                 @db.VarChar(255)
  ipAddress   String                  @map("ip_address") @db.VarChar(45)

  // Específico de BNG (RADIUS) — quando preenchidos, sincronizamos com
  // radius.nas. nasType usa o vocabulário do FreeRADIUS (mikrotik, cisco,
  // juniper, other). secret é compartilhado com o equipamento.
  radiusSecret  String? @map("radius_secret") @db.VarChar(64)
  radiusNasType String? @map("radius_nas_type") @db.VarChar(30)

  // Específico de OLT/Router (SNMP futuro):
  snmpCommunity String? @map("snmp_community") @db.VarChar(64)
  snmpVersion   String? @map("snmp_version") @db.VarChar(10)

  // ───────────────────────────────────────────────────────────────────────
  // Disconnect (multi-vendor) — credenciais pra CoA/API/SSH
  // ───────────────────────────────────────────────────────────────────────
  // Strategy: AUTO infere por vendor+authType. Override quando o cenário
  // foge do padrão (ex: BNG Linux com script SSH custom).
  disconnectStrategy DisconnectStrategy @default(AUTO) @map("disconnect_strategy")
  coaPort            Int?               @map("coa_port")              // default 3799

  // RouterOS API (Mikrotik) — porta 8728 (plain) ou 8729 (TLS)
  apiHost            String?            @map("api_host")              // null → usa ipAddress
  apiPort            Int?               @map("api_port")
  apiUser            String?            @map("api_user")              @db.VarChar(64)
  apiPasswordEnc     String?            @map("api_password_enc")      @db.Text
  apiTlsEnabled      Boolean            @default(false) @map("api_tls_enabled")

  // SSH (fallback ou override) — comando customizado por equipment
  // Template aceita placeholders: {{macAddress}}, {{framedIp}}, {{username}},
  // {{acctSessionId}}, {{nasIp}}. Ex: "/ip dhcp-server lease remove [find mac-address={{macAddress}}]"
  sshHost            String?            @map("ssh_host")
  sshPort            Int?               @default(22) @map("ssh_port")
  sshUser            String?            @map("ssh_user")              @db.VarChar(64)
  sshPasswordEnc     String?            @map("ssh_password_enc")      @db.Text
  sshKeyName         String?            @map("ssh_key_name")          @db.VarChar(128)
  sshDisconnectCmd   String?            @map("ssh_disconnect_cmd")    @db.Text
  // Host key fingerprint "SHA256:<base64>" pra defesa MITM (ver migration
  // 20260517010000_equipment_ssh_host_key). NULL = strategy SSH bloqueada;
  // operador captura via test-connectivity (TOFU explícito).
  sshHostKey         String?            @map("ssh_host_key")           @db.Text

  // Última verificação de conectividade (Test connection)
  lastReachableAt    DateTime?          @map("last_reachable_at")
  lastReachError     String?            @map("last_reach_error")      @db.Text

  // ── Monitoramento no NMS (netx-nms) ──────────────────────────────────────
  // Opt-in por equipamento: o NMS só tem driver pra juniper/mikrotik/
  // cisco_iosxe, e propagar o resto criaria device que ele não consegue
  // coletar. Ligado, o cadastro/edição faz upsert do device no NMS.
  //
  // Bancos separados (o NMS roda Timescale próprio pras séries em metrics.*),
  // então não há FK: nmsDeviceId é só o id espelhado, e a chave de correlação
  // do lado de lá é device.core_equipment_id.
  nmsMonitored       Boolean            @default(false) @map("nms_monitored")
  nmsDeviceId        String?            @map("nms_device_id") @db.Uuid
  nmsSyncedAt        DateTime?          @map("nms_synced_at")
  // Último erro de propagação. Sync falho NÃO bloqueia o cadastro (mesma
  // política do RADIUS), então este campo é o que torna a falha visível.
  nmsSyncError       String?            @map("nms_sync_error") @db.Text

  // Geolocalização (módulo Rede/Mapeamento). Pode diferir da lat/lng do POP
  // — equipamento dentro de rack específico tem coord ligeiramente distinta.
  latitude    Decimal? @db.Decimal(9, 6)
  longitude   Decimal? @db.Decimal(9, 6)

  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")

  createdById String?  @map("created_by_id") @db.Uuid
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  pop         NetworkPop? @relation(fields: [popId], references: [id], onDelete: SetNull)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("NetworkEquipmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?       @relation("NetworkEquipmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  // IPAM — IPs documentados deste equipamento (gerência, loopback, etc.)
  ipamPrefixes  IpamPrefix[]
  ipamAddresses IpamAddress[]
  // Fase 3 — o bem físico do patrimônio que ESTE equipamento é. Lista no
  // Prisma por limitação da relação opcional; o @@unique em SerialItem
  // .networkEquipmentId garante no máximo um.
  serialItems   SerialItem[]

  @@unique([tenantId, name])
  @@unique([tenantId, ipAddress])
  @@index([tenantId, type])
  @@index([popId])
  @@map("network_equipment")
}

// =============================================================================
// MODULE — IPAM (documentação de IPs) + CGNAT determinístico
// =============================================================================
//
// IPAM no estilo phpIPAM/NetBox (focado): supernets → subnets/prefixos → IPs
// individuais, com VLAN, status, vínculo a POP/equipamento e a cliente/contrato.
// Suporta IPv4 E IPv6 de forma uniforme: além do CIDR textual, guardamos os
// limites numéricos (firstAddr/lastAddr) como Decimal(40,0) — numeric(40,0)
// comporta 2^128, então a MESMA query de overlap/containment serve v4 e v6.
//
// Princípio: IPAM é a FONTE DE DOCUMENTAÇÃO. Ele não escreve no RADIUS direto —
// o contrato continua aplicando Framed-IP no radreply (radius-applier). O que
// fazemos é SINCRONIZAR bidirecionalmente (IpamSyncService): atribuir um IP
// fixo a um contrato registra automaticamente no IPAM (e vice-versa), e o mesmo
// vale pro ipAddress de NetworkEquipment. Assim nunca há 2 clientes/equipamentos
// no mesmo IP, e o operador instala um IP fixo pegando "o próximo livre" do pool.
//
// CGNAT determinístico (estilo cgnat.remontti.com.br): a partir de um bloco
// público + um bloco privado (ex.: 100.64.0.0/10) + nº de portas por cliente,
// uma fórmula linear mapeia cada IP privado → (IP público, faixa de portas).
// Materializamos em IpamCgnatEntry pra consulta e BUSCA REVERSA (Marco Civil:
// dado IP público + porta + horário → qual cliente/contrato).
// =============================================================================

enum IpVersion {
  V4
  V6
}

/// Papel do prefixo na rede (orienta UI, cálculo de CGNAT e validações).
enum IpamPrefixRole {
  SUPERNET     // agregado/raiz (RIR, bloco do ISP)
  CUSTOMER     // bloco delegado a cliente corporativo (ex.: /29, /48 v6)
  CGNAT_POOL   // bloco PRIVADO de CGNAT (ex.: 100.64.0.0/10)
  PUBLIC_POOL  // bloco PÚBLICO usado como saída de CGNAT / atribuição direta
  MANAGEMENT   // rede de gerência de equipamentos
  LOOPBACK
  P2P          // ponto-a-ponto (/30, /31, /127)
  DHCP         // faixa servida por DHCP
  OTHER
}

enum IpamPrefixStatus {
  ACTIVE
  RESERVED
  DEPRECATED
}

enum IpamAddressStatus {
  FREE
  USED
  RESERVED
  DHCP
  DEPRECATED
}

/// O que ocupa o IP — usado pra montar a busca e evitar sobrescrever vínculo.
enum IpamAddressKind {
  CONTRACT
  EQUIPMENT
  CUSTOMER
  GATEWAY
  OTHER
}

enum IpamCgnatAlgo {
  LINEAR // port-block sequencial (Remontti): blocos de N portas por IP público
}

/// VRF / espaço de roteamento. Opcional — a maioria dos ISPs usa só o default.
/// Existe pra permitir blocos privados sobrepostos isolados (ex.: CGNAT por POP).
model IpamVrf {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(64)
  rd          String?  @db.VarChar(32) // route distinguisher (opcional)
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prefixes    IpamPrefix[]

  @@unique([tenantId, name])
  @@map("ipam_vrfs")
}

/// Prefixo CIDR hierárquico (supernet → subnet). v4 e v6.
model IpamPrefix {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  vrfId       String?          @map("vrf_id") @db.Uuid
  parentId    String?          @map("parent_id") @db.Uuid

  cidr        String           @db.VarChar(49) // ex.: "2001:db8::/32" ou "10.0.0.0/8"
  version     IpVersion
  prefixLen   Int              @map("prefix_len")
  // Limites numéricos do bloco (inclusive). numeric(40,0) comporta IPv6 (2^128).
  firstAddr   Decimal          @map("first_addr") @db.Decimal(40, 0)
  lastAddr    Decimal          @map("last_addr") @db.Decimal(40, 0)

  role        IpamPrefixRole   @default(OTHER)
  status      IpamPrefixStatus @default(ACTIVE)
  vlanId      Int?             @map("vlan_id")
  gateway     String?          @db.VarChar(45)
  description String?          @db.VarChar(255)

  // Vínculos (todos opcionais)
  popId       String?          @map("pop_id") @db.Uuid
  equipmentId String?          @map("equipment_id") @db.Uuid
  customerId  String?          @map("customer_id") @db.Uuid // bloco corporativo direto no cliente

  createdById String?          @map("created_by_id") @db.Uuid
  updatedById String?          @map("updated_by_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vrf         IpamVrf?          @relation(fields: [vrfId], references: [id], onDelete: SetNull)
  parent      IpamPrefix?       @relation("IpamPrefixTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    IpamPrefix[]      @relation("IpamPrefixTree")
  pop         NetworkPop?       @relation(fields: [popId], references: [id], onDelete: SetNull)
  equipment   NetworkEquipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  customer    Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  addresses   IpamAddress[]
  pools       IpamPool[]
  cgnatPlansPublic  IpamCgnatPlan[] @relation("CgnatPublicPrefix")
  cgnatPlansPrivate IpamCgnatPlan[] @relation("CgnatPrivatePrefix")

  @@unique([tenantId, vrfId, cidr])
  @@index([tenantId, firstAddr, lastAddr])
  @@index([tenantId, role])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([equipmentId])
  @@index([parentId])
  @@map("ipam_prefixes")
}

/// IP individual documentado. addrNum = valor numérico do IP (v4/v6 uniforme).
model IpamAddress {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  prefixId    String            @map("prefix_id") @db.Uuid
  vrfId       String?           @map("vrf_id") @db.Uuid // desnormalizado p/ unicidade/lookup

  address     String            @db.VarChar(45)
  addrNum     Decimal           @map("addr_num") @db.Decimal(40, 0)
  version     IpVersion

  status      IpamAddressStatus @default(FREE)
  kind        IpamAddressKind?

  // Vínculos (no máximo um "dono" — contrato OU equipamento OU cliente)
  customerId  String?           @map("customer_id") @db.Uuid
  contractId  String?           @map("contract_id") @db.Uuid
  equipmentId String?           @map("equipment_id") @db.Uuid

  macAddress  String?           @map("mac_address") @db.VarChar(17)
  hostname    String?           @db.VarChar(255)
  description String?           @db.VarChar(255)
  isGateway   Boolean           @default(false) @map("is_gateway")

  // Origem do registro — distingue sync automático de cadastro manual e
  // evita laço infinito de sincronização. CONTRACT | EQUIPMENT | MANUAL | POOL
  source      String?           @db.VarChar(16)

  createdById String?           @map("created_by_id") @db.Uuid
  updatedById String?           @map("updated_by_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prefix      IpamPrefix        @relation(fields: [prefixId], references: [id], onDelete: Cascade)
  customer    Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contract    Contract?         @relation(fields: [contractId], references: [id], onDelete: SetNull)
  equipment   NetworkEquipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@unique([tenantId, vrfId, addrNum])
  @@unique([contractId]) // 1 contrato ↔ no máximo 1 IP fixo documentado
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, prefixId])
  @@index([equipmentId])
  @@index([addrNum])
  @@map("ipam_addresses")
}

/// Pool de IPs do IPAM (não é radippool do FreeRADIUS). Serve pro operador
/// pegar "o próximo IP livre" e fixar no contrato (Framed-IP). Faixa dentro de
/// um prefixo.
model IpamPool {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  prefixId    String     @map("prefix_id") @db.Uuid
  vrfId       String?    @map("vrf_id") @db.Uuid

  name        String     @db.VarChar(64)
  version     IpVersion
  rangeStart  String     @map("range_start") @db.VarChar(45)
  rangeEnd    String     @map("range_end") @db.VarChar(45)
  startNum    Decimal    @map("start_num") @db.Decimal(40, 0)
  endNum      Decimal    @map("end_num") @db.Decimal(40, 0)
  description String?    @db.VarChar(255)
  isActive    Boolean    @default(true) @map("is_active")

  createdById String?    @map("created_by_id") @db.Uuid
  updatedById String?    @map("updated_by_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prefix      IpamPrefix @relation(fields: [prefixId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, prefixId])
  @@map("ipam_pools")
}

/// Plano de CGNAT determinístico. Guarda os parâmetros; a tabela de mapeamento
/// (IpamCgnatEntry) é derivável por fórmula e materializada sob demanda.
model IpamCgnatPlan {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  name           String        @db.VarChar(64)

  publicPrefixId String        @map("public_prefix_id") @db.Uuid
  cgnatPrefixId  String        @map("cgnat_prefix_id") @db.Uuid

  portsPerClient Int           @default(1000) @map("ports_per_client")
  portBase       Int           @default(1024) @map("port_base")
  maxPort        Int           @default(65535) @map("max_port")
  algorithm      IpamCgnatAlgo @default(LINEAR)
  description    String?       @db.VarChar(255)

  // Materialização
  generatedAt    DateTime?     @map("generated_at")
  entryCount     Int           @default(0) @map("entry_count")

  createdById    String?       @map("created_by_id") @db.Uuid
  updatedById    String?       @map("updated_by_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publicPrefix   IpamPrefix       @relation("CgnatPublicPrefix", fields: [publicPrefixId], references: [id], onDelete: Restrict)
  cgnatPrefix    IpamPrefix       @relation("CgnatPrivatePrefix", fields: [cgnatPrefixId], references: [id], onDelete: Restrict)
  entries        IpamCgnatEntry[]

  @@unique([tenantId, name])
  @@map("ipam_cgnat_plans")
}

/// Linha materializada do mapeamento CGNAT: IP privado → (IP público, portas).
/// Indexada por IP público + porta pra busca reversa (Marco Civil).
model IpamCgnatEntry {
  id         String        @id @default(uuid()) @db.Uuid
  tenantId   String        @map("tenant_id") @db.Uuid
  planId     String        @map("plan_id") @db.Uuid

  privateIp  String        @map("private_ip") @db.VarChar(45)
  privateNum Decimal       @map("private_num") @db.Decimal(40, 0)
  publicIp   String        @map("public_ip") @db.VarChar(45)
  publicNum  Decimal       @map("public_num") @db.Decimal(40, 0)
  portStart  Int           @map("port_start")
  portEnd    Int           @map("port_end")

  // Vínculo opcional ao cliente/contrato (resolvido via IP privado = Framed-IP)
  contractId String?       @map("contract_id") @db.Uuid
  customerId String?       @map("customer_id") @db.Uuid

  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan       IpamCgnatPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  contract   Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([planId, privateNum])
  @@index([tenantId, publicNum, portStart])
  @@index([tenantId, publicIp])
  @@index([tenantId, privateIp])
  @@index([tenantId, contractId])
  @@map("ipam_cgnat_entries")
}

// =============================================================================
// WhatsApp / Atendimento (Evolution API integration)
// =============================================================================
// Módulo de chat MVP: WhatsApp via Evolution API com multi-operador, sem URA,
// sem fluxos automáticos, sem templates. Apenas inbox compartilhada com
// atribuição manual e auditoria realtime.
//
// Webhook receiver em /v1/webhooks/evolution; SSE em /v1/whatsapp/stream.
// Mídia armazenada localmente em /var/lib/netx/whatsapp/media/.
// =============================================================================

/// Canal de transporte da instância: WAHA (QR, não-oficial) ou
/// META_CLOUD (WhatsApp Business Platform oficial). Default WAHA preserva
/// as instâncias existentes sem migração de dados.
enum WaChannel {
  WAHA
  META_CLOUD
}

/// Finalidade de uma instância WhatsApp.
/// - SUPPORT: atendimento ao cliente (comportamento padrão/histórico — chatbot
///   voltado ao assinante, inbox humano).
/// - NEXUS: linha INTERNA. Operadores autorizados (NexusOperator) conversam com
///   o copiloto Nexus (read-only) via WhatsApp. NÃO passa pelo chatbot de cliente.
enum WaInstancePurpose {
  SUPPORT
  NEXUS
}

enum WaInstanceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

enum WaConversationStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

enum WaMsgDirection {
  IN
  OUT
}

enum WaMsgType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  STICKER
  CONTACT
  UNKNOWN
}

enum WaMsgStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

/// Representa uma instância (sessão WhatsApp) gerenciada pelo Evolution API.
/// O MVP suporta múltiplas instâncias por tenant, mas a UI v1 mostra só a
/// primeira ativa — manter o `@@unique([tenantId, instanceName])` permite
/// crescer pra multi-instância depois sem schema migration.
model WhatsappInstance {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid

  name          String  @db.VarChar(120)                   // "Atendimento Principal"
  channel       WaChannel @default(WAHA)                 // transporte (WAHA | META_CLOUD)
  purpose       WaInstancePurpose @default(SUPPORT)       // SUPPORT (cliente) | NEXUS (copiloto interno)
  evolutionUrl  String  @map("evolution_url") @db.VarChar(255) @default("http://localhost:8080")
  apiKey        String  @map("api_key") @db.Text           // cifrado (CryptoService). WAHA: X-Api-Key. Meta: ver apiCredentialsEnc
  instanceName  String  @map("instance_name") @db.VarChar(120) // nome no Evolution
  webhookSecret String  @map("webhook_secret") @db.VarChar(64)  // valida POST /webhooks/evolution

  phoneE164     String?  @map("phone_e164") @db.VarChar(20)  // número conectado
  status        WaInstanceStatus @default(DISCONNECTED)
  qrCode        String?  @map("qr_code") @db.Text             // base64 PNG quando aguardando scan
  lastError     String?  @map("last_error") @db.Text
  connectedAt   DateTime? @map("connected_at")

  // --- Canal oficial Meta Cloud API (channel = META_CLOUD) ---
  wabaId            String? @map("waba_id") @db.VarChar(40)            // WhatsApp Business Account id
  phoneNumberId     String? @map("phone_number_id") @db.VarChar(40)    // roteia o webhook Meta -> instância
  verifyToken       String? @map("verify_token") @db.VarChar(120)      // hub.verify_token (GET de verificação)
  apiCredentialsEnc String? @map("api_credentials_enc") @db.Text       // JSON cifrado { accessToken, appSecret }

  active        Boolean @default(true)
  captureGroups Boolean @default(false) @map("capture_groups")        // opt-in: ingerir mensagens de grupos do WhatsApp (WAHA QR)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations WhatsappConversation[]

  @@unique([tenantId, instanceName])
  @@unique([phoneNumberId])
  @@index([tenantId, status])
  @@map("whatsapp_instances")
}

/// Status de um operador da Nexus (allowlist da linha interna).
/// - PENDING: criado pelo admin, aguardando o operador enviar o código de
///   pareamento no WhatsApp (o telefone ainda não está vinculado/confirmado).
/// - ACTIVE:  pareado — o número está confirmado e fala com a Nexus.
/// - REVOKED: acesso revogado pelo admin (mantém o histórico, bloqueia o uso).
enum NexusOperatorStatus {
  PENDING
  ACTIVE
  REVOKED
}

/// Operador AUTORIZADO a conversar com o copiloto Nexus via WhatsApp (linha
/// NEXUS). É a fronteira de segurança: só quem está aqui (ACTIVE) recebe
/// resposta da Nexus — que expõe dados internos da operação. O vínculo do
/// número é feito por PAREAMENTO: o admin cria o operador (PENDING) e gera um
/// `pairCode`; o operador envia esse código para o número da Nexus e o servidor
/// confirma o telefone real (resolve o problema de formato @lid) e ativa.
model NexusOperator {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  userId     String  @map("user_id") @db.Uuid            // qual usuário do NetX está do outro lado

  phoneE164  String? @map("phone_e164") @db.VarChar(20)  // número confirmado no pareamento (null enquanto PENDING)
  status     NexusOperatorStatus @default(PENDING)
  pairCode   String? @map("pair_code") @db.VarChar(16)   // código que o operador envia p/ parear (limpo após ACTIVE)
  pairedAt   DateTime? @map("paired_at")
  lastSeenAt DateTime? @map("last_seen_at")              // última mensagem tratada (telemetria)

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phoneE164])                        // um número → no máx. um operador (múltiplos NULLs ok no Postgres)
  @@unique([tenantId, userId])                           // um usuário → no máx. um vínculo
  @@index([tenantId, status])
  @@map("nexus_operators")
}

/// Contato com quem trocamos mensagens. Único por (tenant, número), não cresce
/// proporcional ao volume de mensagens. `customerId` é null até alguém linkar
/// (auto pelo `Customer.primaryPhone` ou manual no painel).
model WhatsappContact {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid

  phoneE164   String? @map("phone_e164") @db.VarChar(20)   // +595981234567 (null em grupos)
  pushName    String? @map("push_name") @db.VarChar(255)   // como aparece no WhatsApp (em grupos: assunto do grupo)
  waChatId    String? @map("wa_chat_id") @db.VarChar(80)    // JID real do WhatsApp (@c.us ou @lid) — responder NELE
  customerId  String? @map("customer_id") @db.Uuid          // se reconhecido

  isGroup     Boolean @default(false) @map("is_group")      // true = chat é um grupo do WhatsApp
  waGroupId   String? @map("wa_group_id") @db.VarChar(80)   // JID do grupo (ex.: 1203...@g.us) — chave do grupo

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  conversations WhatsappConversation[]

  @@unique([tenantId, phoneE164])
  @@unique([tenantId, waGroupId])
  @@index([tenantId, customerId])
  @@map("whatsapp_contacts")
}

/// Thread de conversa entre uma instância e um contato. Status OPEN é o
/// inbox; RESOLVED some do inbox principal; ARCHIVED some de tudo. Apenas
/// uma conversa OPEN por (instance, contact) — re-abre a existente se nova
/// mensagem chegar de contato com conversa RESOLVED.
model WhatsappConversation {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  instanceId     String  @map("instance_id") @db.Uuid
  contactId      String  @map("contact_id") @db.Uuid

  status         WaConversationStatus @default(OPEN)
  assignedUserId String?  @map("assigned_user_id") @db.Uuid
  assignedAt     DateTime? @map("assigned_at")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedById   String?  @map("resolved_by_id") @db.Uuid

  lastMessageAt  DateTime  @map("last_message_at")
  lastInboundAt  DateTime? @map("last_inbound_at")           // p/ "tem nova msg?"
  unreadCount    Int       @default(0) @map("unread_count")

  botActive      Boolean   @default(false) @map("bot_active")  // chatbot está conduzindo esta conversa
  botContext     Json?     @map("bot_context")                 // estado da máquina do bot (node, pendências)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance       WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  contact        WhatsappContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser   User?  @relation("WaConversationAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  messages       WhatsappMessage[]
  views          WhatsappConversationView[]
  members        WhatsappConversationMember[]

  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, assignedUserId])
  @@index([instanceId, contactId])
  @@map("whatsapp_conversations")
}

/// Operadores que ENTRARAM numa conversa de GRUPO (atendimento compartilhado do
/// NOC). Diferente do `assignedUserId` (dono único, usado no 1:1), um grupo pode
/// ter VÁRIOS membros simultâneos: todos podem responder e todos são notificados.
/// Entrar = clicar "Atender"; sair = "Sair". Sem membros, o grupo fica só na aba
/// de Grupos, sem notificar ninguém.
model WhatsappConversationMember {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid

  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User @relation("WaConversationMember", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("whatsapp_conversation_members")
}

/// Mensagem individual. Direction IN = recebida do cliente; OUT = enviada
/// pelo NetX (com `fromUserId` apontando pro operador). `evolutionMsgId`
/// é único pra dedup quando o webhook do Evolution reentrega.
model WhatsappMessage {
  id              String  @id @default(uuid()) @db.Uuid
  conversationId  String  @map("conversation_id") @db.Uuid

  direction       WaMsgDirection
  type            WaMsgType
  body            String? @db.Text                         // texto ou caption
  mediaUrl        String? @map("media_url") @db.VarChar(500) // path local ou URL
  mediaMimeType   String? @map("media_mime_type") @db.VarChar(100)
  mediaSize       Int?    @map("media_size")               // bytes
  transcription   String? @db.Text                         // transcrição de áudio (whisper, sob demanda)

  providerMsgId   String?  @unique @map("provider_msg_id") @db.VarChar(120)
  templateName    String?  @map("template_name") @db.VarChar(120)   // HSM enviado (auditoria Meta)
  fromUserId      String?  @map("from_user_id") @db.Uuid    // null se IN
  isBot           Boolean  @default(false) @map("is_bot")    // OUT enviada pelo chatbot (não por humano)
  authorName      String?  @map("author_name") @db.VarChar(255)  // em grupos: quem enviou (pushName do participante)
  authorPhone     String?  @map("author_phone") @db.VarChar(20)  // em grupos: telefone do participante (E164)
  status          WaMsgStatus @default(SENT)
  errorReason     String?  @map("error_reason") @db.Text

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  conversation    WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromUser        User? @relation("WaMessageFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("whatsapp_messages")
}

/// Template HSM (Highly Structured Message) aprovado na Meta. Obrigatório
/// para iniciar conversa ou responder fora da janela de 24h no canal
/// META_CLOUD. Sincronizado da Graph API (GET /{wabaId}/message_templates)
/// ou cadastrado manualmente. Não se aplica ao canal WAHA.
model WhatsappTemplate {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  instanceId     String? @map("instance_id") @db.Uuid       // null = nível tenant

  name           String  @db.VarChar(120)                   // nome aprovado na Meta
  language       String  @db.VarChar(10)                    // ex: pt_BR
  category       String  @db.VarChar(40)                    // MARKETING | UTILITY | AUTHENTICATION
  status         String  @db.VarChar(20)                    // APPROVED | PENDING | REJECTED
  bodyText       String? @map("body_text") @db.Text         // preview do corpo com {{1}}
  components     Json?                                       // estrutura crua da Graph API
  metaTemplateId String? @map("meta_template_id") @db.VarChar(60)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name, language])
  @@index([tenantId, status])
  @@map("whatsapp_templates")
}

/// Auditoria realtime: registra cada vez que um usuário abre uma conversa
/// que NÃO está atribuída a ele. Permite "espionar" mas deixa rastro.
/// Combinado com AuditLog (action=whatsapp.conversation.viewed) pra trail
/// completa em compliance LGPD.
model WhatsappConversationView {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  viewerUserId   String   @map("viewer_user_id") @db.Uuid

  viewedAt       DateTime @default(now()) @map("viewed_at")

  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  viewer         User @relation(fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, viewedAt])
  @@index([viewerUserId, viewedAt])
  @@map("whatsapp_conversation_views")
}

/// Configuração do chatbot de atendimento (um por tenant). Híbrido: um menu
/// determinístico (menuJson) cobre os caminhos comuns (2ª via, status, etc.) e,
/// quando ligado, a IA agêntica (aiEnabled) responde o que sai do menu. O bot
/// só conduz conversas SEM atendente humano atribuído — ao transferir/assumir,
/// o humano assume e o bot sai. Ações de escrita são autônomas porém auditadas.
model WhatsappBotConfig {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @unique @map("tenant_id") @db.Uuid

  enabled       Boolean @default(false)                       // liga o bot
  aiEnabled     Boolean @default(false) @map("ai_enabled")    // IA agêntica p/ texto livre (exige backend com tools)
  greeting      String? @db.Text                              // saudação inicial (antes do menu)
  menuJson      Json?   @map("menu_json")                     // opções do menu (flow determinístico)
  fallbackText  String? @db.Text @map("fallback_text")        // quando não entende e IA off
  handoffText   String? @db.Text @map("handoff_text")         // ao transferir p/ humano
  unknownText   String? @db.Text @map("unknown_text")         // quando o número não bate com nenhum cadastro

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("whatsapp_bot_configs")
}

/// Mensagem predefinida ("resposta rápida") do atendimento — saudações,
/// encerramentos, negativa de viabilidade, planos, prazos, etc. Inserida no
/// compositor (editável) com 1 clique. `ownerUserId` null = biblioteca
/// COMPARTILHADA da equipe (gerida em Configurações por chat.admin);
/// preenchido = resposta PESSOAL daquele operador. Suporta os placeholders
/// {cliente} e {operador}, interpolados na inserção.
model WhatsappQuickReply {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  ownerUserId String? @map("owner_user_id") @db.Uuid   // null = compartilhada (equipe); set = pessoal do operador

  category    String  @default("geral") @db.VarChar(40) // saudacao | encerramento | viabilidade | planos | prazos | geral
  title       String  @db.VarChar(120)                  // rótulo curto pra achar rápido
  body        String  @db.Text                          // texto (até 4096) com {cliente}/{operador}
  shortcut    String? @db.VarChar(40)                   // atalho opcional (ex.: /ola)
  sortOrder   Int     @default(0) @map("sort_order")
  createdById String? @map("created_by_id") @db.Uuid

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User?  @relation("WaQuickReplyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, ownerUserId])
  @@map("whatsapp_quick_replies")
}

/// Notificação genérica pra um usuário — centro de notificações do NetX (sino).
/// Qualquer módulo dispara via NotificationsService.notify() (in-process) ou
/// POST /v1/notifications/dispatch (cross-app, ex.: alarmes do NMS). `type` é
/// livre (ex.: 'chat.mention', 'task.assigned', 'nms.alarm'); `href` é o
/// deep-link do clique; `data` é contexto livre do módulo emissor.
model Notification {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  userId    String  @map("user_id") @db.Uuid

  type      String  @db.VarChar(60)
  title     String  @db.VarChar(200)
  body      String? @db.Text
  href      String? @db.VarChar(500)             // deep-link do clique
  icon      String? @db.VarChar(40)              // hint de ícone (bell|message|alarm|task|...)
  data      Json?                                // contexto livre do emissor

  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// Configuração-mestre do disparo de cobrança do tenant (liga/desliga + modo teste).
/// As REGRAS (quando/qual template/canal) ficam em BillingReminderRule.
model BillingReminderConfig {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @unique @map("tenant_id") @db.Uuid

  enabled       Boolean @default(false)                       // liga o disparo diário
  // Redireciona TODO envio pra este número (modo teste). Null = envia aos clientes.
  testRecipient String? @map("test_recipient") @db.VarChar(20)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("billing_reminder_configs")
}

/// Régua de cobrança: uma regra = "envie o template X pelo canal C, N dias
/// antes/no/depois do vencimento". Vários disparos por tenant. `offsetDays`:
/// negativo = antes do vencimento, 0 = no dia, positivo = depois.
model BillingReminderRule {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid

  enabled      Boolean @default(true)
  label        String? @db.VarChar(120)                       // rótulo amigável opcional
  offsetDays   Int     @map("offset_days")                    // <0 antes | 0 no dia | >0 depois
  channel      String  @default("WHATSAPP_META") @db.VarChar(30) // canal de disparo (extensível)
  templateName String  @map("template_name") @db.VarChar(120)
  language     String  @default("pt_BR") @db.VarChar(10)
  instanceId   String? @map("instance_id") @db.Uuid           // null = resolve a instância ativa do canal
  sortOrder    Int     @default(0) @map("sort_order")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs         BillingReminderLog[]

  @@index([tenantId, enabled])
  @@map("billing_reminder_rules")
}

/// Log de disparo por (regra, fatura) — garante que cada regra dispara UMA vez
/// por fatura (dedup: unique) e serve de histórico/relatório.
model BillingReminderLog {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  ruleId     String  @map("rule_id") @db.Uuid
  invoiceId  String  @map("invoice_id") @db.Uuid

  channel    String  @db.VarChar(30)
  status     String  @db.VarChar(12)                          // SENT | FAILED
  error      String? @db.Text
  // Snapshot pra histórico legível (nome/telefone podem mudar depois).
  customerName String? @map("customer_name") @db.VarChar(200)
  sentTo       String? @map("sent_to") @db.VarChar(20)        // número que recebeu (pode ser o de teste)
  invoiceRef   String? @map("invoice_ref") @db.VarChar(120)
  sentAt     DateTime @default(now()) @map("sent_at")

  rule       BillingReminderRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, invoiceId])
  @@index([tenantId, sentAt])
  @@map("billing_reminder_logs")
}

// =============================================================================
// SIFEN — Sistema Integrado de Facturación Electrónica Nacional (Paraguay)
// =============================================================================
// Cada DTE (Documento Tributario Electrónico) emitido pro SIFEN da DNIT.
// Vinculado a uma ContractInvoice (mensalidade) ou OneTimeCharge (avulsa).
// Mantém XML em 3 versões (gerado / assinado / enviado) pra audit fiscal.
//
// Veja docs/sifen-integration.md (TODO) e Manual Técnico v150:
// https://www.dnit.gov.py/documents/20123/420592/Manual+Técnico+Versión+150.pdf

enum SifenDocumentType {
  FACTURA       // Tipo 1 — mensalidade, taxa, serviço
  NOTA_CREDITO  // Tipo 5 — devolução, desconto retroativo
  NOTA_DEBITO   // Tipo 6 — juros, multa, ajuste
  AUTOFACTURA   // Tipo 4 — compra de não contribuinte (raro p/ ISP)
  NOTA_REMISION // Tipo 7 — entrega de CPE/ONU (não fiscal)
}

enum SifenDocumentStatus {
  DRAFT     // Persistido localmente, ainda não assinado
  SIGNED    // Assinado com CCFE, pronto pra enviar
  SENT      // Enviado pro SIFEN, aguarda resposta
  APPROVED  // SIFEN aprovou — vira DTE com efeito fiscal
  REJECTED  // SIFEN rejeitou — corrigir e re-emitir (CDC novo)
  CANCELLED // Cancelado via evento pós-emissão (até 48h)
}

model SifenDocument {
  id                  String              @id @default(uuid()) @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid

  // Vínculos opcionais com a origem do documento. Pelo menos um deve estar
  // preenchido. ContractInvoice = mensalidade; OneTimeCharge = avulsa.
  contractInvoiceId   String?             @map("contract_invoice_id") @db.Uuid
  oneTimeChargeId     String?             @map("one_time_charge_id") @db.Uuid

  type                SifenDocumentType
  status              SifenDocumentStatus @default(DRAFT)

  // Número fiscal — único por (tenant, establecimiento, puntoExpedicion).
  // Formato impresso: "001-001-0000001" (estab-punto-numero, padding 7).
  // Sem buracos: cancelar NÃO recicla número.
  establecimiento     String              @db.VarChar(3)
  puntoExpedicion     String              @map("punto_expedicion") @db.VarChar(3)
  numero              Int                 // contador sequencial; @@unique abaixo

  // CDC (Código de Control): 44 chars determinístico, calculado a partir de
  // RUC + timbrado + tipo + estab + punto + número + data + tipoEmissão +
  // código de segurança aleatório (9 dígitos) + DV. É o "código de barras"
  // do DTE — vai no QR e na URL de consulta pública.
  cdc                 String              @unique @db.VarChar(44)

  // Identificadores fiscais denormalizados (não dependem de relação)
  emisorRuc           String              @map("emisor_ruc") @db.VarChar(20)
  emisorTimbrado      String              @map("emisor_timbrado") @db.VarChar(8)
  receptorTaxId       String?             @map("receptor_tax_id") @db.VarChar(32)
  receptorName        String?             @map("receptor_name") @db.VarChar(255)

  // Valor total do documento (denormalizado)
  totalAmount         Decimal             @map("total_amount") @db.Decimal(14, 2)
  currency            String              @default("PYG") @db.Char(3)

  // Versões do XML (Text, podem ser grandes — ~5-10KB cada)
  xmlGenerated        String?             @map("xml_generated") @db.Text
  xmlSigned           String?             @map("xml_signed") @db.Text
  xmlSent             String?             @map("xml_sent") @db.Text

  // Resposta crua do SIFEN (envelope SOAP). Útil pra debug + audit.
  sifenResponse       Json?               @map("sifen_response")
  rejectionCode       String?             @map("rejection_code") @db.VarChar(20)
  rejectionReason     String?             @map("rejection_reason") @db.Text

  // QR code URL (consulta pública do DTE no portal SIFEN)
  qrUrl               String?             @map("qr_url") @db.Text

  // Timestamps relevantes
  issuedAt            DateTime            @map("issued_at")
  signedAt            DateTime?           @map("signed_at")
  sentAt              DateTime?           @map("sent_at")
  approvedAt          DateTime?           @map("approved_at")
  rejectedAt          DateTime?           @map("rejected_at")
  cancelledAt         DateTime?           @map("cancelled_at")

  // Retry de envio (em caso de timeout / 5xx do SIFEN)
  retryCount          Int                 @default(0) @map("retry_count")
  lastError           String?             @map("last_error") @db.Text
  nextRetryAt         DateTime?           @map("next_retry_at")

  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractInvoice     ContractInvoice?    @relation(fields: [contractInvoiceId], references: [id], onDelete: SetNull)
  oneTimeCharge       OneTimeCharge?      @relation(fields: [oneTimeChargeId], references: [id], onDelete: SetNull)

  // Numeração sequencial sem buracos por (tenant, estab, punto)
  @@unique([tenantId, establecimiento, puntoExpedicion, numero], map: "sifen_doc_numero_uniq")
  @@index([tenantId, status, issuedAt(sort: Desc)])
  @@index([tenantId, type, issuedAt(sort: Desc)])
  @@index([contractInvoiceId])
  @@index([oneTimeChargeId])
  @@index([nextRetryAt], map: "sifen_doc_retry_idx")
  @@map("sifen_documents")
}

// =============================================================================
// MÓDULO ESTOQUE — Fase 1
// =============================================================================
// Cobre: catálogo de produtos, fornecedores, locais de estoque com ACL,
// compras com seriais, saldo por (produto, local), kardex completo, custo
// médio ponderado global por produto.
//
// Fase 2 (próxima): Sale, comodato (vínculo com Contract), consumo em OS.
// =============================================================================

enum ProductType {
  PATRIMONIAL // unidade rastreada por serial (router, ONU) — comodato
  CONSUMIVEL  // qty rastreada (cabo, conector) — consumo em OS
}

enum SerialStatus {
  IN_STOCK     // disponível em algum local
  ALLOCATED    // em comodato com cliente (Fase 2: contract_id setado)
  IN_USE       // instalado na rede PRÓPRIA (pop_id / network_equipment_id).
               // Distinto de ALLOCATED: não é do cliente, é ativo da operação —
               // continua no patrimônio, mas fora do saldo disponível.
  IN_TRANSIT   // entre locais
  DEFECTIVE    // com defeito, aguardando RMA/descarte
  WRITTEN_OFF  // baixado contábil
  SOLD         // vendido (saída por venda)
  DISCARDED    // inutilizado/sucateado/perda
}

enum MovementType {
  PURCHASE          // entrada — compra de fornecedor
  PURCHASE_RETURN   // saída — devolução pro fornecedor
  SALE              // saída — venda avulsa (Fase 2)
  SALE_RETURN       // entrada — devolução do cliente
  COMODATO_OUT      // saída — equipamento ao cliente (Fase 2)
  COMODATO_RETURN   // entrada — retorno de equipamento (Fase 2)
  DEPLOY_OUT        // saída — bem instalado na rede própria (POP/equipamento)
  DEPLOY_RETURN     // entrada — bem recolhido da rede própria pro estoque
  OS_CONSUMPTION    // saída — consumo em OS (Fase 2)
  ADJUSTMENT_IN     // entrada — ajuste de inventário (achado)
  ADJUSTMENT_OUT    // saída — ajuste de inventário (perda, dano)
  TRANSFER_OUT      // saída — transferência entre locais
  TRANSFER_IN       // entrada — par do TRANSFER_OUT
}

model Supplier {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  taxId       String?  @map("tax_id") @db.VarChar(32) // CNPJ/RUC/etc
  taxIdType   String?  @map("tax_id_type") @db.VarChar(16) // CNPJ | RUC | DNI | ...
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(40)
  address     String?  @db.VarChar(500)
  city        String?  @db.VarChar(120)
  state       String?  @db.VarChar(120)
  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  payables  SupplierPayable[]

  @@unique([tenantId, taxId, taxIdType])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@map("suppliers")
}

model Product {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  sku          String      @db.VarChar(64)
  name         String      @db.VarChar(255)
  description  String?     @db.Text
  brand        String?     @db.VarChar(120)
  model        String?     @db.VarChar(120)
  type         ProductType
  unit         String      @default("un") @db.VarChar(16) // un, m, kg, pç, cx
  // Custo médio ponderado global (recalculado a cada PURCHASE / ADJUSTMENT_IN).
  // Decimal(14,4) cobre cents fracionários típicos de cálculo médio
  // (ex.: 1234,5678 / unit). Saída usa este custo pra avaliar a movimentação.
  cost         Decimal     @default(0) @db.Decimal(14, 4)
  // Preço de venda (consultivo — venda real pode override). Optional.
  price        Decimal?    @db.Decimal(14, 4)
  // Alerta de estoque baixo. Quando saldo global cai abaixo, badge na UI.
  minStock     Decimal?    @default(0) @map("min_stock") @db.Decimal(14, 4)
  isActive     Boolean     @default(true) @map("is_active")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serialItems  SerialItem[]
  stockLevels  StockLevel[]
  movements    StockMovement[]
  purchaseItems PurchaseItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, type])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@map("products")
}

model StockLocation {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String   @db.VarChar(40)  // "DEP-MATRIZ", "VAN-JOAO"
  name        String   @db.VarChar(120) // "Depósito Matriz", "Caminhão João"
  address     String?  @db.VarChar(500)
  // Depósito que fica DENTRO de um POP (almoxarifado do site). Permite
  // responder "o que tem de estoque neste POP" sem convenção de nomenclatura.
  popId       String?  @map("pop_id") @db.Uuid
  // Trava: não pode deletar local com saldo > 0 ou seriais alocados.
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pop          NetworkPop?         @relation(fields: [popId], references: [id], onDelete: SetNull)
  userAccess   StockLocationUser[]
  stockLevels  StockLevel[]
  serialItems  SerialItem[]
  movementsFrom StockMovement[]    @relation("MovementFromLocation")
  movementsTo   StockMovement[]    @relation("MovementToLocation")
  purchaseItems PurchaseItem[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("stock_locations")
}

// ACL many-to-many: quais users operam quais locais.
// Filtro padrão das listagens: WHERE location_id IN (select location_id from
// stock_location_users where user_id = current_user).
// Roles com permissão `stock.admin` bypass — vêem todos os locais do tenant.
model StockLocationUser {
  locationId String  @map("location_id") @db.Uuid
  userId     String  @map("user_id") @db.Uuid
  canWrite   Boolean @default(true) @map("can_write") // false = read-only nesse local

  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([locationId, userId])
  @@index([userId])
  @@map("stock_location_users")
}

// Saldo de CONSUMÍVEIS por (produto, local). Patrimoniais NÃO usam esta tabela
// — saldo deles é COUNT(SerialItem WHERE status='IN_STOCK' AND location_id=X
// AND product_id=Y). Manter ambos na mesma tabela criaria desync.
model StockLevel {
  tenantId   String   @map("tenant_id") @db.Uuid // denorm pra índice
  productId  String   @map("product_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  quantity   Decimal  @default(0) @db.Decimal(14, 4)
  updatedAt  DateTime @updatedAt @map("updated_at")

  product  Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([productId, locationId])
  @@index([tenantId, productId])
  @@index([tenantId, locationId])
  @@map("stock_levels")
}

// Unidade patrimonial (1 row = 1 equipamento físico com serial).
model SerialItem {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  productId       String       @map("product_id") @db.Uuid
  serial          String       @db.VarChar(120)

  // ── Patrimônio ────────────────────────────────────────────────────────────
  // Identidade INTERNA do bem: "{Tenant.assetPrefix}-{assetSeq}" com padding
  // ("PAT-000123"). Distinta do `serial`, que é do fabricante, só é único por
  // produto e é editável (renameSerial). O assetTag é único no tenant, gerado
  // na entrada (compra ou ajuste) e NUNCA reusado nem reeditado — é o que vai
  // na etiqueta física. Nullable pro acervo anterior à migration; o backfill é
  // decisão da operação (etiquetar bem já instalado exige visita).
  // `assetSeq` guarda o sequencial cru pro MAX+1, mesmo padrão de Contract.seq.
  assetTag        String?      @map("asset_tag") @db.VarChar(32)
  assetSeq        Int?         @map("asset_seq")

  status          SerialStatus @default(IN_STOCK)
  locationId      String?      @map("location_id") @db.Uuid // null se status != IN_STOCK e != IN_TRANSIT

  // Vínculo com contrato — preenchido em Fase 2 (operação ALLOCATE = comodato).
  // FK em migration 20260520000000_stock_phase2_comodato_consumption.
  contractId      String?      @map("contract_id") @db.Uuid

  // ── Uso na rede própria (status IN_USE) ───────────────────────────────────
  // Até aqui o estoque só sabia entregar bem ao CLIENTE (ALLOCATED + contractId).
  // Bem próprio instalado num POP não tinha representação: ficava eternamente
  // IN_STOCK (mentira contábil) ou saía por ADJUSTMENT_OUT (sumia do
  // patrimônio). Estes dois campos são o destino "rede própria".
  //
  // popId sozinho cobre o bem que não é equipamento gerenciável (rack, nobreak,
  // gerador). networkEquipmentId é o vínculo 1:1 com a Planta de rede — é ele
  // que faz "Técnico > Equipamentos" e "Estoque" pararem de ser dois cadastros.
  popId              String?   @map("pop_id") @db.Uuid
  networkEquipmentId String?   @map("network_equipment_id") @db.Uuid
  deployedAt         DateTime? @map("deployed_at")

  // Linha de compra que originou este patrimônio (null = veio de ajuste de
  // entrada ou de backfill sem correspondência). Permite entrada incremental de
  // seriais e reversão por FK (sem casar string). SetNull ao excluir a compra.
  purchaseItemId  String?      @map("purchase_item_id") @db.Uuid

  acquisitionCost Decimal?     @map("acquisition_cost") @db.Decimal(14, 4)
  acquisitionDate DateTime?    @map("acquisition_date")
  allocatedAt     DateTime?    @map("allocated_at")
  returnedAt      DateTime?    @map("returned_at")
  notes           String?      @db.Text

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  location  StockLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  // SetNull: se contrato for deletado (hoje bloqueado por Restrict em Contract→
  // Customer; defensive aqui), serial volta ao "limbo" sem contrato. Status NÃO
  // muda automaticamente — operador deve devolver via UI/comodato.return.
  contract     Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)
  purchaseItem PurchaseItem?  @relation(fields: [purchaseItemId], references: [id], onDelete: SetNull)
  // SetNull nos dois: apagar POP ou equipamento não some com o bem — ele fica
  // IN_USE "órfão" e o operador devolve ao estoque ou re-vincula. Mesma
  // filosofia do netxOltId/netxPopId.
  pop              NetworkPop?       @relation(fields: [popId], references: [id], onDelete: SetNull)
  networkEquipment NetworkEquipment? @relation(fields: [networkEquipmentId], references: [id], onDelete: SetNull)
  movements StockMovement[]

  @@unique([tenantId, productId, serial])
  // 1:1 com a planta — um equipamento é UM bem físico. Sem isso dois seriais
  // poderiam reivindicar o mesmo equipamento e o patrimônio ficaria ambíguo.
  // (NULLs não conflitam entre si no Postgres, então o acervo sem vínculo passa.)
  @@unique([networkEquipmentId])
  // Identidade patrimonial — únicos por tenant (não por produto, ao contrário
  // do serial). Protegem a corrida do MAX+1: colisão vira P2002 e o service
  // re-tenta, mesmo contrato de Contract.seq/code.
  @@unique([tenantId, assetTag])
  @@unique([tenantId, assetSeq])
  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([tenantId, locationId, status])
  @@index([purchaseItemId])
  // "Que bens estão neste POP?" — pergunta de inventário de campo.
  @@index([tenantId, popId])
  @@map("serial_items")
}

// Kardex completo — every stock-affecting operation gera linhas aqui.
// Fonte da verdade pra reconciliação e auditoria. Saldo é derivado mas
// cacheado em StockLevel/SerialItem pra performance.
model StockMovement {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  type           MovementType
  productId      String         @map("product_id") @db.Uuid
  serialItemId   String?        @map("serial_item_id") @db.Uuid // se patrimonial

  // Direção:
  //   Entradas (PURCHASE, ADJ_IN, TRANSFER_IN, etc): toLocationId setado, fromLocationId null
  //   Saídas:                                       fromLocationId setado, toLocationId null
  //   Transfer cria PAR: TRANSFER_OUT (from setado) + TRANSFER_IN (to setado)
  fromLocationId String?        @map("from_location_id") @db.Uuid
  toLocationId   String?        @map("to_location_id") @db.Uuid

  quantity       Decimal        @db.Decimal(14, 4)
  unitCost       Decimal        @map("unit_cost") @db.Decimal(14, 4)
  totalCost      Decimal        @map("total_cost") @db.Decimal(14, 4)

  // Referências polimórficas — só uma é populada conforme o type:
  //   PURCHASE / PURCHASE_RETURN   → purchaseId
  //   COMODATO_OUT / COMODATO_RETURN → contractId (Fase 2)
  //   DEPLOY_OUT / DEPLOY_RETURN    → popId (Fase 3 — rede própria)
  //   OS_CONSUMPTION                → serviceOrderId (Fase 2)
  //   ADJUSTMENT_IN/OUT, TRANSFER_* → todas null
  //   SALE / SALE_RETURN            → dormente (não usado; operação só faz comodato)
  purchaseId     String?        @map("purchase_id") @db.Uuid
  contractId     String?        @map("contract_id") @db.Uuid
  serviceOrderId String?        @map("service_order_id") @db.Uuid
  popId          String?        @map("pop_id") @db.Uuid

  notes          String?        @db.Text
  createdById    String         @map("created_by_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")

  product      Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  serialItem   SerialItem?    @relation(fields: [serialItemId], references: [id], onDelete: SetNull)
  fromLocation StockLocation? @relation("MovementFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation   StockLocation? @relation("MovementToLocation",   fields: [toLocationId],   references: [id], onDelete: SetNull)
  purchase     Purchase?      @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  contract     Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)
  serviceOrder ServiceOrder?  @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  pop          NetworkPop?    @relation(fields: [popId], references: [id], onDelete: SetNull)
  createdBy    User           @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, productId, createdAt(sort: Desc)])
  @@index([tenantId, type, createdAt(sort: Desc)])
  @@index([purchaseId])
  @@index([serialItemId])
  @@index([contractId])
  @@index([serviceOrderId])
  @@map("stock_movements")
}

model Purchase {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  supplierId    String         @map("supplier_id") @db.Uuid
  // Número da NF-e/factura do fornecedor (texto livre pra suportar vários formatos)
  invoiceNumber String?        @map("invoice_number") @db.VarChar(64)
  date          DateTime
  totalCost     Decimal        @map("total_cost") @db.Decimal(14, 4)
  notes         String?        @db.Text
  createdById   String         @map("created_by_id") @db.Uuid
  // Quem fez a ÚLTIMA edição (null = nunca editada). Trilha completa fica no AuditLog.
  updatedById   String?        @map("updated_by_id") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier  Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User            @relation("PurchaseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?           @relation("PurchaseUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  items     PurchaseItem[]
  movements StockMovement[]
  payables  SupplierPayable[]

  @@unique([tenantId, supplierId, invoiceNumber])
  @@index([tenantId, date(sort: Desc)])
  @@index([supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid // denorm
  purchaseId   String   @map("purchase_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  locationId   String   @map("location_id") @db.Uuid // onde foi recebido
  quantity     Decimal  @db.Decimal(14, 4)
  unitCost     Decimal  @map("unit_cost") @db.Decimal(14, 4)
  totalCost    Decimal  @map("total_cost") @db.Decimal(14, 4)
  // Seriais cadastrados nesta entrada (1 array de N strings, N = quantity pra patrimonial).
  // Pra consumível, fica vazio. Validado no service.
  serials      String[] @default([]) // será desnormalizado em SerialItem rows
  notes        String?  @db.Text

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  location StockLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  // Seriais cadastrados nesta linha (PATRIMONIAL) — vínculo forte que substitui
  // o casamento por string. A coluna `serials` acima continua como cache/denorm.
  serialItems SerialItem[]

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

// =============================================================================
// PROVISIONAMENTO (OLT/ONT + TR-069 ACS) — Fase 1
// =============================================================================
// Modela o fluxo de ativação de cliente em campo:
//   1. Vendedor cria Contract com status=PENDING_INSTALL (sem ONT vinculada)
//   2. Técnico abre /provisioning/install/:contractId no celular, escolhe OLT,
//      digita SN GPON da ONT, preenche SSID + senha Wi-Fi
//   3. ProvisioningService chama OltDriver.authorize() → cria Ont row
//   4. (Fase 3) Tr069Task enfileira SET_PARAMS + REBOOT pro ACS aplicar Wi-Fi
//   5. RadiusSyncService enfileira AUTHORIZE → cliente online no pool ativos
//
// Multi-provider: Olt.providerMode discrimina entre OLT direta (Parks/Huawei
// SSH) e orquestrador externo (Ufinet API). Driver-pattern em
// modules/provisioning/drivers/* esconde a diferença.

enum OltVendor {
  HUAWEI       // MA5800-X2/X7/X17, MA5608T, EA5800 — SSH CLI
  ZTE          // C300, C320, C600, C610, C650 — SSH CLI
  DATACOM      // DM4610, DM4615, DM4170 — NETCONF
  FIBERHOME    // AN5516-01/04/06 — SSH CLI
  NOKIA        // 7360 FX, ISAM — NETCONF
  PARKS        // OLT 4830-G, 4840-G — SSH CLI
  ZYXEL        // OLT2406 e família — ZyNOS SSH CLI (driver DIRECT)
  UFINET       // rede neutra PY — API orquestrador, não OLT direta
  GENERIC      // fallback / dev
}

// DIRECT: NetX fala direto com a OLT (SSH/NETCONF) — operação BR típica.
// ORCHESTRATOR: NetX chama API de um terceiro (Ufinet, wholesale) que abstrai
// a OLT física. Operação PY hoje.
// EXTERNAL: OLT é provisionada FORA do NetX (admin via web/CLI do vendor,
// ou via plataforma de terceiros). NetX só registra a ONT como AUTHORIZED
// e segue pra RADIUS+TR-069. Útil enquanto Ufinet API não chega ou pra
// instalações onde provisioning óptico é manual.
enum OltProviderMode {
  DIRECT
  ORCHESTRATOR
  EXTERNAL
}

enum OltStatus {
  ONLINE       // testConnection() OK na última checagem
  OFFLINE      // testConnection() falhou
  UNREACHABLE  // sem rota / timeout
  UNKNOWN      // ainda não testou
}

model Olt {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @map("tenant_id") @db.Uuid
  name                String          @db.VarChar(128)         // "OLT POP-Centro"
  vendor              OltVendor
  model               String          @db.VarChar(64)          // "MA5800-X7", "C320"
  providerMode        OltProviderMode @default(DIRECT) @map("provider_mode")

  // ── DIRECT mode (SSH/NETCONF) ────────────────────────────────────────────
  managementIp        String?         @map("management_ip") @db.Inet
  sshPort             Int             @default(22) @map("ssh_port")
  sshUser             String?         @map("ssh_user") @db.VarChar(64)
  // Senha SSH criptografada com KMS_MASTER_KEY (mesma chave que .secrets).
  // Nunca retorna em response sem decrypt explícito + permissão olts.admin.
  sshPasswordEnc      String?         @map("ssh_password_enc") @db.Text
  // Pra Huawei: senha do modo `enable` (privileged exec).
  enableSecretEnc     String?         @map("enable_secret_enc") @db.Text

  // ── ORCHESTRATOR mode (API REST) ─────────────────────────────────────────
  apiEndpoint         String?         @map("api_endpoint") @db.VarChar(255)
  apiAuthType         String?         @map("api_auth_type") @db.VarChar(32)  // "OAUTH2"|"API_KEY"|"MTLS"
  apiCredentialsEnc   String?         @map("api_credentials_enc") @db.Text   // JSON encrypted (segredos)
  apiWebhookSecret    String?         @map("api_webhook_secret") @db.VarChar(128)
  // Config NÃO-secreta do orquestrador (Ufinet): operator/region/contractId/
  // polygonAlias/nms/nmsId/bandwidthProfile/scope/tokenUrl. Cada polígono da
  // Ufinet é cadastrado como UMA OLT. Segredos (clientId/clientSecret/
  // accessKey) ficam em apiCredentialsEnc.
  apiConfig           Json?           @map("api_config")

  // ── Defaults aplicados nas provisões (override por contrato possível) ────
  serviceVlanId       Int?            @map("service_vlan_id")
  defaultUpProfile    String?         @map("default_up_profile") @db.VarChar(64)
  defaultDownProfile  String?         @map("default_down_profile") @db.VarChar(64)
  // Template de provisionamento padrão da OLT (Fase 2 — Zyxel ZyNOS). É o
  // fallback quando o plano do contrato não tem override próprio.
  defaultProvisioningProfileId String? @map("default_provisioning_profile_id") @db.Uuid

  // ── Telemetria ───────────────────────────────────────────────────────────
  status              OltStatus       @default(UNKNOWN)
  lastSeenAt          DateTime?       @map("last_seen_at")
  lastError           String?         @map("last_error") @db.Text

  // ── Geolocalização (módulo Rede/Mapeamento) ──────────────────────────────
  latitude            Decimal?        @db.Decimal(9, 6)
  longitude           Decimal?        @db.Decimal(9, 6)

  // R8.2 — POP onde a OLT está fisicamente instalada. SetNull pra não
  // quebrar a OLT se o POP for apagado (admin re-vincula depois).
  popId               String?         @map("pop_id") @db.Uuid

  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")

  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pop                 NetworkPop?     @relation(fields: [popId], references: [id], onDelete: SetNull)
  defaultProvisioningProfile OltProvisioningProfile? @relation("OltDefaultProfile", fields: [defaultProvisioningProfileId], references: [id], onDelete: SetNull)
  onts                Ont[]
  ponPorts            PonPort[]
  enclosures          OpticalEnclosure[]
  ufinetServices      UfinetService[]
  fibermapDevices     FibermapDevice[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, popId])
  @@map("olts")
}

// =============================================================================
// Rede óptica (OSP) — R8.3: PonPort (porta PON da OLT)
// =============================================================================
// Cada OLT tem N portas PON (1..16 típico GPON), cada uma sai por UM cabo
// óptico backbone e ocupa UMA fibra específica desse cabo. Esse vínculo é o
// que permite o power budget AUTOMÁTICO: dado uma fibra/porta da CTO, o
// algoritmo traversa o grafo até encontrar a PonPort de origem.
//
// txPowerDbm: potência da porta. Quando null, usa default GPON Class B+
// (+3 dBm). Operador override por OLT/porta quando o transceiver é diferente.

model PonPort {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  oltId           String          @map("olt_id") @db.Uuid

  // Índice da porta — 1-based. Validação no service: <= 16 pra GPON típico
  // (operador override pra XGS-PON etc).
  ponIndex        Int             @map("pon_index")

  // Cabo backbone saindo desta porta + qual fibra desse cabo.
  cableId         String?         @map("cable_id") @db.Uuid
  fiberIndex      Int?            @map("fiber_index")

  // Potência de saída em dBm. null = default da tabela de coeficientes (+3).
  txPowerDbm      Decimal?        @map("tx_power_dbm") @db.Decimal(4, 2)

  notes           String?         @db.Text

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olt             Olt             @relation(fields: [oltId], references: [id], onDelete: Cascade)
  cable           FiberCable?     @relation(fields: [cableId], references: [id], onDelete: SetNull)
  enclosures      OpticalEnclosure[]

  // Uma porta por (olt, ponIndex). Garante unicidade física.
  @@unique([oltId, ponIndex])
  // Uma fibra do cabo só atende UMA PON port. Se aparecer 2x, é erro de
  // cadastro — power budget retornaria valores inconsistentes.
  @@unique([cableId, fiberIndex])
  @@index([tenantId, oltId])
  @@map("pon_ports")
}

// Estado da ONT no ciclo de vida:
//   PENDING_AUTH: criada no NetX mas authorize() na OLT ainda não rodou
//   AUTHORIZED  : OLT aceitou o SN, esperando ONT registrar/sincronizar
//   ONLINE      : ONT registrada e operacional (lastSeenAt recente)
//   OFFLINE     : ONT estava ONLINE mas parou de reportar (lastSeenAt antigo)
//   LOS         : Loss of Signal — fibra caiu fisicamente
//   FAULT       : erro persistente reportado pela OLT (firmware/hardware)
enum OntStatus {
  PENDING_AUTH
  AUTHORIZED
  ONLINE
  OFFLINE
  LOS
  FAULT
}

// Comportamento de Wi-Fi por modelo de ONT — define como o TR-069 aplica
// os SSIDs 2.4GHz e 5GHz:
//   BAND_STEERING — SSID único nas 2 bandas (ex.: EG8145X6, EG8145-X10).
//                   A ONT decide a banda; o cliente vê uma rede só.
//   DUAL_BAND     — SSIDs separados (ex.: EG8145V5). 2.4GHz = nome normal,
//                   5GHz = "5G-" + nome.
enum WifiBandMode {
  BAND_STEERING
  DUAL_BAND
}

model Ont {
  id                  String       @id @default(uuid()) @db.Uuid
  tenantId            String       @map("tenant_id") @db.Uuid
  contractId          String       @unique @map("contract_id") @db.Uuid
  oltId               String       @map("olt_id") @db.Uuid

  // SN GPON da ONT — identificador único entregue pela Huawei no preset.
  // Formato típico: "HWTC12AB34CD" (Huawei), "ZTEG..." (ZTE), "ALCL..." (Nokia).
  // Case-insensitive na consulta (citext seria ideal mas mantemos varchar
  // pra compat — comparação UPPER() no service).
  snGpon              String       @map("sn_gpon") @db.VarChar(32)
  // MAC da WAN da ONT — pode chegar via Inform TR-069 ou via Accounting
  // RADIUS. Usado como identificador RADIUS (Contract.macAddress).
  macAddress          String?      @map("mac_address") @db.VarChar(17)
  // Serial físico (etiqueta na carcaça) — opcional, pra inventário.
  serialPhysical      String?      @map("serial_physical") @db.VarChar(64)

  // Posicionamento na OLT (frame/slot/onu-index). Em ORCHESTRATOR mode pode
  // ficar null se o provider não expõe.
  ponFrame            Int?         @map("pon_frame")
  ponSlot             Int?         @map("pon_slot")
  ponOnuIndex         Int?         @map("pon_onu_index")

  status              OntStatus    @default(PENDING_AUTH)
  // Comportamento de Wi-Fi (depende do modelo da ONT). Escolhido no install,
  // usado pelo TR-069 ao montar os SSIDs. Default BAND_STEERING (modelos
  // mais novos — EG8145X6/X10).
  wifiBandMode        WifiBandMode @default(BAND_STEERING) @map("wifi_band_mode")
  // Métricas ópticas (atualizadas por driver poll ou webhook). dBm.
  lastRxPower         Decimal?     @map("last_rx_power") @db.Decimal(6, 2)
  lastTxPower         Decimal?     @map("last_tx_power") @db.Decimal(6, 2)

  authorizedAt        DateTime?    @map("authorized_at")
  lastSeenAt          DateTime?    @map("last_seen_at")
  lastError           String?      @map("last_error") @db.Text

  // Notas livres do técnico (ex.: "ONT colada atrás do quadro").
  notes               String?      @db.Text

  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Restrict: ONT é histórico — cancelamento do contrato deve fazer soft-delete
  // ou desautorizar via driver, mas não sumir a row.
  contract            Contract     @relation(fields: [contractId], references: [id], onDelete: Restrict)
  // Restrict tb na OLT — não dá pra deletar OLT com ONTs vinculadas.
  olt                 Olt          @relation(fields: [oltId], references: [id], onDelete: Restrict)
  tr069Device         Tr069Device?
  alarmEvents         AlarmEvent[]

  // SN único por OLT (não global — duas OLTs podem ter SNs iguais em
  // ambientes de teste, embora real-world seja improvável).
  @@unique([oltId, snGpon])
  @@unique([oltId, ponFrame, ponSlot, ponOnuIndex])
  @@index([tenantId, status])
  @@index([tenantId, macAddress])
  @@map("onts")
}

// =============================================================================
// Templates de provisionamento de OLT (Fase 2 — Zyxel ZyNOS)
// =============================================================================
// O operador cadastra UM template estruturado (perfis de banda por NOME +
// lista de VLANs com papel + protocolo) e o driver renderiza o bloco CLI
// (configure → remote ont → remote uniport → write memory). Resolução na
// hora de autorizar: Plan.provisioningProfile ?? Olt.defaultProvisioningProfile.
// Perfis de banda (usbwprofname/dsbwprofname) precisam JÁ existir na OLT —
// o NetX referencia por nome, não cria.

enum ServiceProtocol {
  PPPOE
  IPOE
  BRIDGE
}

// Papel de cada VLAN do serviço: DATA = tráfego do cliente (PPPoE/IPoE);
// MGMT = gerência (ex. VLAN do TR-069/ACS).
enum ProfileVlanRole {
  DATA
  MGMT
}

model OltProvisioningProfile {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  name              String          @db.VarChar(120)
  description       String?         @db.VarChar(500)
  // Por ora ZYXEL; o campo permite render multi-vendor no futuro.
  vendor            OltVendor       @default(ZYXEL)

  // ── nível ONT (remote ont <aid>) ─────────────────────────────────────────
  ontPassword       String          @default("DEFAULT") @map("ont_password") @db.VarChar(64)
  fullBridge        Boolean         @default(false) @map("full_bridge")
  bwUpProfileName   String          @map("bw_up_profile_name") @db.VarChar(64)   // ex ZUX-MAX-US
  bwDownProfileName String          @map("bw_down_profile_name") @db.VarChar(64) // ex ZUX-MAX-DS
  bwGroupId         Int             @default(1) @map("bw_group_id")

  // ── nível UNI (remote uniport uniport-<aid>-<uniPort>) ───────────────────
  uniPort           String          @default("2-1") @map("uni_port") @db.VarChar(16)
  serviceProtocol   ServiceProtocol @default(PPPOE) @map("service_protocol")
  queueTc           Int             @default(1) @map("queue_tc")
  queuePriority     Int             @default(0) @map("queue_priority")
  queueWeight       Int             @default(0) @map("queue_weight")
  ingressProfile    String          @default("DEFVAL") @map("ingress_profile") @db.VarChar(64)

  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vlans             OltProfileVlan[]
  defaultForOlts    Olt[]           @relation("OltDefaultProfile")
  plans             Plan[]

  @@unique([tenantId, name])
  @@index([tenantId, vendor])
  @@map("olt_provisioning_profiles")
}

model OltProfileVlan {
  id              String          @id @default(uuid()) @db.Uuid
  profileId       String          @map("profile_id") @db.Uuid
  vid             Int                                              // 1..4094
  role            ProfileVlanRole @default(DATA)
  // txtag tag (true) | untag (false)
  tagged          Boolean         @default(true)
  // pvid do uniport aponta pra esta VLAN (só 1 deve ser true, tipicamente DATA)
  isPvid          Boolean         @default(false) @map("is_pvid")
  // gera `protocol-based <serviceProtocol> vlan <vid>` (a VLAN de dados)
  isProtocolBased Boolean         @default(false) @map("is_protocol_based")
  order           Int             @default(0)

  profile         OltProvisioningProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("olt_profile_vlans")
}

// =============================================================================
// Central de Alarmes (CPE/OLT) — correlação de quedas por PON/CTO/cabo/OLT/geo
// =============================================================================
// Duas camadas: AlarmEvent (bruto, append-only — todo down/up/degraded de ONT)
// alimenta o motor de correlação, que abre Incident agregado no escopo mais
// alto que bate o limiar do tenant (AlarmPolicy), suprimindo os filhos. O
// `reason` (POWER_LOSS=dying-gasp / LINK_LOSS=LOS) discrimina energia vs
// rompimento. A camada de IA (Fase 4) preenche aiSummary/aiRootCause depois.

enum AlarmEventKind {
  DOWN
  UP
  DEGRADED
}

// Escopo de agregação de um incidente, do mais específico ao mais amplo.
enum AlarmScope {
  ONT
  PON
  CTO
  CABLE
  OLT
  GEO
}

enum IncidentStatus {
  OPEN
  ACK
  RESOLVED
}

enum IncidentSeverity {
  INFO
  WARNING
  CRITICAL
}

// Causa-raiz inferida (determinística pela mistura de reason; IA refina).
enum AlarmRootCause {
  POWER_OUTAGE      // dying-gasp em massa → queda de energia (bairro/CTO)
  FIBER_CUT         // LOS em massa no mesmo cabo/PON → rompimento
  OPTICAL_DEGRADED  // potência óptica baixa subindo (pré-falha)
  ISOLATED          // 1 ONT isolada (provável problema do cliente)
  UNKNOWN
}

model AlarmEvent {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  ontId         String?        @map("ont_id") @db.Uuid
  oltId         String?        @map("olt_id") @db.Uuid
  contractId    String?        @map("contract_id") @db.Uuid
  kind          AlarmEventKind
  // Bruto do syslog: reason POWER_LOSS|LINK_LOSS, alarm DGi|LOSi|LowTxOpticalPower.
  reason        String?        @db.VarChar(32)
  alarm         String?        @db.VarChar(32)
  aid           String?        @db.VarChar(32)
  // Snapshot da posição PON pra correlação sem join pesado.
  ponSlot       Int?           @map("pon_slot")
  ponFrame      Int?           @map("pon_frame")
  source        String         @default("syslog") @db.VarChar(24)
  // Incident que agregou este evento (null enquanto na janela de debounce).
  incidentId    String?        @map("incident_id") @db.Uuid
  // Carimbado no RECEBIMENTO (relógio da OLT não é confiável).
  at            DateTime
  createdAt     DateTime       @default(now()) @map("created_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ont           Ont?           @relation(fields: [ontId], references: [id], onDelete: SetNull)
  incident      Incident?      @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([tenantId, ontId])
  @@index([incidentId])
  @@map("alarm_events")
}

model Incident {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  scope             AlarmScope
  // Id da entidade do escopo (CTO/cabo/OLT). null pra GEO (cluster sem FK).
  scopeRefId        String?          @map("scope_ref_id") @db.Uuid
  scopeLabel        String           @map("scope_label") @db.VarChar(120)
  severity          IncidentSeverity @default(WARNING)
  status            IncidentStatus   @default(OPEN)
  rootCause         AlarmRootCause   @default(UNKNOWN) @map("root_cause")
  affectedCount     Int              @default(0) @map("affected_count")
  totalInScope      Int              @default(0) @map("total_in_scope")
  affectedPct       Decimal          @default(0) @map("affected_pct") @db.Decimal(5, 2)
  // Incidente-pai que suprime este (ex: rompimento de cabo engloba as CTOs).
  parentIncidentId  String?          @map("parent_incident_id") @db.Uuid
  // Ganchos da Fase 4 (IA) — preenchidos assíncronos, nunca no caminho crítico.
  aiSummary         String?          @map("ai_summary") @db.Text
  aiRootCause       String?          @map("ai_root_cause") @db.VarChar(120)
  firstEventAt      DateTime         @map("first_event_at")
  lastEventAt       DateTime         @map("last_event_at")
  acknowledgedAt    DateTime?        @map("acknowledged_at")
  acknowledgedById  String?          @map("acknowledged_by_id") @db.Uuid
  resolvedAt        DateTime?        @map("resolved_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent            Incident?        @relation("IncidentChildren", fields: [parentIncidentId], references: [id], onDelete: SetNull)
  children          Incident[]       @relation("IncidentChildren")
  events            AlarmEvent[]

  @@index([tenantId, status])
  @@index([tenantId, scope, scopeRefId])
  @@index([tenantId, createdAt])
  @@map("incidents")
}

model AlarmPolicy {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @unique @map("tenant_id") @db.Uuid

  // Limiares de agregação por escopo: alarma quando % afetado ≥ pct E
  // afetados ≥ minCount (o mínimo absoluto evita falso-positivo em escopo
  // pequeno, ex: CTO com 2 clientes).
  ctoPctThreshold   Int      @default(60) @map("cto_pct_threshold")
  ctoMinCount       Int      @default(3) @map("cto_min_count")
  ponPctThreshold   Int      @default(50) @map("pon_pct_threshold")
  ponMinCount       Int      @default(4) @map("pon_min_count")
  cablePctThreshold Int      @default(50) @map("cable_pct_threshold")
  cableMinCount     Int      @default(2) @map("cable_min_count")
  oltMinCount       Int      @default(10) @map("olt_min_count")
  geoMinCount       Int      @default(5) @map("geo_min_count")

  // Janela de debounce (s) pra agregar quedas quase-simultâneas.
  debounceSeconds   Int      @default(45) @map("debounce_seconds")

  // RSSI (dBm): limiares de sinal ruim/saturado pros relatórios e alertas.
  rxLowDbm          Decimal  @default(-27) @map("rx_low_dbm") @db.Decimal(6, 2)
  rxHighDbm         Decimal  @default(-8) @map("rx_high_dbm") @db.Decimal(6, 2)

  // Mapa causa→severidade (override do default). JSON: {"FIBER_CUT":"CRITICAL"}.
  severityMap       Json?    @map("severity_map")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("alarm_policies")
}

// =============================================================================
// TR-069 / CWMP — registro de devices ACS
// =============================================================================
// Fase 1: schema + stubs. apps/cwmp-server (Fase 3) vai popular essa tabela
// quando CPEs fazem Inform na porta 7547. Por hora as rows são criadas pelo
// ProvisioningService como placeholder pra UI mostrar "aguardando Inform".

model Tr069Device {
  id                       String   @id @default(uuid()) @db.Uuid
  tenantId                 String   @map("tenant_id") @db.Uuid
  // ONT vinculada (1:1 quando o device é uma ONT GPON gerenciada pelo NetX).
  // Pode ser null se cadastrarmos CPEs sem ONT (ex.: roteador downstream
  // BYOD no futuro).
  ontId                    String?  @unique @map("ont_id") @db.Uuid

  // OUI-Serial — chave de identificação CWMP. Formato: "<OUI>-<SerialNumber>".
  // Ex.: Huawei "00259E-HWTC12AB34CD". Único globalmente por TR-069 spec.
  deviceId                 String   @unique @map("device_id") @db.VarChar(128)

  // Atributos reportados no Inform (cacheados pra UI/filtro):
  manufacturer             String?  @db.VarChar(64)
  oui                      String?  @db.VarChar(6)
  productClass             String?  @map("product_class") @db.VarChar(64)
  hardwareVersion          String?  @map("hardware_version") @db.VarChar(32)
  softwareVersion          String?  @map("software_version") @db.VarChar(32)
  provisioningCode         String?  @map("provisioning_code") @db.VarChar(128)

  // Connection Request — endpoint do CPE que aceita trigger (NetX → CPE) pra
  // forçar sessão imediata. Em rede neutra com NAT geralmente é unreachable;
  // confiamos no Periodic Inform.
  connectionRequestUrl     String?  @map("connection_request_url") @db.VarChar(255)
  connectionRequestUser    String?  @map("connection_request_user") @db.VarChar(64)
  connectionRequestPwdEnc  String?  @map("connection_request_pwd_enc") @db.Text

  // Snapshot completo dos parameters lidos no último GetParameterValues
  // (JSON). Útil pra debug e dashboards. Caro pra storage — TTL implícito
  // (overwrite a cada Inform).
  parametersSnapshot       Json?    @map("parameters_snapshot")

  // Estado:
  status                   String   @default("UNKNOWN") @db.VarChar(32)
                                    // "UNKNOWN"|"ONLINE"|"OFFLINE"|"PROVISIONING"
  lastInformAt             DateTime? @map("last_inform_at")
  lastInformReason         String?   @map("last_inform_reason") @db.VarChar(64)
  // Última coleta de diagnóstico (GetParameterValues) bem-sucedida — usada
  // pelo cron de coleta proativa pra espaçar as leituras por device.
  lastDiagnosticAt         DateTime? @map("last_diagnostic_at")
  // Quando os SetParameterAttributes (notificações) foram armados no CPE —
  // null = ainda não armado. Permite armar uma vez por device.
  notificationsArmedAt     DateTime? @map("notifications_armed_at")
  // Quando o PeriodicInformInterval foi relaxado (ZTP rápido → permanente).
  // null = ainda no intervalo rápido do ZTP.
  informIntervalRelaxedAt  DateTime? @map("inform_interval_relaxed_at")

  // Conformidade (motor de profiles — Fase 2). profileId resolvido por
  // (manufacturer, productClass, firmware). complianceStatus é o resumo
  // denormalizado pro badge do portal.
  profileId                String?  @map("profile_id") @db.Uuid
  complianceStatus         Tr069ComplianceStatus @default(UNKNOWN) @map("compliance_status")
  lastReconciledAt         DateTime? @map("last_reconciled_at")
  reconciledProfileVersion Int?      @map("reconciled_profile_version")
  pendingRebootSince       DateTime? @map("pending_reboot_since")
                                    // "0 BOOTSTRAP"|"1 BOOT"|"2 PERIODIC"|...

  // WiFi-Opt — marcador do pacote de otimização aplicado ('BASE'|'GIGA').
  // Morre junto no deleteMany do swap — desejado: a ONT nova re-otimiza do zero.
  wifiOptProfile           String?   @map("wifi_opt_profile") @db.VarChar(8)
  // Quando a task SET do pacote confirmou DONE (insumo do sweeper horário).
  wifiOptAppliedAt         DateTime? @map("wifi_opt_applied_at")

  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ont                      Ont?     @relation(fields: [ontId], references: [id], onDelete: SetNull)
  tasks                    Tr069Task[]
  diagnostics              Tr069Diagnostic[]
  alerts                   Tr069Alert[]
  diagRuns                 Tr069DiagnosticRun[]
  profile                  Tr069Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  drifts                   Tr069Drift[]
  notes                    Tr069DeviceNote[]

  @@index([tenantId, status])
  @@index([tenantId, lastInformAt])
  @@map("tr069_devices")
}

enum Tr069TaskAction {
  SET_PARAMS       // SetParameterValues
  GET_PARAMS       // GetParameterValues
  SET_ATTRIBUTES   // SetParameterAttributes (notificação passiva/ativa)
  REBOOT           // Reboot()
  FACTORY_RESET    // FactoryReset()
  DOWNLOAD         // Download() — firmware upgrade (futuro)
  ADD_OBJECT       // AddObject() — criar instância (ex.: nova WLAN)
  DELETE_OBJECT
}

enum Tr069TaskStatus {
  PENDING          // aguardando próximo Inform
  RUNNING          // entregue ao CPE no fim do session, aguardando ack
  DONE             // CPE confirmou aplicação
  FAILED           // CPE retornou fault ou timeout
  CANCELLED        // operador cancelou antes de aplicar
}

model Tr069Task {
  id           String           @id @default(uuid()) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  deviceId     String           @map("device_id") @db.Uuid
  // Acrescenta rastreabilidade pro contrato — facilita debug ("qual task
  // criou esse Wi-Fi?")
  contractId   String?          @map("contract_id") @db.Uuid

  action       Tr069TaskAction
  // Payload depende da action:
  //   SET_PARAMS: { params: [{ name, value, type }] }
  //   GET_PARAMS: { names: string[] }
  //   REBOOT/FACTORY_RESET: {}
  //   DOWNLOAD: { url, fileType, targetFileName, ... }
  payload      Json
  // Response do CPE (faults + parameter snapshots).
  result       Json?

  status       Tr069TaskStatus  @default(PENDING)
  attempts     Int              @default(0)
  error        String?          @db.Text

  // FIFO por device: applier processa em ordem de createdAt ASC.
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  startedAt    DateTime?        @map("started_at")
  completedAt  DateTime?        @map("completed_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device       Tr069Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, status])
  @@index([tenantId, status, createdAt])
  @@map("tr069_tasks")
}

// =============================================================================
// TR-069 DIAGNOSTICS & ALERTS — monitoramento proativo de CPEs
// =============================================================================
// O ACS (apps/cwmp-server) enfileira GET_PARAMS periódicos (cron no
// core-service) lendo nível óptico (RX/TX PON), temperatura/tensão do
// transceiver e a experiência Wi-Fi do cliente. Cada resposta vira um
// Tr069Diagnostic (série temporal) e, ao cruzar limiares, abre/atualiza um
// Tr069Alert. Limiares canônicos vivem em @netx/shared (tr069.dto.ts).

enum Tr069OpticalHealth {
  OK
  WARNING
  CRITICAL
  UNKNOWN
}

enum Tr069AlertType {
  OPTICAL_RX_LOW      // recepção fraca (fibra suja/dobrada, distância, splitter)
  OPTICAL_RX_HIGH     // recepção forte demais (falta atenuador) — satura o receptor
  OPTICAL_TX_ABNORMAL // potência de transmissão da ONT fora da faixa
  DEVICE_OFFLINE      // CPE sem Inform há mais de N intervalos
  WIFI_WEAK_CLIENT    // cliente Wi-Fi com RSSI muito baixo (cobertura ruim)
  WIFI_HIGH_UTIL      // utilização de canal alta (congestionamento)
  OPTICAL_FIBER_DEGRADED // FEC/HEC subindo — fibra suja/conector ruim
  WAN_DOWN            // PPPoE/WAN do cliente caiu (erro de autenticação etc.)
}

enum Tr069AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum Tr069AlertStatus {
  OPEN
  RESOLVED
}

/// Série temporal de leituras de diagnóstico de um CPE (via GetParameterValues).
/// Uma linha por coleta — base pra tendência (gráfico de RX) e disparo de alertas.
/// Append-only; retenção/limpeza por cron fica pra incremento futuro.
model Tr069Diagnostic {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  deviceId      String   @map("device_id") @db.Uuid

  capturedAt    DateTime @default(now()) @map("captured_at")

  // ── Óptico (transceiver GPON da ONT, já normalizado) ───────────────────────
  rxPower       Decimal? @map("rx_power") @db.Decimal(6, 2)      // dBm (recepção)
  txPower       Decimal? @map("tx_power") @db.Decimal(6, 2)      // dBm (transmissão)
  temperature   Decimal? @map("temperature") @db.Decimal(6, 2)   // °C
  voltage       Decimal? @map("voltage") @db.Decimal(7, 3)       // V
  biasCurrent   Decimal? @map("bias_current") @db.Decimal(7, 2)  // mA
  opticalHealth Tr069OpticalHealth @default(UNKNOWN) @map("optical_health")

  // ── Estatísticas GPON (qualidade do enlace — alerta precoce de fibra) ───────
  gponStatus    String?  @map("gpon_status") @db.VarChar(16)    // "Up"/"Down"
  fecErrors     BigInt?  @map("fec_errors")    // corrigidos por FEC (contador)
  hecErrors     BigInt?  @map("hec_errors")    // erros de HEC (contador)
  dropRate      Decimal? @map("drop_rate") @db.Decimal(8, 3)
  errorRate     Decimal? @map("error_rate") @db.Decimal(8, 3)

  // ── WAN/PPPoE (lado do CPE — diagnóstico de autenticação/conexão) ───────────
  pppStatus     String?  @map("ppp_status") @db.VarChar(32)   // Connected/Disconnected/...
  pppLastError  String?  @map("ppp_last_error") @db.VarChar(64)
  wanUptime     Int?     @map("wan_uptime")   // segundos
  // Contadores de bytes da WAN PPPoE (cumulativos) — base do throughput.
  wanRxBytes    BigInt?  @map("wan_rx_bytes")
  wanTxBytes    BigInt?  @map("wan_tx_bytes")

  // ── Hosts da LAN (dispositivos conectados na casa do cliente) ───────────────
  hostsCount    Int?     @map("hosts_count")
  hosts         Json?    // [{mac,ip,hostname,active}]

  // ── Wi-Fi (agregado por banda) ─────────────────────────────────────────────
  wifiClients24 Int?     @map("wifi_clients_24")
  wifiClients5  Int?     @map("wifi_clients_5")
  wifiChannel24 Int?     @map("wifi_channel_24")
  wifiChannel5  Int?     @map("wifi_channel_5")
  // Pior RSSI entre os clientes associados (dBm) — indicador de cobertura.
  wifiWorstRssi Int?     @map("wifi_worst_rssi")
  // RSSI MÉDIO dos clientes (dBm) — denormalizado p/ rankear cobertura no banco.
  wifiAvgRssi   Int?     @map("wifi_avg_rssi")
  // Lista por cliente Wi-Fi associado: [{ mac, band, rssi, txRate, rxRate }].
  wifiClients   Json?    @map("wifi_clients")

  // ── Recursos do CPE (DeviceInfo) ────────────────────────────────────────────
  cpuUsage      Int?     @map("cpu_usage")    // % CPU (X_HW_CpuUsed)
  memUsage      Int?     @map("mem_usage")    // % memória (X_HW_MemUsed)
  deviceTemp    Int?     @map("device_temp")  // °C do CPE (TemperatureSensor)

  // Snapshot bruto dos parâmetros lidos (nome→valor) — debug e métricas futuras.
  raw           Json?

  createdAt     DateTime @default(now()) @map("created_at")

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device        Tr069Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, capturedAt])
  @@index([deviceId, capturedAt])
  @@map("tr069_diagnostics")
}

/// Alerta de diagnóstico proativo. Aberto quando um limiar é cruzado
/// (ex.: RX < -27 dBm) e resolvido quando o valor normaliza ou o CPE volta a
/// comunicar. A regra "1 alerta OPEN por (device,type)" é garantida em código
/// (não dá pra expressar índice único parcial no Prisma).
model Tr069Alert {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  deviceId    String   @map("device_id") @db.Uuid

  type        Tr069AlertType
  severity    Tr069AlertSeverity @default(WARNING)
  status      Tr069AlertStatus   @default(OPEN)

  // Mensagem legível + valor que disparou (pra UI e histórico).
  message     String   @db.Text
  value       Decimal? @db.Decimal(8, 2)

  openedAt    DateTime  @default(now()) @map("opened_at")
  resolvedAt  DateTime? @map("resolved_at")
  // Última vez que a condição foi reobservada (mantém o alerta "fresco").
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device      Tr069Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, severity])
  @@index([deviceId, status])
  @@map("tr069_alerts")
}

enum Tr069DiagKind {
  DOWNLOAD
  UPLOAD
  PING
  TRACEROUTE
}

enum Tr069DiagState {
  REQUESTED
  COMPLETED
  ERROR
}

/// Execução on-demand de um diagnóstico TR-143 (speed test / ping) disparado
/// pelo operador. O ACS seta DiagnosticsState=Requested no CPE; quando o CPE
/// manda "8 DIAGNOSTICS COMPLETE", o ACS lê os resultados e fecha a run.
model Tr069DiagnosticRun {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  deviceId       String          @map("device_id") @db.Uuid

  kind           Tr069DiagKind
  state          Tr069DiagState  @default(REQUESTED)
  target         String?         @db.VarChar(512)   // URL (speed) ou host (ping)

  // Resultados (preenchidos quando COMPLETED):
  throughputKbps Int?            @map("throughput_kbps")   // download/upload
  pingSuccess    Int?            @map("ping_success")
  pingFailure    Int?            @map("ping_failure")
  pingAvgMs      Decimal?        @map("ping_avg_ms") @db.Decimal(8, 2)
  pingMinMs      Decimal?        @map("ping_min_ms") @db.Decimal(8, 2)
  pingMaxMs      Decimal?        @map("ping_max_ms") @db.Decimal(8, 2)
  errorText      String?         @map("error_text") @db.Text
  raw            Json?

  requestedBy    String?         @map("requested_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  completedAt    DateTime?       @map("completed_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device         Tr069Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, createdAt])
  @@index([deviceId, kind, state])
  @@map("tr069_diagnostic_runs")
}

// =============================================================================
// TR-069 PROFILES — motor de conformidade (desired-state / drift remediation)
// =============================================================================
// Profile = config padrão de um modelo homologado (manufacturer/productClass/
// firmware). O reconciliador compara o snapshot do CPE com as regras e remedia
// (auto-enforce). IPv6 Origin vira uma regra. Decidido jun/2026.

enum Tr069RuleSource {
  STATIC                 // valor fixo na regra (staticValue)
  CONTRACT_PPPOE_USER
  CONTRACT_PPPOE_PASS
  CONTRACT_PPPOE_VLAN
  CONTRACT_WIFI_SSID
  CONTRACT_WIFI_SSID_5G  // SSID 5G derivado (sufixo -5G no DUAL_BAND)
  CONTRACT_WIFI_PASS
  TENANT_ACCESS_PASSWORD // senha de acesso padrão do Tr069TenantConfig (cifrada)
}

enum Tr069RuleMode {
  ENFORCE      // diverge → SET automático
  REPORT_ONLY  // diverge → só registra drift, não escreve
}

enum Tr069ComplianceStatus {
  UNKNOWN         // ainda não reconciliado
  COMPLIANT       // bate com o profile
  DRIFTED         // divergência detectada (report-only ou pré-remediação)
  REMEDIATING     // SET enfileirado, aguardando confirmação
  PENDING_REBOOT  // SET aplicado, aguarda reboot pra valer
  FAILED          // remediação não convergiu após N tentativas
}

enum Tr069DriftStatus {
  OPEN
  REMEDIATING
  PENDING_REBOOT
  RESOLVED
  FAILED
}

model Tr069Profile {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid

  name            String   @db.VarChar(120)
  // Matching do modelo homologado. productClass/firmwarePattern null = curinga.
  manufacturer    String   @db.VarChar(64)
  productClass    String?  @map("product_class") @db.VarChar(64)
  firmwarePattern String?  @map("firmware_pattern") @db.VarChar(64)

  // Bump de versão → marca devices stale pra re-reconciliar (campanha).
  version         Int      @default(1)
  active          Boolean  @default(true)

  createdById     String?  @map("created_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules           Tr069ProfileRule[]
  devices         Tr069Device[]

  @@unique([tenantId, name])
  @@index([tenantId, manufacturer, productClass])
  @@map("tr069_profiles")
}

model Tr069ProfileRule {
  id             String          @id @default(uuid()) @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid

  // Path TR-069 (data model). Ex.: ...WANPPPConnection.1.X_HW_IPv6.IPv6Address.1.Origin
  param          String          @db.VarChar(255)
  valueType      String          @default("xsd:string") @map("value_type") @db.VarChar(32)
  source         Tr069RuleSource @default(STATIC)
  // Valor esperado quando source=STATIC. Para sources derivadas, ignorado.
  staticValue    String?         @map("static_value") @db.VarChar(255)

  mode           Tr069RuleMode   @default(REPORT_ONLY)
  // Aplica só após reboot (ex.: IPv6 Origin). O reconciliador defere o reboot.
  requiresReboot Boolean         @default(false) @map("requires_reboot")
  enabled        Boolean         @default(true)
  sortOrder      Int             @default(0) @map("sort_order")

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  profile        Tr069Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, param])
  @@index([profileId])
  @@map("tr069_profile_rules")
}

model Tr069Drift {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  deviceId       String           @map("device_id") @db.Uuid

  param          String           @db.VarChar(255)
  expected       String?          @db.VarChar(255)
  actual         String?          @db.VarChar(255)

  status         Tr069DriftStatus @default(OPEN)
  requiresReboot Boolean          @default(false) @map("requires_reboot")
  attempts       Int              @default(0)
  // Task de remediação corrente (SET) — referência solta (sem FK).
  taskId         String?          @map("task_id") @db.Uuid

  detectedAt     DateTime         @default(now()) @map("detected_at")
  lastSeenAt     DateTime         @default(now()) @map("last_seen_at")
  resolvedAt     DateTime?        @map("resolved_at")

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device         Tr069Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, status])
  @@index([tenantId, status])
  @@map("tr069_drifts")
}

// =============================================================================
// TR069_DEVICE_NOTE — anotações livres do atendimento N1 sobre um CPE
// =============================================================================
// Notas operacionais do atendente (ex.: "cliente trocou de cômodo", "fibra
// reterminada em 18/06"). Soft-delete pra preservar histórico. Autor é
// referência solta ao User (sem FK) com email cacheado pra render sem join.
// -----------------------------------------------------------------------------
// Catálogo de firmware TR-069 — imagem por fabricante/modelo, armazenada em
// disco (TR069_FIRMWARE_DIR) e servida ao CPE pelo cwmp-server em /fw/{id}.
// O rollout cria Tr069Tasks DOWNLOAD com payload.firmwareId — o status da
// campanha é lido de volta por esse vínculo (sem tabela de rollout própria).
// -----------------------------------------------------------------------------
model Tr069Firmware {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  /// Vendor do registry de paths (HUAWEI | ZTE | VSOL | ZYXEL) — informativo.
  vendor       String   @db.VarChar(16)
  /// ProductClass EXATO reportado no Inform (F670L, EG8145V5…) — chave do alvo.
  productClass String   @map("product_class") @db.VarChar(64)
  version      String   @db.VarChar(64)
  fileName     String   @map("file_name") @db.VarChar(255)
  fileSize     Int      @map("file_size")
  /// SHA-256 do arquivo (hex) — integridade e dedup manual.
  checksum     String   @db.VarChar(64)
  notes        String?
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, vendor, productClass])
  @@map("tr069_firmwares")
}

model Tr069DeviceNote {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @map("tenant_id") @db.Uuid
  deviceId       String      @map("device_id") @db.Uuid

  body           String      @db.Text
  createdById    String?     @map("created_by_id") @db.Uuid
  createdByEmail String?     @map("created_by_email") @db.VarChar(255)

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device         Tr069Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, deviceId, deletedAt])
  @@map("tr069_device_notes")
}


// =============================================================================
// PROVISIONING_EVENT — trilha de auditoria do orquestrador
// =============================================================================
// Cada chamada de driver (authorize, deauthorize, status poll) gera 1 evento.
// Histórico imutável pra debug ("por que cliente X não subiu?"). Separado de
// audit_log pq tem retenção/cardinalidade diferentes — provisioning gera muito
// volume e merece índice próprio.

enum ProvisioningEventStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
}

enum ProvisioningEventAction {
  OLT_AUTHORIZE
  OLT_DEAUTHORIZE
  OLT_STATUS_POLL
  OLT_TEST_CONNECTION
  TR069_TASK_ENQUEUE
  TR069_INFORM_RECEIVED
  RADIUS_ENQUEUE
  CONTRACT_ACTIVATE
  TR069_WIFI_OPT       // pacote de otimização Wi-Fi (bootstrap/plan-change/rollout)
  TR069_CHANNEL_SWITCH // troca de canal 5G observada em device GIGA (radar/DFS)
}

model ProvisioningEvent {
  id           String                  @id @default(uuid()) @db.Uuid
  tenantId     String                  @map("tenant_id") @db.Uuid
  contractId   String?                 @map("contract_id") @db.Uuid
  ontId        String?                 @map("ont_id") @db.Uuid
  oltId        String?                 @map("olt_id") @db.Uuid

  action       ProvisioningEventAction
  status       ProvisioningEventStatus @default(PENDING)
  // Detalhes da chamada (input, response, fault). JSON pra flexibilidade
  // entre drivers — cada driver loga seu próprio formato.
  payload      Json?
  error        String?                 @db.Text
  durationMs   Int?                    @map("duration_ms")

  // Quem disparou (técnico em campo, cron, webhook).
  actorUserId  String?                 @map("actor_user_id") @db.Uuid
  actorKind    String                  @default("user") @map("actor_kind") @db.VarChar(32)
                                       // "user"|"cron"|"webhook"|"system"

  createdAt    DateTime                @default(now()) @map("created_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, contractId, createdAt])
  @@index([tenantId, ontId])
  @@index([tenantId, status, createdAt])
  @@map("provisioning_events")
}

// =============================================================================
// WIFI-OPT — rollout em ondas do pacote de otimização Wi-Fi Huawei
// =============================================================================
// O baseline mora AQUI (Json da wave) porque `parametersSnapshot` do device é
// sobrescrito a cada Inform e `tr069_diagnostics` tem retenção de 30d — a onda
// precisa do retrato do momento da captura pra comparar depois do push.
// `deviceId` é o OUI-SN (string) SEM FK de propósito: o swap de ONT deleta a
// row de tr069_devices e o histórico da onda deve sobreviver.

enum WifiOptWaveStatus {
  DRAFT       // criada, ainda sem start
  RUNNING     // motor de ondas atuando (cron por minuto)
  GATE_PASSED // terminou e o gate de qualidade aprovou
  GATE_FAILED // terminou reprovada (bloqueia a próxima onda sem force)
  CANCELLED   // operador abortou
}

enum WifiOptWaveDeviceState {
  QUEUED      // aguardando janela/baseline
  BASELINED   // baseline (diagnostics) + GET "previous" capturados
  PUSHED      // SET do pacote enfileirado/entregue
  VERIFYING   // task DONE; observando clientes pós-push
  APPLIED     // 2h com clientes vistos — sucesso
  ROLLED_BACK // rollback automático disparado (clientes zeraram)
  SKIPPED     // offline/sem insumo após N tentativas — não é falha
  FAILED      // task terminal FAILED no ACS
}

model WifiOptWave {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  name        String            @db.VarChar(120)
  status      WifiOptWaveStatus @default(DRAFT)
  startedAt   DateTime?         @map("started_at")
  completedAt DateTime?         @map("completed_at")
  // Relatório do gate: { avgRssiDelta, sustainedDrops, rolledBack, pass }.
  gateReport  Json?             @map("gate_report")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  devices     WifiOptWaveDevice[]

  @@index([tenantId, status])
  @@map("wifi_opt_waves")
}

model WifiOptWaveDevice {
  id           String                 @id @default(uuid()) @db.Uuid
  waveId       String                 @map("wave_id") @db.Uuid
  tenantId     String                 @map("tenant_id") @db.Uuid
  // Tr069Device.deviceId (OUI-SN, string) — SEM FK, ver comentário da seção.
  deviceId     String                 @map("device_id") @db.VarChar(128)
  ontId        String?                @map("ont_id") @db.Uuid
  state        WifiOptWaveDeviceState @default(QUEUED)
  // { capturedAt, clients24, clients5, rssiByMac, avgRssi, channel5 } —
  // copiado de tr069_diagnostics no momento da captura.
  baseline     Json?
  // { ssid5, bandSteeringPolicy, ht20, wifiBandMode } — GET pré-push, insumo
  // do rollback automático. NUNCA guarda PSK.
  previous     Json?
  attempts     Int                    @default(0)
  error        String?                @db.Text
  pushedAt     DateTime?              @map("pushed_at")
  verifiedAt   DateTime?              @map("verified_at")
  rolledBackAt DateTime?              @map("rolled_back_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wave         WifiOptWave @relation(fields: [waveId], references: [id], onDelete: Cascade)

  @@unique([waveId, deviceId])
  @@index([tenantId, state])
  @@map("wifi_opt_wave_devices")
}

// -----------------------------------------------------------------------------
// UFINET — rede neutra PY (API TM Forum, assíncrona). Task #29.
// -----------------------------------------------------------------------------
// 1 contrato = 1 serviço óptico Ufinet (1:1). A Ufinet provisiona SÓ a camada
// óptica; o RADIUS/PPPoE local do NetX continua autorizando o tráfego e o QoS
// (Caso A — todo cliente é "ZUX 1G" na Ufinet, banda real vem do Mikrotik).
//
// O ciclo de vida é uma sequência de ORDENS TMF assíncronas (cada POST/PATCH
// cria uma ordem com `serviceOrderId` que se faz poll via GET até
// state=completed/Failed). Esta tabela guarda a IDENTIDADE estável do serviço
// (externalId, ids dos 4 sub-serviços, CTO_PORT) + a OPERAÇÃO em voo
// (currentOrderId/attempts), e o `lifecycle` é a fonte de verdade de onde o
// contrato está no mundo Ufinet. O poller (cron) avança os estados transientes.
//
// Bundle de 4 sub-serviços por serviço (mapeado ao vivo em QA):
//   spec 10 Datos        → serviço-pai (parentServiceId / idService de sync)
//   spec  3 Fiber Access → camada óptica
//   spec  5 HSD          → sinaliza Active/Inactive em suspend/reactivate
//   spec  4 Res Pon Access → IdResponAccess do "Confirmar ONT" (PATCH + SN)
enum UfinetLifecycle {
  PENDING_PROVIDE     // criada no NetX; alta (provide) ainda não enviada
  PROVIDING           // alta enviada; aguardando reserva de porta
  RESERVED            // porta reservada; aguarda técnico confirmar ONT em campo
  CONFIRMING_ONT      // PATCH Res Pon Access (SN) + sync enviados; aguardando
  CONFIRMING_SERVICE  // PATCH order (CTO_PORT + LABEL_DROP) enviado; aguardando
  ACTIVE              // todos os sub-serviços Active
  SUSPENDING
  SUSPENDED
  REACTIVATING
  SWAPPING_ONT        // troca de ONT (CHANGE_RESOURCE) enviada; aguardando
  CEASING             // baja enviada
  CEASED
  CANCELLING          // cancelación enviada (só se ONT não confirmada)
  CANCELLED
  FAILED              // erro terminal — requer ação manual (retry)
}

model UfinetService {
  id                    String          @id @default(uuid()) @db.Uuid
  tenantId              String          @map("tenant_id") @db.Uuid
  contractId            String          @map("contract_id") @db.Uuid
  oltId                 String          @map("olt_id") @db.Uuid

  // externalId = código do contrato (Contract.code, ex.: ZUX-234) — serve como
  // externalId TMF, LABEL_DROP e etiqueta do técnico em campo. O sequencial
  // vive no Contract agora (não mais aqui).
  externalId            String          @map("external_id") @db.VarChar(80)
  labelDrop             String          @map("label_drop") @db.VarChar(80)
  bandwidthProfile      String          @default("ZUX 1G") @map("bandwidth_profile") @db.VarChar(64)

  lifecycle             UfinetLifecycle @default(PENDING_PROVIDE)

  // ── Identificadores do lado Ufinet (preenchidos conforme o fluxo avança) ──
  ufinetContractId      String?         @map("ufinet_contract_id") @db.VarChar(32)  // idContrato
  serviceOrderId        String?         @map("service_order_id") @db.VarChar(32)    // ordem de alta (provide)
  parentServiceId       String?         @map("parent_service_id") @db.VarChar(32)   // Datos (idService p/ sync)
  fiberAccessServiceId  String?         @map("fiber_access_service_id") @db.VarChar(32)
  hsdServiceId          String?         @map("hsd_service_id") @db.VarChar(32)
  resPonAccessServiceId String?         @map("res_pon_access_service_id") @db.VarChar(32)
  // ctoPort = CAIXA (CTO) enviada à Ufinet como CTO_PORT — eles controlam só a
  // caixa, não a porta. dropPort = porta (1..16) que o técnico usou, guardada
  // SÓ pra doc interna do NetX (não vai pra Ufinet).
  ctoPort               String?         @map("cto_port") @db.VarChar(64)
  dropPort              String?         @map("drop_port") @db.VarChar(16)
  serialNumber          String?         @map("serial_number") @db.VarChar(32)       // SN GPON da ONT confirmada

  // Última leitura de níveis ópticos (STATUS_ONT) — array [{name,value}] + quando.
  // Sempre exibido no contrato (a última leitura disponível, com timestamp).
  lastSignalLevels      Json?           @map("last_signal_levels")
  lastSignalAt          DateTime?       @map("last_signal_at")

  // ── Operação em voo (consumida pelo poller) ──────────────────────────────
  currentOrderId        String?         @map("current_order_id") @db.VarChar(32)    // serviceOrderId do passo atual
  ufinetState           String?         @map("ufinet_state") @db.VarChar(32)        // initial/inProgress/completed/Failed
  waitingCode           String?         @map("waiting_code") @db.VarChar(16)        // !=0 = precisa trabalho de campo
  attempts              Int             @default(0)
  nextAttemptAt         DateTime?       @map("next_attempt_at")
  // Âncora do teto de espera em "aprovisionando" (Ufinet 426). Marcado no 1º
  // tick pending; limpo quando o serviço avança/poll normal. Estourou 1h → FAILED.
  pendingSince          DateTime?       @map("pending_since")
  lastResponse          Json?           @map("last_response")
  error                 String?         @db.Text

  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract              Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  olt                   Olt             @relation(fields: [oltId], references: [id], onDelete: Restrict)

  @@unique([contractId])
  @@unique([tenantId, externalId])
  @@index([tenantId, lifecycle])
  @@index([nextAttemptAt])
  @@map("ufinet_services")
}

// Trilha completa de request/response NetX↔Ufinet por serviço (externalId).
// NUNCA guarda token nem o header Access — só método/rota/corpos de negócio.
// Serve de EVIDÊNCIA pra abrir chamado com a Ufinet (export por serviço).
model UfinetRequestLog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  externalId   String   @map("external_id") @db.VarChar(80)
  method       String   @db.VarChar(8)
  path         String   @db.VarChar(255)
  status       Int?     // null = erro de transporte (timeout/conexão)
  durationMs   Int      @map("duration_ms")
  requestBody  Json?    @map("request_body")
  responseBody Json?    @map("response_body")
  error        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId, externalId, createdAt])
  @@map("ufinet_request_logs")
}

// -----------------------------------------------------------------------------
// MOBILE — app do técnico em campo (Expo + React Native)
// -----------------------------------------------------------------------------
// Cada instalação do app pareada com um User vira uma linha aqui. Permite
// admin revogar acesso por device perdido sem invalidar a sessão web do
// mesmo user. `lastPulledAt` será usado pelo endpoint /mobile/sync/pull
// pra entregar só changes desde a última sincronização.
//
// `deviceId` vem de `expo-application` (Application.androidId em Android,
// ios.identifierForVendor no iOS). Estável por install. Reinstalou app =
// novo deviceId = nova linha (a antiga fica como histórico até revoked).
enum MobilePlatform {
  IOS
  ANDROID
}

model MobileDevice {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  userId       String         @map("user_id") @db.Uuid

  deviceId     String         @map("device_id") @db.VarChar(128)
  platform     MobilePlatform
  model        String?        @db.VarChar(120)  // ex. "SM-G990B", "iPhone15,2"
  osVersion    String?        @map("os_version") @db.VarChar(32)
  appVersion   String         @map("app_version") @db.VarChar(32)
  pushToken    String?        @map("push_token") @db.VarChar(255) // Expo push token

  lastPulledAt DateTime?      @map("last_pulled_at")
  lastSeenAt   DateTime       @default(now()) @map("last_seen_at")
  revokedAt    DateTime?      @map("revoked_at")  // soft-delete (admin revoga)
  revokedReason String?       @map("revoked_reason") @db.VarChar(255)

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, deviceId])
  @@index([tenantId, userId])
  @@index([tenantId, lastSeenAt])
  @@map("mobile_devices")
}

// =============================================================================
// Rede óptica (OSP) — R2: Caixas ópticas + portas
// =============================================================================
// Modelos pra planta FTTH externa. Doc de visão: docs/architecture/osp-network.md
//
// Estrutura típica:
//   OLT → cabo backbone → CTO (parent) → cabo distribuição → CTO/Splitter →
//   cabo drop → cliente
//
// `parentId` em OpticalEnclosure permite cascateamento (CTO mãe → CTOs filhas).
// `splitterRatio` só faz sentido pra SPLITTER (ratio óptico — afeta loss em dB
// no R5 power budget).

enum OpticalEnclosureType {
  CTO       // Caixa Terminal Óptica — atende clientes diretamente
  NAP       // Network Access Point — ponto de derivação
  SPLITTER  // Caixa só com splitter óptico (sem porta de cliente)
  EMENDA    // Caixa de emenda (sem splitter, só fusões)
  RESERVA   // Reserva técnica — sobra de cabo enrolada (poste/caixa pequena)
}

enum SplitterRatio {
  ONE_TO_2
  ONE_TO_4
  ONE_TO_8
  ONE_TO_16
  ONE_TO_32
  ONE_TO_64
}

enum OpticalMountType {
  POSTE
  AEREO
  SUBTERRANEO
  PAREDE
  RACK
}

enum OpticalPortStatus {
  FREE       // disponível pra atribuir
  RESERVED   // reservada (instalação agendada)
  USED       // ocupada por contrato (contractId preenchido)
  DAMAGED    // queimada/quebrada — não pode usar
}

model OpticalEnclosure {
  id              String                @id @default(uuid()) @db.Uuid
  tenantId        String                @map("tenant_id") @db.Uuid
  // Código humano: CTO-001, NAP-A-12, SP-3F-007
  code            String                @db.VarChar(40)
  type            OpticalEnclosureType
  // null = standalone; preenchido = cascateado a partir desta caixa-pai
  parentId        String?               @map("parent_id") @db.Uuid
  // Geo obrigatória — caixa sem coord não aparece no mapa, então não vale
  // muito. Operador marca via LocationPicker no form.
  latitude        Decimal               @db.Decimal(9, 6)
  longitude       Decimal               @db.Decimal(9, 6)
  mountType       OpticalMountType?     @map("mount_type")
  // Splitter ratio (loss) — só faz sentido em type=SPLITTER OU em CTO/NAP
  // que tenha splitter embutido (modelo de mercado). null = não há splitter
  // óptico (caixa puramente passiva de derivação ou emenda).
  splitterRatio   SplitterRatio?        @map("splitter_ratio")
  // Capacidade total = número de portas físicas. Geralmente bate com o ratio
  // (1:16 → 16 portas), mas separamos pra suportar caixas híbridas.
  capacity        Int
  // Endereço descritivo livre (poste #, rua, marco) pra técnico achar em campo.
  locationLabel   String?               @map("location_label") @db.VarChar(255)
  notes           String?               @db.Text
  isActive        Boolean               @default(true) @map("is_active")

  createdById     String?               @map("created_by_id") @db.Uuid
  updatedById     String?               @map("updated_by_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")
  // Lote de import KMZ/KML que criou esta caixa (pra desfazer o import inteiro).
  importBatchId   String?               @map("import_batch_id") @db.Uuid

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent          OpticalEnclosure?     @relation("EnclosureChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children        OpticalEnclosure[]    @relation("EnclosureChildren")
  ports           OpticalPort[]
  // Cabos entrando nesta caixa (terminação física). Backend lista isso pra
  // vista esquemática Tomodat-like (R4.5b).
  cablesEndingHereA FiberCable[]        @relation("CableEndpointA")
  cablesEndingHereB FiberCable[]        @relation("CableEndpointB")
  createdBy       User?                 @relation("OpticalEnclosureCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?                 @relation("OpticalEnclosureUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // R4.5e — organização administrativa (pasta opcional). Permite operador
  // agrupar por região/projeto/cliente sem mexer na topologia técnica.
  folderId        String?               @map("folder_id") @db.Uuid
  folder          NetworkFolder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Vínculo de rede (provisionamento): qual OLT atende esta caixa e, quando a
  // OLT fala direto (DIRECT), qual porta PON. Quando a OLT é ORCHESTRATOR
  // (Ufinet), só a OLT é vinculada — a PON é abstraída pela rede neutra.
  oltId           String?               @map("olt_id") @db.Uuid
  ponPortId       String?               @map("pon_port_id") @db.Uuid
  olt             Olt?                  @relation(fields: [oltId], references: [id], onDelete: SetNull)
  ponPort         PonPort?              @relation(fields: [ponPortId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@index([tenantId, folderId])
  @@index([tenantId, oltId])
  @@index([tenantId, importBatchId])
  @@map("optical_enclosures")
}

model OpticalPort {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  enclosureId     String              @map("enclosure_id") @db.Uuid
  // Número da porta 1..enclosure.capacity. Validado no service no create/update.
  number          Int
  status          OpticalPortStatus   @default(FREE)
  // FK pro contrato atendido. SetNull permite contrato cancelar sem perder
  // o histórico da porta (porta volta a FREE). Audit log mantém quem ocupou.
  // @unique aqui (não compound) porque Prisma exige unique simples no lado
  // owning de relação 1:1. Como contractId já é UUID globalmente único e o
  // Contract já carrega tenantId, o constraint cross-tenant é redundante.
  contractId      String?             @unique @map("contract_id") @db.Uuid
  // Observação livre — ex: "fibra 3 do cabo BB-001", "fundida em 2026-04-12".
  notes           String?             @db.Text

  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enclosure       OpticalEnclosure    @relation(fields: [enclosureId], references: [id], onDelete: Cascade)
  contract        Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)

  // Uma porta por (enclosure, número) — evita duplicar slot físico.
  @@unique([enclosureId, number])
  @@index([tenantId, status])
  @@map("optical_ports")
}

// =============================================================================
// Rede óptica (OSP) — R3: Cabos de fibra
// =============================================================================
// FiberCable modela um trecho de cabo geo-localizado por uma LineString
// (sequência de pontos lat/lng). Backend calcula comprimento via @turf/length
// se `lengthMeters` não for explicitado.
//
// Conceito de "fibra individual" não vira tabela aqui — fica implícito no
// fiberCount + índice (1..fiberCount). R4 (FiberSplice) referencia fibra por
// `(cableId, fiberIndex)`.

enum FiberCableType {
  BACKBONE       // OLT → primeiro splitter de distribuição
  DISTRIBUTION   // splitter intermediário → caixa de cliente
  DROP           // CTO/NAP → ONT do cliente (última milha)
}

model FiberCable {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  code            String           @db.VarChar(40)
  type            FiberCableType
  // Quantidade de fibras dentro do cabo. Valores comuns FTTH:
  // 2/6/12/24/48/96/144/288. Validado no DTO Zod (multipliers do ITU/TIA).
  fiberCount      Int              @map("fiber_count")
  // Geometria como LineString GeoJSON: array de [longitude, latitude].
  // Atenção: ordem GeoJSON oficial é [LNG, LAT] (RFC 7946). Mas no resto
  // do app usamos {latitude, longitude}; o service serializa/desserializa
  // pra manter a API consistente — o JSON puro só fica nesse modelo.
  path            Json
  // Comprimento em metros. Backend calcula via Haversine ao salvar; operador
  // pode override (cabo "frouxo" no poste tem 10-15% a mais que a distância
  // em linha reta dos vértices).
  lengthMeters    Decimal          @map("length_meters") @db.Decimal(12, 2)

  // Pontas físicas do cabo — onde ele TERMINA (R4.5a). Permite à vista
  // esquemática da caixa (Tomodat-like) saber quais cabos entram nela.
  // Nullable porque cabos antigos foram criados sem isso, e cabos "soltos"
  // ainda não conectados existem na construção da planta. SetNull em delete
  // da caixa: cabo continua existindo no banco, só perde o vínculo.
  endpointAId     String?          @map("endpoint_a_id") @db.Uuid
  endpointBId     String?          @map("endpoint_b_id") @db.Uuid

  notes           String?          @db.Text
  isActive        Boolean          @default(true) @map("is_active")

  createdById     String?          @map("created_by_id") @db.Uuid
  updatedById     String?          @map("updated_by_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  // Lote de import KMZ/KML que criou este cabo (pra desfazer o import inteiro).
  importBatchId   String?          @map("import_batch_id") @db.Uuid

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("FiberCableCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?            @relation("FiberCableUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  endpointA       OpticalEnclosure? @relation("CableEndpointA", fields: [endpointAId], references: [id], onDelete: SetNull)
  endpointB       OpticalEnclosure? @relation("CableEndpointB", fields: [endpointBId], references: [id], onDelete: SetNull)
  splicesA        FiberSplice[]    @relation("SpliceCableA")
  splicesB        FiberSplice[]    @relation("SpliceCableB")
  events          FiberEvent[]
  ponPorts        PonPort[]

  // R4.5e — pasta opcional.
  folderId        String?          @map("folder_id") @db.Uuid
  folder          NetworkFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([tenantId, endpointAId])
  @@index([tenantId, endpointBId])
  @@index([tenantId, folderId])
  @@index([tenantId, importBatchId])
  @@map("fiber_cables")
}

// =============================================================================
// Rede óptica (OSP) — R4: Fusões / emendas (FiberSplice)
// =============================================================================
// Cada fusão é um ponto físico onde 2 fibras se encontram: cabo A fibra X
// fundida com cabo B fibra Y. lossDb é a atenuação medida (machine fusora /
// OTDR puxa esse número). Modelo permite a MESMA fibra aparecer em até 2
// splices ativas (representando as 2 pontas — fundida nas extremidades em
// emendas distintas), com warning na UI quando >2. Não bloqueamos no banco
// pra preservar flexibilidade operacional — anel de proteção viola essa
// regra propositadamente, por exemplo.

model FiberSplice {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid

  // Ponto físico da fusão. Pode ou não coincidir com uma OpticalEnclosure
  // existente (caixa de emenda). Por enquanto não FK — operador pode marcar
  // qualquer ponto. Evolução futura: enclosureId opcional pra associar.
  latitude        Decimal         @db.Decimal(9, 6)
  longitude       Decimal         @db.Decimal(9, 6)

  // Lado A
  cableAId        String          @map("cable_a_id") @db.Uuid
  // Índice 1..cableA.fiberCount. Validado no service.
  fiberAIndex     Int             @map("fiber_a_index")

  // Lado B
  cableBId        String          @map("cable_b_id") @db.Uuid
  fiberBIndex     Int             @map("fiber_b_index")

  // Atenuação medida em dB. Default 0.1 (ITU-T G.652 típico em campo). Operador
  // sobrescreve com leitura do OTDR/fusora. nullable pra "não medido ainda".
  lossDb          Decimal?        @map("loss_db") @db.Decimal(4, 2)

  // URL externa de foto (operador hospeda onde quiser; futura iteração:
  // upload integrado via StorageModule + MinIO). nullable.
  photoUrl        String?         @map("photo_url") @db.VarChar(2000)

  // Quando + quem fez a medição. measuredAt nulo = não medido.
  measuredAt      DateTime?       @map("measured_at")
  measuredById    String?         @map("measured_by_id") @db.Uuid

  notes           String?         @db.Text

  createdById     String?         @map("created_by_id") @db.Uuid
  updatedById     String?         @map("updated_by_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cableA          FiberCable      @relation("SpliceCableA", fields: [cableAId], references: [id], onDelete: Restrict)
  cableB          FiberCable      @relation("SpliceCableB", fields: [cableBId], references: [id], onDelete: Restrict)
  measuredBy      User?           @relation("FiberSpliceMeasuredBy", fields: [measuredById], references: [id], onDelete: SetNull)
  createdBy       User?           @relation("FiberSpliceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?           @relation("FiberSpliceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Busca rápida por cabo (R5 power budget traversa o grafo de splices).
  @@index([tenantId, cableAId, fiberAIndex])
  @@index([tenantId, cableBId, fiberBIndex])
  @@map("fiber_splices")
}

// =============================================================================
// Rede óptica (OSP) — R6: Eventos OTDR (rompimentos / atenuações)
// =============================================================================
// Cada evento é uma anomalia detectada pelo OTDR ao longo de UM cabo:
// rompimento físico, curva exagerada, perda inesperada, conector ruim, etc.
// Operador informa a distância (km) reportada pelo aparelho; backend
// calcula lat/lng exato caminhando pela polyline do cabo (@turf/along
// implementado inline via Haversine — sem dep externa).
//
// Status: ativo (resolvedAt = null) ou resolvido (resolvedAt preenchido).
// Pino vermelho no mapa = ativo. Pino cinza = resolvido (histórico).

enum FiberEventType {
  BREAK         // rompimento físico (fibra cortada)
  BEND          // curva excessiva (macro/micro-bending)
  REFLECTION    // reflexão alta (conector ruim, ponto sujo)
  ATTENUATION   // atenuação anormal (degradação)
  CONNECTOR     // conector com problema
  OTHER
}

model FiberEvent {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  cableId         String          @map("cable_id") @db.Uuid

  // Distância do evento a partir da origem do cabo (em metros). Decimal
  // pra preservar precisão das medidas OTDR (típico: ~0.01 m).
  distanceMeters  Decimal         @map("distance_meters") @db.Decimal(12, 2)
  // Fibra específica (opcional — algumas OTDR não isolam, reportam o cabo).
  fiberIndex      Int?            @map("fiber_index")

  // Coordenadas calculadas pelo backend ao criar/editar (a partir do path
  // do cabo + distância). Reescritas se cabo muda de path.
  latitude        Decimal         @db.Decimal(9, 6)
  longitude       Decimal         @db.Decimal(9, 6)

  type            FiberEventType
  // Loss medido pelo OTDR no ponto do evento (opcional).
  lossDb          Decimal?        @map("loss_db") @db.Decimal(4, 2)

  // Quando + quem reportou. resolvedAt = null → evento ativo (precisa atenção).
  reportedAt      DateTime        @default(now()) @map("reported_at")
  reportedById    String?         @map("reported_by_id") @db.Uuid
  resolvedAt      DateTime?       @map("resolved_at")
  resolvedById    String?         @map("resolved_by_id") @db.Uuid

  // URL externa de foto (gráfico do OTDR, foto da área, etc).
  photoUrl        String?         @map("photo_url") @db.VarChar(2000)
  notes           String?         @db.Text

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cable           FiberCable      @relation(fields: [cableId], references: [id], onDelete: Cascade)
  reportedBy      User?           @relation("FiberEventReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)
  resolvedBy      User?           @relation("FiberEventResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  // Eventos ativos do mapa filtram por (tenantId + resolvedAt IS NULL).
  @@index([tenantId, cableId])
  @@index([tenantId, resolvedAt])
  @@map("fiber_events")
}

// =============================================================================
// Rede óptica (OSP) — R4.5e: Pastas (organização administrativa)
// =============================================================================
// Estrutura paralela à topologia técnica. Operador agrupa caixas/cabos por
// região, projeto, cliente, equipe — qualquer eixo que faça sentido na ISP.
// Cada item pode estar em UMA pasta (ou nenhuma). Pasta tem hierarquia
// (parentId) pra refletir organograma de operação.
//
// Tomodat usa esse padrão (CampoNet/NDC/Parceiros/ZUX no print) — permite
// equipes diferentes verem só "a região delas" sem mexer na planta global.

model NetworkFolder {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  parentId        String?         @map("parent_id") @db.Uuid
  name            String          @db.VarChar(120)
  // Cor opcional pra UI distinguir pastas no mapa (hex com #).
  color           String?         @db.VarChar(7)
  // Ordem entre irmãos (drag-drop preserva). null = appended.
  position        Int             @default(0)
  notes           String?         @db.Text

  createdById     String?         @map("created_by_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent          NetworkFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children        NetworkFolder[] @relation("FolderChildren")
  createdBy       User?           @relation("NetworkFolderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  enclosures      OpticalEnclosure[]
  cables          FiberCable[]

  @@index([tenantId, parentId])
  @@map("network_folders")
}

// =============================================================================
// FROTA (Fleet) — veículos, motoristas, despesas, manutenções, rastreamento GPS
//
// Extraído do antigo placeholder em /mapping/vehicles. O "Ao vivo" consome
// posições de um Traccar self-hosted: cada Vehicle.trackerUniqueId casa com o
// device.uniqueId (IMEI) no Traccar; o NetX filtra por tenantId e é a
// autoridade de multi-tenancy (Traccar é uma instância única do deploy).
// =============================================================================

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  VAN
  PICKUP
  OTHER
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

// Ícone do veículo no mapa "Ao vivo" da Frota (escolhido no cadastro).
enum VehicleMapIcon {
  RED_CAR     // carro vermelho
  LADDER_CAR  // carrinho com escada (utilitário de campo)
  WHITE_VAN   // van branca
  TRUCK       // caminhão
}

enum DriverStatus {
  ACTIVE
  INACTIVE
}

enum FleetExpenseType {
  FUEL
  TOLL
  FINE
  INSURANCE
  REPAIR
  TAX
  OTHER
}

enum MaintenanceKind {
  OIL_CHANGE
  REVISION
  TIRES
  BRAKES
  FILTERS
  ALIGNMENT
  OTHER
}

model Vehicle {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid

  plate           String        @db.VarChar(16) // placa (Mercosul BR / chapa PY)
  brand           String?       @db.VarChar(80)
  model           String?       @db.VarChar(80)
  year            Int?
  type            VehicleType   @default(CAR)
  color           String?       @db.VarChar(40)
  renavam         String?       @db.VarChar(32)
  chassis         String?       @db.VarChar(40)
  status          VehicleStatus @default(ACTIVE)
  mapIcon         VehicleMapIcon @default(RED_CAR) @map("map_icon") // ícone no mapa Ao vivo

  // IMEI / uniqueId do rastreador no Traccar. Null = veículo sem rastreador.
  trackerUniqueId String?       @map("tracker_unique_id") @db.VarChar(64)

  odometer        Int           @default(0) // km atual
  notes           String?       @db.Text

  currentDriverId String?       @map("current_driver_id") @db.Uuid

  createdById     String?       @map("created_by_id") @db.Uuid
  updatedById     String?       @map("updated_by_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentDriver   Driver?       @relation("VehicleCurrentDriver", fields: [currentDriverId], references: [id], onDelete: SetNull)
  createdBy       User?         @relation("VehicleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?         @relation("VehicleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  expenses           FleetExpense[]
  maintenancePlans   MaintenancePlan[]
  maintenanceRecords MaintenanceRecord[]
  position           VehiclePosition?

  @@unique([tenantId, plate])
  // Impede dois veículos no mesmo tracker. NULLs são distintos no Postgres,
  // então veículos sem rastreador não colidem.
  @@unique([tenantId, trackerUniqueId])
  @@index([tenantId, status])
  @@index([tenantId, currentDriverId])
  @@map("vehicles")
}

model Driver {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid

  name            String       @db.VarChar(160)
  document        String?      @db.VarChar(32) // CPF / CI
  licenseNumber   String?      @map("license_number") @db.VarChar(32) // CNH
  licenseCategory String?      @map("license_category") @db.VarChar(8) // A, B, AB, D...
  licenseExpiry   DateTime?    @map("license_expiry") @db.Date // base de alerta de vencimento
  phone           String?      @db.VarChar(32)
  status          DriverStatus @default(ACTIVE)

  // Vínculo opcional a um usuário do sistema (técnico que tem login).
  userId          String?      @map("user_id") @db.Uuid

  notes           String?      @db.Text

  createdById     String?      @map("created_by_id") @db.Uuid
  updatedById     String?      @map("updated_by_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?        @relation("DriverUser", fields: [userId], references: [id], onDelete: SetNull)
  createdBy       User?        @relation("DriverCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?        @relation("DriverUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  vehicles        Vehicle[]      @relation("VehicleCurrentDriver")
  expenses        FleetExpense[]

  @@index([tenantId, status])
  @@map("drivers")
}

model FleetExpense {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  vehicleId      String           @map("vehicle_id") @db.Uuid
  driverId       String?          @map("driver_id") @db.Uuid

  type           FleetExpenseType @default(FUEL)
  amount         Decimal          @db.Decimal(12, 2)
  occurredAt     DateTime         @map("occurred_at")
  odometer       Int?
  description    String?          @db.VarChar(500)

  // Integração financeira: caixa que pagou + movimento OUTCOME gerado.
  // cashMovementId é FK polimórfica simples (não relation) — igual padrão
  // de CashMovement.sourceId. Indexado pra lookup reverso.
  cashRegisterId String?          @map("cash_register_id") @db.Uuid
  cashMovementId String?          @map("cash_movement_id") @db.Uuid

  createdById    String?          @map("created_by_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver         Driver?       @relation(fields: [driverId], references: [id], onDelete: SetNull)
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("FleetExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, vehicleId])
  @@index([tenantId, occurredAt])
  @@index([tenantId, type])
  @@index([cashMovementId])
  @@map("fleet_expenses")
}

// Plano de manutenção preventiva: dispara alertas ("trocar óleo", "revisão
// próxima") quando o veículo se aproxima do próximo vencimento por KM ou data.
// Pelo menos um de intervalKm/intervalDays deve estar preenchido (validado no
// service). O nextDue* é recalculado no service ao criar/editar/registrar.
model MaintenancePlan {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @map("tenant_id") @db.Uuid
  vehicleId           String          @map("vehicle_id") @db.Uuid

  kind                MaintenanceKind @default(OIL_CHANGE)
  description         String?         @db.VarChar(255)

  intervalKm          Int?            @map("interval_km")
  intervalDays        Int?            @map("interval_days")

  lastServiceOdometer Int?            @map("last_service_odometer")
  lastServiceDate     DateTime?       @map("last_service_date") @db.Date

  nextDueOdometer     Int?            @map("next_due_odometer")
  nextDueDate         DateTime?       @map("next_due_date") @db.Date

  active              Boolean         @default(true)

  createdById         String?         @map("created_by_id") @db.Uuid
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")

  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle             Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy           User?           @relation("MaintenancePlanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  records             MaintenanceRecord[]

  @@index([tenantId, vehicleId])
  @@index([tenantId, active, nextDueDate])
  @@map("maintenance_plans")
}

// Registro de manutenção executada. Avança o lastService* do plano vinculado
// (e recalcula o próximo vencimento) no service. Custo é informativo — saída
// de caixa de verdade é lançada como FleetExpense (REPAIR), não aqui.
model MaintenanceRecord {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  vehicleId      String           @map("vehicle_id") @db.Uuid
  planId         String?          @map("plan_id") @db.Uuid

  kind           MaintenanceKind  @default(OIL_CHANGE)
  performedAt    DateTime         @map("performed_at") @db.Date
  odometer       Int?
  cost           Decimal?         @db.Decimal(12, 2)
  workshop       String?          @db.VarChar(160)
  description    String?          @db.VarChar(500)

  createdById    String?          @map("created_by_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle        Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  plan           MaintenancePlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  createdBy      User?            @relation("MaintenanceRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, vehicleId])
  @@index([tenantId, performedAt])
  @@map("maintenance_records")
}

// Última posição conhecida de cada veículo (1:1). Atualizada (upsert) a cada
// poll/sync do Traccar. Histórico de rotas, se necessário, vira tabela própria
// no futuro — aqui guardamos só o "agora" pro mapa Ao Vivo.
model VehiclePosition {
  vehicleId   String   @id @map("vehicle_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid

  latitude    Float
  longitude   Float
  speed       Float?   // km/h
  course      Float?   // heading em graus
  altitude    Float?
  address     String?  @db.VarChar(500)
  deviceTime  DateTime @map("device_time")  // horário reportado pelo rastreador
  serverTime  DateTime @default(now()) @map("server_time") // quando o NetX gravou
  attributes  Json?    // payload extra do Traccar (ignition, battery, motion...)
  lastMovedAt DateTime? @map("last_moved_at") // última vez em movimento — base do status IDLE

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, deviceTime])
  @@map("vehicle_positions")
}

// =============================================================================
// RH — RECURSOS HUMANOS / COLABORADORES
// =============================================================================
// Decisões (2026-05-31, ver AGENTS / memória project_netx_rh):
//  - Login do colaborador = User do sistema (Employee.userId 1:1, role restrita).
//    O "portal do colaborador" é uma área self-service em apps/web que resolve
//    Employee onde userId = currentUser.
//  - Folha = lançamento MANUAL (linhas provento/desconto, bruto/líquido por
//    soma). SEM cálculo de INSS/FGTS/IRRF/IPS.
//  - Anexos (contrato, atestado, advertência, comprovante, holerite) via
//    StorageModule (MinIO presigned) — guardamos só a storageKey aqui.

enum EmployeeStatus {
  ACTIVE       // ativo
  ON_LEAVE     // afastado (licença, férias, atestado longo)
  SUSPENDED    // suspenso
  TERMINATED   // desligado
}

enum EmploymentType {
  CLT          // BR — carteira assinada
  PJ           // prestador (pessoa jurídica)
  INTERN       // estágio
  TEMPORARY    // temporário / contrato a prazo
  RELACION_DEPENDENCIA // PY — empregado em relação de dependência (IPS)
  OTHER
}

enum PayFrequency {
  MONTHLY
  BIWEEKLY     // quinzenal
  WEEKLY
}

model Employee {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid

  // Matrícula interna sequencial/legível (única por tenant). Gerada no service.
  registration    String?        @db.VarChar(32)

  // ── Dados pessoais ─────────────────────────────────────────────────────────
  fullName        String         @map("full_name") @db.VarChar(180)
  preferredName   String?        @map("preferred_name") @db.VarChar(80)
  // Documento principal: CPF (BR) ou CI (PY). taxIdType reaproveita semântica
  // do CRM mas guardado como string livre aqui pra não acoplar.
  document        String?        @db.VarChar(32)
  documentType    String?        @map("document_type") @db.VarChar(16) // CPF, CI, RUC...
  // BR: PIS/PASEP · PY: nº de aporte IPS. Identificador previdenciário.
  socialSecurityNo String?       @map("social_security_no") @db.VarChar(32)
  birthDate       DateTime?      @map("birth_date") @db.Date
  gender          String?        @db.VarChar(16)
  maritalStatus   String?        @map("marital_status") @db.VarChar(24)
  nationality     String?        @db.VarChar(48)

  // ── Contato ─────────────────────────────────────────────────────────────────
  email           String?        @db.VarChar(160)
  phone           String?        @db.VarChar(32)
  emergencyContact String?       @map("emergency_contact") @db.VarChar(180)
  emergencyPhone  String?        @map("emergency_phone") @db.VarChar(32)
  address         String?        @db.VarChar(500)

  // ── Vínculo / cargo ───────────────────────────────────────────────────────
  department      String?        @db.VarChar(120)
  position        String?        @db.VarChar(120) // função / cargo
  employmentType  EmploymentType @default(CLT) @map("employment_type")
  status          EmployeeStatus @default(ACTIVE)
  hiredAt         DateTime?      @map("hired_at") @db.Date
  // Fim do contrato de experiência (45/90d BR) — base de alerta no futuro.
  probationEndsAt DateTime?      @map("probation_ends_at") @db.Date
  terminatedAt    DateTime?      @map("terminated_at") @db.Date
  terminationReason String?      @map("termination_reason") @db.VarChar(500)

  // ── Remuneração / jornada ───────────────────────────────────────────────────
  baseSalary      Decimal?       @map("base_salary") @db.Decimal(12, 2)
  payFrequency    PayFrequency   @default(MONTHLY) @map("pay_frequency")
  // Jornada: descrição + carga semanal. Escala detalhada (turnos) fica p/ fase 2.
  weeklyHours     Decimal?       @map("weekly_hours") @db.Decimal(5, 2)
  workSchedule    String?        @map("work_schedule") @db.VarChar(255) // ex.: "Seg-Sex 08:00-17:00"
  // Tolerância de atraso em minutos pro espelho de ponto.
  clockToleranceMin Int          @default(10) @map("clock_tolerance_min")

  // ── Aptidões / acompanhamento RH ────────────────────────────────────────────
  skills          String[]       @default([]) // aptidões (ex.: "fusão fibra", "CNH D")
  notes           String?        @db.Text // observações de acompanhamento do RH

  // ── Vínculos ────────────────────────────────────────────────────────────────
  // Login no sistema. 1:1 — um User é no máximo um colaborador.
  userId          String?        @unique @map("user_id") @db.Uuid
  // Gestor direto (organograma). Self-relation.
  managerId       String?        @map("manager_id") @db.Uuid

  createdById     String?        @map("created_by_id") @db.Uuid
  updatedById     String?        @map("updated_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?          @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  manager         Employee?      @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports         Employee[]     @relation("EmployeeManager")
  createdBy       User?          @relation("EmployeeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?          @relation("EmployeeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  documents       EmployeeDocument[]
  timeEntries     TimeEntry[]
  correctionRequests TimeCorrectionRequest[]
  payslips        Payslip[]
  signatures      DocumentSignature[]

  @@unique([tenantId, registration])
  @@index([tenantId, status])
  @@index([tenantId, department])
  @@index([tenantId, managerId])
  @@map("employees")
}

// ── Documentos do colaborador ────────────────────────────────────────────────
enum EmployeeDocumentType {
  CONTRACT            // contrato de trabalho
  AMENDMENT           // aditivo
  MEDICAL_CERTIFICATE // atestado médico
  WARNING             // advertência
  SUSPENSION          // suspensão
  ID_DOCUMENT         // RG/CI/CPF/etc.
  CERTIFICATE         // certificado / curso
  PAYSLIP             // holerite (também referenciado por Payslip.documentId)
  PAYMENT_RECEIPT     // comprovante de pagamento
  OTHER
}

model EmployeeDocument {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  employeeId      String               @map("employee_id") @db.Uuid

  type            EmployeeDocumentType @default(OTHER)
  title           String               @db.VarChar(200)
  description     String?              @db.VarChar(500)

  // Arquivo no storage (MinIO). storageKey = chave no bucket; null = sem anexo
  // (ex.: advertência registrada só como texto).
  storageKey      String?              @map("storage_key") @db.VarChar(500)
  fileName        String?              @map("file_name") @db.VarChar(255)
  mimeType        String?              @map("mime_type") @db.VarChar(120)
  fileSize        Int?                 @map("file_size")
  // SHA-256 do arquivo — base do "protocolo" de assinatura (prova de integridade).
  fileHash        String?              @map("file_hash") @db.VarChar(64)

  issuedAt        DateTime?            @map("issued_at") @db.Date
  expiresAt       DateTime?            @map("expires_at") @db.Date // p/ alertas de vencimento

  // Exige aceite/assinatura do colaborador no portal? (advertência, contrato…)
  requiresSignature Boolean            @default(false) @map("requires_signature")

  uploadedById    String?              @map("uploaded_by_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy      User?                @relation("EmployeeDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  signature       DocumentSignature?

  @@index([tenantId, employeeId])
  @@index([tenantId, type])
  @@index([tenantId, requiresSignature])
  @@index([tenantId, expiresAt])
  @@map("employee_documents")
}

// Aceite eletrônico "estilo protocolo" — NÃO é assinatura ICP-Brasil/cert
// digital. Prova de ciência: quem, quando, de onde (IP/UA) e contra qual hash.
// 1:1 com o documento (um aceite por doc). Reabrir = limpar e reexigir.
model DocumentSignature {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  documentId      String           @unique @map("document_id") @db.Uuid
  employeeId      String           @map("employee_id") @db.Uuid

  signedAt        DateTime         @default(now()) @map("signed_at")
  // Hash do arquivo no momento do aceite — confere contra EmployeeDocument.fileHash.
  signedFileHash  String?          @map("signed_file_hash") @db.VarChar(64)
  ipAddress       String?          @map("ip_address") @db.VarChar(64)
  userAgent       String?          @map("user_agent") @db.VarChar(400)
  // Texto do aceite exibido ("Li e estou ciente…") — congela o que foi aceito.
  acceptedText    String?          @map("accepted_text") @db.VarChar(1000)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document        EmployeeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@map("document_signatures")
}

// ── Ponto (relógio de ponto) ─────────────────────────────────────────────────
enum TimeEntryType {
  CLOCK_IN     // entrada
  CLOCK_OUT    // saída
  BREAK_START  // início de intervalo
  BREAK_END    // fim de intervalo
}

enum TimeEntrySource {
  PORTAL       // batido pelo colaborador na web (self-service)
  MOBILE       // app do técnico (fase 2 — com GPS)
  MANUAL       // lançado pelo RH (correção aprovada / ajuste)
}

model TimeEntry {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  employeeId      String          @map("employee_id") @db.Uuid

  type            TimeEntryType
  // Momento da marcação (UTC). O espelho agrupa por dia no timezone do tenant.
  occurredAt      DateTime        @map("occurred_at")
  source          TimeEntrySource @default(PORTAL)

  // Geolocalização opcional (fase mobile). Mantido aqui pra não migrar depois.
  latitude        Float?
  longitude       Float?
  ipAddress       String?         @map("ip_address") @db.VarChar(64)

  // Marcação criada/alterada via correção aprovada aponta pra request de origem.
  correctionId    String?         @map("correction_id") @db.Uuid
  notes           String?         @db.VarChar(500)

  createdById     String?         @map("created_by_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("TimeEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId, occurredAt])
  @@index([tenantId, occurredAt])
  @@map("time_entries")
}

enum TimeCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimeCorrectionKind {
  ADD     // faltou bater — adicionar marcação
  EDIT    // bateu errado — corrigir horário de uma marcação
  REMOVE  // marcação indevida — remover
}

// Solicitação do colaborador para corrigir o ponto. Sobe pendente, RH aprova
// ou rejeita. Ao aprovar, o service materializa a mudança em TimeEntry
// (source=MANUAL, correctionId apontando aqui).
model TimeCorrectionRequest {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  employeeId      String               @map("employee_id") @db.Uuid

  kind            TimeCorrectionKind   @default(ADD)
  // Dia de referência da correção.
  targetDate      DateTime             @map("target_date") @db.Date
  // Marcação alvo (EDIT/REMOVE). Null em ADD.
  targetEntryId   String?              @map("target_entry_id") @db.Uuid
  // Tipo + horário propostos (ADD/EDIT).
  proposedType    TimeEntryType?       @map("proposed_type")
  proposedTime    DateTime?            @map("proposed_time")
  reason          String               @db.VarChar(1000)

  status          TimeCorrectionStatus @default(PENDING)
  reviewedById    String?              @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?            @map("reviewed_at")
  reviewNotes     String?              @map("review_notes") @db.VarChar(1000)

  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy      User?                @relation("TimeCorrectionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, employeeId])
  @@map("time_correction_requests")
}

// ── Folha de pagamento (lançamento manual) ──────────────────────────────────
enum PayslipStatus {
  DRAFT     // em edição
  APPROVED  // fechado, pronto p/ pagar
  PAID      // pago (tem SalaryPayment)
  CANCELLED
}

// Holerite/recibo de uma competência. Itens (proventos/descontos) ficam em
// Json — flexível e suficiente pro lançamento manual (sem cálculo legal).
// netAmount = grossAmount - deductionsTotal, calculado no service.
model Payslip {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  employeeId      String        @map("employee_id") @db.Uuid

  // Competência (mês de referência) — dia 1 do mês, no timezone do tenant.
  referenceMonth  DateTime      @map("reference_month") @db.Date

  // Linhas: [{ kind: 'EARNING'|'DEDUCTION', label, amount }]. Validado no DTO.
  items           Json          @default("[]")
  grossAmount     Decimal       @map("gross_amount") @db.Decimal(12, 2) @default(0)
  deductionsTotal Decimal       @map("deductions_total") @db.Decimal(12, 2) @default(0)
  netAmount       Decimal       @map("net_amount") @db.Decimal(12, 2) @default(0)

  status          PayslipStatus @default(DRAFT)
  notes           String?       @db.VarChar(1000)

  // PDF do holerite gerado/anexado (storage). Pode também virar EmployeeDocument.
  storageKey      String?       @map("storage_key") @db.VarChar(500)

  createdById     String?       @map("created_by_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("PayslipCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  payment         SalaryPayment?

  @@unique([tenantId, employeeId, referenceMonth])
  @@index([tenantId, status])
  @@index([tenantId, referenceMonth])
  @@map("payslips")
}

// Pagamento efetivo de um holerite. Integra no caixa: gera CashMovement OUTCOME
// (source=PAYROLL) — mesmo padrão de FleetExpense. cashMovementId é FK
// polimórfica simples (não relation), igual CashMovement.sourceId.
model SalaryPayment {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  payslipId       String        @unique @map("payslip_id") @db.Uuid
  employeeId      String        @map("employee_id") @db.Uuid

  amount          Decimal       @db.Decimal(12, 2)
  paidAt          DateTime      @map("paid_at")
  method          PaymentMethod @default(CASH)

  cashRegisterId  String?       @map("cash_register_id") @db.Uuid
  cashMovementId  String?       @map("cash_movement_id") @db.Uuid

  // Comprovante de pagamento (storage).
  receiptStorageKey String?     @map("receipt_storage_key") @db.VarChar(500)
  notes           String?       @db.VarChar(500)

  createdById     String?       @map("created_by_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslip         Payslip       @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  createdBy       User?         @relation("SalaryPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId])
  @@index([tenantId, paidAt])
  @@index([cashMovementId])
  @@map("salary_payments")
}

// ── Blog / Notícias da empresa (portal do colaborador) ──────────────────────
enum CompanyPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model CompanyPost {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid

  title           String            @db.VarChar(250)
  // Slug legível por tenant (p/ URL no portal).
  slug            String            @db.VarChar(280)
  excerpt         String?           @db.VarChar(500)
  body            String            @db.Text // markdown
  coverStorageKey String?           @map("cover_storage_key") @db.VarChar(500)

  status          CompanyPostStatus @default(DRAFT)
  pinned          Boolean           @default(false) // fixar no topo do feed
  publishedAt     DateTime?         @map("published_at")

  authorId        String?           @map("author_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author          User?             @relation("CompanyPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([tenantId, slug])
  @@index([tenantId, status, publishedAt])
  @@map("company_posts")
}

// =============================================================================
// EFI / EfiPay — Pagamentos BR (Pix imediato + Boleto híbrido com Pix "Bolix")
// Integração SOMENTE BR. Credenciais e certificado por tenant, cifrados
// (CryptoService). O NetX sobe cobranças individuais por fatura — sem
// recorrência/assinatura do lado do EFI.
// =============================================================================
enum EfiEnvironment {
  PRODUCTION
  SANDBOX
}

// PIX   = cobrança imediata Pix (API Pix v2, exige certificado mTLS).
// BOLIX = boleto híbrido com QR Pix embutido (API Cobranças, sem mTLS).
enum EfiChargeKind {
  PIX
  BOLIX
}

enum EfiChargeStatus {
  PENDING  // criada no NetX, ainda não emitida no EFI
  ACTIVE   // emitida no EFI, aguardando pagamento
  PAID     // confirmada paga (webhook)
  CANCELED // cancelada/expirada
  ERROR    // falha ao emitir
}

model EfiConfig {
  id                   String         @id @default(uuid()) @db.Uuid
  tenantId             String         @unique @map("tenant_id") @db.Uuid

  environment          EfiEnvironment @default(PRODUCTION)
  enabled              Boolean        @default(false)

  // Segredos cifrados (CryptoService v1:iv:tag:ct).
  // credentialsEnc = JSON {clientId, clientSecret}. As mesmas credenciais
  // servem pra API Pix e API Cobranças (conta EFI unificada).
  credentialsEnc       String?        @map("credentials_enc") @db.Text
  // Certificado .p12 (base64) — exigido pela API Pix (mTLS). Cobranças não usa.
  certificateEnc       String?        @map("certificate_enc") @db.Text
  // Senha do .p12 (geralmente vazia no EFI). Cifrada.
  certificatePassEnc   String?        @map("certificate_pass_enc") @db.Text

  // Config não-secreta
  pixKey               String?        @map("pix_key") @db.VarChar(140)
  defaultChargeKind    EfiChargeKind  @default(BOLIX) @map("default_charge_kind")
  // Dias até expirar (Pix calendario.expiracao / vencimento do boleto).
  expirationDays       Int            @default(3) @map("expiration_days")
  // Emitir cobrança EFI automaticamente quando a fatura entra em OPEN.
  autoGenerate         Boolean        @default(false) @map("auto_generate")
  // Multa (%) e juros a.m. (%) aplicados no boleto (Bolix). Null = sem.
  finePercent          Decimal?       @map("fine_percent") @db.Decimal(5, 2)
  interestPercent      Decimal?       @map("interest_percent") @db.Decimal(5, 2)
  // Token aleatório validado no querystring do webhook (defesa além do mTLS).
  webhookToken         String?        @map("webhook_token") @db.VarChar(64)
  // Marca se o webhook Pix já foi registrado no EFI (chave/ambiente).
  pixWebhookRegistered Boolean        @default(false) @map("pix_webhook_registered")

  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("efi_configs")
}

model EfiCharge {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  invoiceId     String          @map("invoice_id") @db.Uuid

  kind          EfiChargeKind
  status        EfiChargeStatus @default(PENDING)
  amount        Decimal         @db.Decimal(12, 2)

  // Identificadores do lado EFI
  txid          String?         @db.VarChar(64) // Pix cob
  efiChargeId   String?         @map("efi_charge_id") @db.VarChar(40) // charge_id (Cobranças)
  locId         String?         @map("loc_id") @db.VarChar(40) // location do Pix

  // Artefatos entregáveis ao cliente
  pixCopiaECola String?         @map("pix_copia_e_cola") @db.Text // BR Code (emv)
  pixQrImage    String?         @map("pix_qr_image") @db.Text // dataURL do QR
  barcode       String?         @db.VarChar(64) // linha digitável do boleto
  pdfUrl        String?         @map("pdf_url") @db.VarChar(500)
  paymentLink   String?         @map("payment_link") @db.VarChar(500)

  expiresAt     DateTime?       @map("expires_at")
  paidAt        DateTime?       @map("paid_at")
  paidAmount    Decimal?        @map("paid_amount") @db.Decimal(12, 2)
  endToEndId    String?         @map("end_to_end_id") @db.VarChar(40) // e2eid do Pix pago
  lastError     String?         @map("last_error") @db.Text
  lastPayload   Json?           @map("last_payload")

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice       ContractInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([txid])
  @@index([tenantId, status])
  @@index([tenantId, invoiceId])
  @@index([efiChargeId])
  @@map("efi_charges")
}

// =============================================================================
// BTG Pactual — pagamentos BR (boleto + Pix cobrança + Pix Automático).
// Espelha EfiConfig/EfiCharge, mas auth é OAuth2 via BTG Id com Authorization
// Code obrigatório p/ operar a conta PJ → guardamos refresh_token cifrado.
// Integração SOMENTE BR. Coexiste com EFI (tenant escolhe o gateway ativo).
// =============================================================================
enum BtgEnvironment {
  PRODUCTION
  SANDBOX
}

enum BtgChargeKind {
  BOLETO // boleto registrado (com Pix híbrido quando a conta suporta)
  PIX    // Pix cobrança dinâmica (QR / copia-e-cola)
}

enum BtgChargeStatus {
  PENDING  // criada no NetX, ainda não emitida no BTG
  ACTIVE   // emitida no BTG, aguardando pagamento
  PAID     // confirmada paga (webhook)
  CANCELED // cancelada/expirada
  ERROR    // falha ao emitir
}

model BtgConfig {
  id                 String          @id @default(uuid()) @db.Uuid
  tenantId           String          @unique @map("tenant_id") @db.Uuid

  environment        BtgEnvironment  @default(SANDBOX)
  enabled            Boolean         @default(false)

  // Segredos cifrados (CryptoService v1:iv:tag:ct).
  // credentialsEnc = JSON {clientId, clientSecret} do app registrado no BTG.
  credentialsEnc     String?         @map("credentials_enc") @db.Text
  // refresh_token do Authorization Code (long-lived) — renova o access_token
  // p/ operar a conta PJ. Sem ele as APIs bancárias (boleto/pix) não funcionam.
  refreshTokenEnc    String?         @map("refresh_token_enc") @db.Text

  // OAuth — fluxo de consentimento (Authorization Code)
  redirectUri        String?         @map("redirect_uri") @db.VarChar(500)
  scopes             String?         @db.VarChar(500) // space-separated
  // Conta PJ no BTG: companyId (CNPJ) compõe o path das APIs; número+agência
  // da conta recebedora são exigidos no corpo das cobranças.
  companyId          String?         @map("company_id") @db.VarChar(20)
  accountNumber      String?         @map("account_number") @db.VarChar(20)
  accountBranch      String?         @map("account_branch") @db.VarChar(10)
  authorizedAt       DateTime?       @map("authorized_at")
  authorizedBy       String?         @map("authorized_by") @db.Uuid
  // state aleatório anti-CSRF guardado entre /authorize e /callback.
  oauthState         String?         @map("oauth_state") @db.VarChar(128)

  // Config de cobrança (não-secreta)
  pixKey             String?         @map("pix_key") @db.VarChar(140)
  defaultChargeKind  BtgChargeKind   @default(BOLETO) @map("default_charge_kind")
  expirationDays     Int             @default(3) @map("expiration_days")
  autoGenerate       Boolean         @default(false) @map("auto_generate")
  finePercent        Decimal?        @map("fine_percent") @db.Decimal(5, 2)
  interestPercent    Decimal?        @map("interest_percent") @db.Decimal(5, 2)
  // Token aleatório validado no path do webhook (mapeia tenant).
  webhookToken       String?         @map("webhook_token") @db.VarChar(64)
  // Secret do webhook BTG: vai no Bearer Authorization que o BTG envia e é
  // registrado no BTG ao criar o webhook. Cifrado.
  webhookSecretEnc   String?         @map("webhook_secret_enc") @db.Text
  // Id do webhook retornado pelo BTG no registro (p/ consulta/atualização).
  webhookId          String?         @map("webhook_id") @db.VarChar(64)


  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("btg_configs")
}

model BtgCharge {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  invoiceId     String          @map("invoice_id") @db.Uuid

  kind          BtgChargeKind
  status        BtgChargeStatus @default(PENDING)
  amount        Decimal         @db.Decimal(12, 2)

  // Identificadores do lado BTG
  txid          String?         @db.VarChar(64) // Pix cobrança
  btgChargeId   String?         @map("btg_charge_id") @db.VarChar(64) // id do boleto/cobrança

  // Artefatos entregáveis ao cliente
  pixEmv        String?         @map("pix_emv") @db.Text // copia-e-cola (BR Code)
  pixQrImage    String?         @map("pix_qr_image") @db.Text // dataURL do QR
  barcode       String?         @db.VarChar(64) // código de barras
  digitableLine String?         @map("digitable_line") @db.VarChar(64) // linha digitável
  pdfUrl        String?         @map("pdf_url") @db.VarChar(500)
  paymentLink   String?         @map("payment_link") @db.VarChar(500)

  expiresAt     DateTime?       @map("expires_at")
  paidAt        DateTime?       @map("paid_at")
  paidAmount    Decimal?        @map("paid_amount") @db.Decimal(12, 2)
  endToEndId    String?         @map("end_to_end_id") @db.VarChar(40) // e2eid do Pix pago
  lastError     String?         @map("last_error") @db.Text
  lastPayload   Json?           @map("last_payload")

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice       ContractInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([txid])
  @@index([tenantId, status])
  @@index([tenantId, invoiceId])
  @@index([btgChargeId])
  @@map("btg_charges")
}


enum BtgRecurrenceStatus {
  PENDING    // criada no NetX, ainda não enviada ao BTG
  PROCESSING // BTG processando a autorização
  CREATED    // autorização criada, aguardando aprovação do pagador
  APPROVED   // pagador aprovou a recorrência
  REJECTED   // pagador recusou
  EXPIRED    // expirou sem aprovação
  CANCELED   // cancelada (por nós ou pelo pagador)
  FINISHED   // ciclo de cobranças concluído
  ERROR      // falha ao criar no BTG
}

/// Pix Automático — autorização de recorrência (1 por contrato ativo).
/// O pagador aprova uma vez; o BTG agenda as cobranças automáticas.
model BtgRecurrence {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  contractId      String              @map("contract_id") @db.Uuid

  status          BtgRecurrenceStatus @default(PENDING)
  // identificador do contrato p/ o BTG (campo `link.contract`, max 35, único).
  contractRef     String              @map("contract_ref") @db.VarChar(35)
  authorizationId String?             @map("authorization_id") @db.VarChar(64)

  period          String              @db.VarChar(16) // WEEKLY/MONTHLY/...
  retryPolicy     String              @map("retry_policy") @db.VarChar(20)
  amount          Decimal?            @db.Decimal(12, 2) // null = valor variável
  minimumAmount   Decimal?            @map("minimum_amount") @db.Decimal(12, 2)
  initialDate     DateTime            @map("initial_date")
  finalDate       DateTime?           @map("final_date")
  installments    Int?

  // Artefato p/ o pagador aprovar (QR / copia-e-cola da jornada).
  emv             String?             @db.Text
  qrImage         String?             @map("qr_image") @db.Text

  approvedAt      DateTime?           @map("approved_at")
  canceledAt      DateTime?           @map("canceled_at")
  lastError       String?             @map("last_error") @db.Text
  lastPayload     Json?               @map("last_payload")

  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract        Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contractRef])
  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([authorizationId])
  @@map("btg_recurrences")
}

// =============================================================================
// NFCom — Nota Fiscal Fatura de Serviço de Comunicação Eletrônica (modelo 62).
// Documento fiscal BR para ISP. Autorizador SVRS (RS) p/ quase todos os estados.
// Espinha espelha SifenDocument (PY); transmissão ao Fisco fica atrás de uma
// porta plugável (1o adapter = agregador REST; SVRS-direto fica p/ depois).
// Integração SOMENTE BR. Módulo opcional, ligado por tenant via /settings/nfcom.
// =============================================================================

enum NfcomEnvironment {
  HOMOLOGACAO
  PRODUCAO
}

enum NfcomTransmitter {
  NUVEM_FISCAL // agregador REST (default)
  FOCUS_NFE    // agregador REST alternativo
  SVRS_DIRECT  // XML + XMLDSig + SOAP direto no SVRS (futuro)
}

enum NfcomDocumentType {
  NFCOM             // emissão normal
  NFCOM_SUBSTITUICAO // substitui um NFCom anterior (gSub)
}

enum NfcomDocumentStatus {
  DRAFT      // criado localmente, ainda não transmitido
  SIGNED     // assinado, pronto p/ transmitir
  SENT       // enviado ao Fisco, aguardando retorno
  AUTHORIZED // autorizado (cStat 100) — documento fiscal efetivo
  REJECTED   // rejeitado pelo Fisco — corrigir e reemitir
  DENIED     // denegado (irregularidade fiscal do emitente/destinatário)
  CANCELLED  // cancelado via evento (dentro do prazo)
}

model NfcomConfig {
  id                     String           @id @default(uuid()) @db.Uuid
  tenantId               String           @unique @map("tenant_id") @db.Uuid

  environment            NfcomEnvironment @default(HOMOLOGACAO)
  enabled                Boolean          @default(false)
  transmitter            NfcomTransmitter @default(NUVEM_FISCAL)

  // Segredos cifrados (CryptoService v1:iv:tag:ct).
  // credentialsEnc = JSON {apiKey/token} do agregador escolhido.
  credentialsEnc         String?          @map("credentials_enc") @db.Text
  // Certificado .pfx A1 (base64) — exigido pelo SVRS_DIRECT e por agregadores
  // que assinam com o cert do cliente. Cifrado.
  certificateEnc         String?          @map("certificate_enc") @db.Text
  certificatePasswordEnc String?          @map("certificate_password_enc") @db.Text

  // Identidade do emitente (não-secreto)
  cnpj                   String           @map("cnpj") @db.VarChar(14)
  inscricaoEstadual      String?          @map("inscricao_estadual") @db.VarChar(20)
  razaoSocial            String           @map("razao_social") @db.VarChar(255)
  nomeFantasia           String?          @map("nome_fantasia") @db.VarChar(255)
  crt                    String?          @map("crt") @db.VarChar(1) // regime tributário
  uf                     String           @map("uf") @db.VarChar(2)
  codMunicipio           String?          @map("cod_municipio") @db.VarChar(7)
  // Endereço do emitente (enderEmit do XSD — todos obrigatórios p/ emitir).
  endLogradouro          String?          @map("end_logradouro") @db.VarChar(60)
  endNumero              String?          @map("end_numero") @db.VarChar(60)
  endComplemento         String?          @map("end_complemento") @db.VarChar(60)
  endBairro              String?          @map("end_bairro") @db.VarChar(60)
  endMunicipioNome       String?          @map("end_municipio_nome") @db.VarChar(60)
  endCep                 String?          @map("end_cep") @db.VarChar(8)
  fone                   String?          @map("fone") @db.VarChar(12)
  email                  String?          @map("email") @db.VarChar(255)
  serie                  String           @default("1") @db.VarChar(3)
  nextNumero             Int              @default(1) @map("next_numero")

  // Defaults tributários — denormalizados no NfcomDocument na emissão.
  cstIcms                String?          @map("cst_icms") @db.VarChar(3)
  aliquotaIcms           Decimal?         @map("aliquota_icms") @db.Decimal(5, 2)
  cfop                   String?          @map("cfop") @db.VarChar(4)
  cClass                 String?          @map("c_class") @db.VarChar(7) // código de classificação
  tpServ                 String?          @map("tp_serv") @db.VarChar(2)

  // Emitir NFCom automaticamente a partir da fatura (cron de autogen).
  autoGenerate           Boolean          @default(false) @map("auto_generate")
  webhookToken           String?          @map("webhook_token") @db.VarChar(64)

  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  tenant                 Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("nfcom_configs")
}

model NfcomDocument {
  id                String              @id @default(uuid()) @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid

  // Vínculo opcional (um dos dois). Espelha SifenDocument.
  contractInvoiceId String?             @map("contract_invoice_id") @db.Uuid
  oneTimeChargeId   String?             @map("one_time_charge_id") @db.Uuid

  type              NfcomDocumentType   @default(NFCOM)
  status            NfcomDocumentStatus @default(DRAFT)

  serie             String              @db.VarChar(3)
  numero            Int
  // Chave de acesso 44 dígitos (preenchida após autorização do Fisco).
  chaveAcesso       String?             @unique @map("chave_acesso") @db.VarChar(44)
  protocolo         String?             @map("protocolo") @db.VarChar(20) // nProt da autorização
  transmitterRef    String?             @map("transmitter_ref") @db.VarChar(64) // id do doc no agregador

  emitenteCnpj      String              @map("emitente_cnpj") @db.VarChar(14)
  receptorTaxId     String?             @map("receptor_tax_id") @db.VarChar(20)
  receptorName      String?             @map("receptor_name") @db.VarChar(255)

  totalAmount       Decimal             @map("total_amount") @db.Decimal(14, 2)
  currency          String              @default("BRL") @db.Char(3)

  // Snapshot tributário (copiado da NfcomConfig na emissão).
  cstIcms           String?             @map("cst_icms") @db.VarChar(3)
  aliquotaIcms      Decimal?            @map("aliquota_icms") @db.Decimal(5, 2)
  baseCalculoIcms   Decimal?            @map("base_calculo_icms") @db.Decimal(14, 2)
  valorIcms         Decimal?            @map("valor_icms") @db.Decimal(14, 2)

  // XMLs + representação impressa (DANFE-COM).
  xmlGenerated      String?             @map("xml_generated") @db.Text
  xmlSigned         String?             @map("xml_signed") @db.Text
  xmlAuthorized     String?             @map("xml_authorized") @db.Text
  danfeUrl          String?             @map("danfe_url") @db.VarChar(500) // PDF DANFE-COM do agregador
  qrCodeData        String?             @map("qrcode_data") @db.Text

  // Resposta do Fisco + eventos.
  authResponse      Json?               @map("auth_response")
  rejectionCode     String?             @map("rejection_code") @db.VarChar(20)
  rejectionReason   String?             @map("rejection_reason") @db.Text
  cancelProtocol    String?             @map("cancel_protocol") @db.VarChar(20)
  cancelReason      String?             @map("cancel_reason") @db.Text
  substitutesId     String?             @map("substitutes_id") @db.Uuid // gSub — NFCom substituído

  // Timeline.
  issuedAt          DateTime            @map("issued_at")
  signedAt          DateTime?           @map("signed_at")
  sentAt            DateTime?           @map("sent_at")
  authorizedAt      DateTime?           @map("authorized_at")
  rejectedAt        DateTime?           @map("rejected_at")
  cancelledAt       DateTime?           @map("cancelled_at")

  // Retry (rede de segurança do transmissor).
  retryCount        Int                 @default(0) @map("retry_count")
  lastError         String?             @map("last_error") @db.Text
  nextRetryAt       DateTime?           @map("next_retry_at")

  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractInvoice   ContractInvoice?    @relation(fields: [contractInvoiceId], references: [id], onDelete: SetNull)
  oneTimeCharge     OneTimeCharge?      @relation(fields: [oneTimeChargeId], references: [id], onDelete: SetNull)
  substitutes       NfcomDocument?      @relation("NfcomSub", fields: [substitutesId], references: [id], onDelete: SetNull)
  substitutedBy     NfcomDocument[]     @relation("NfcomSub")

  @@unique([tenantId, serie, numero], map: "nfcom_doc_numero_uniq")
  @@index([tenantId, status, issuedAt(sort: Desc)])
  @@index([tenantId, contractInvoiceId])
  @@index([nextRetryAt], map: "nfcom_doc_retry_idx")
  @@map("nfcom_documents")
}

// =============================================================================
// Hubsoft — integração de LEITURA (read-only) p/ migração/operação conjunta.
// Consome a API oficial do Hubsoft (OAuth2 password grant) e espelha clientes,
// contratos (servicos[]) e financeiro (faturas) nos modelos do NetX. Credenciais
// por tenant, cifradas (CryptoService). Ver project_netx + módulo /hubsoft.
// =============================================================================
model HubsoftConfig {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @unique @map("tenant_id") @db.Uuid

  enabled        Boolean  @default(false)

  // Endereço do servidor do provedor (ex.: https://api.provedor.hubsoft.com.br).
  host           String?  @db.VarChar(255)

  // Segredos cifrados (CryptoService v1:iv:tag:ct).
  // credentialsEnc = JSON {clientId, clientSecret, username, password}.
  credentialsEnc String?  @map("credentials_enc") @db.Text

  // Sync contínuo automático (cron). SEMPRE read-only — nunca escreve no Hubsoft.
  autoSync       Boolean  @default(false) @map("auto_sync")
  syncCustomers  Boolean  @default(true)  @map("sync_customers")
  syncFinanceiro Boolean  @default(true)  @map("sync_financeiro")

  // Telemetria do último sync.
  lastSyncAt     DateTime? @map("last_sync_at")
  lastSyncStatus String?   @map("last_sync_status") @db.VarChar(16) // OK|PARTIAL|ERROR
  lastSyncError  String?   @map("last_sync_error") @db.Text
  lastSyncStats  Json?     @map("last_sync_stats")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("hubsoft_configs")
}

/// Config TR-069 por instância (1:1 tenant). Padrão EfiConfig — segredo cifrado.
model Tr069TenantConfig {
  id                      String   @id @default(uuid()) @db.Uuid
  tenantId                String   @unique @map("tenant_id") @db.Uuid

  // Adoção de CPE desconhecido (server-level: o cwmp-server aceita se QUALQUER
  // tenant tiver ligado). CPE cai em Tr069PendingDevice (tenantless).
  acceptUnknownInforms    Boolean  @default(false) @map("accept_unknown_informs")

  // Wi-Fi do contrato (gate nas regras CONTRACT_WIFI_*).
  wifiFromContract        Boolean  @default(true) @map("wifi_from_contract")

  // PPPoE: origem (CONTRACT | STATIC | OLT) + VLAN padrão.
  pppoeSource             String   @default("CONTRACT") @map("pppoe_source") @db.VarChar(16)
  defaultVlan             Int?     @map("default_vlan")
  pullFromOltProvisioning Boolean  @default(false) @map("pull_from_olt_provisioning")

  // IPv6: ativo + modo (AUTOCONFIGURED | DHCPV6).
  ipv6Enabled             Boolean  @default(true) @map("ipv6_enabled")
  ipv6Mode                String   @default("AUTOCONFIGURED") @map("ipv6_mode") @db.VarChar(16)

  // Senha de acesso padrão (cifrada) + aplicar (provisionamento/reconcile).
  accessPasswordEnc       String?  @map("access_password_enc") @db.Text
  applyAccessPassword     Boolean  @default(false) @map("apply_access_password")

  // Acesso remoto HTTP: ligado + porta + modo (LAN_ONLY | LAN_WAN).
  remoteHttpEnabled       Boolean  @default(false) @map("remote_http_enabled")
  remoteHttpPort          Int?     @map("remote_http_port")
  remoteMode              String   @default("LAN_ONLY") @map("remote_mode") @db.VarChar(16)

  // Firmware: campanha de atualização da frota.
  firmwareAutoUpdate      Boolean  @default(false) @map("firmware_auto_update")
  firmwareUrl             String?  @map("firmware_url") @db.VarChar(512)
  firmwareTargetVersion   String?  @map("firmware_target_version") @db.VarChar(64)

  // Conformidade: intervalo (min) e janela horária (hora local do tenant).
  reconcileIntervalMin    Int?     @map("reconcile_interval_min")
  reconcileWindowStart    Int?     @map("reconcile_window_start")
  reconcileWindowEnd      Int?     @map("reconcile_window_end")

  // WiFi-Opt: pacote de otimização Wi-Fi Huawei (gatilhos + rollout em ondas).
  // Duplo opt-in: só age com a env global (WIFI_OPT_ENABLED /
  // WIFI_OPT_ROLLOUT_ENABLED) E a flag do tenant ligadas.
  wifiOptEnabled          Boolean  @default(false) @map("wifi_opt_enabled")
  wifiOptRegDomain        String   @default("PY") @map("wifi_opt_reg_domain") @db.VarChar(8)
  wifiOptRolloutEnabled   Boolean  @default(false) @map("wifi_opt_rollout_enabled")

  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tr069_tenant_configs")
}

/// Caixa de adoção: CPE que informou mas não casou com ONT/placeholder.
/// TENANTLESS de propósito (equipamento desconhecido não tem tenant ainda); o
/// operador adota e atribui tenant/contrato. Único por deviceId.
model Tr069PendingDevice {
  id                   String   @id @default(uuid()) @db.Uuid
  deviceId             String   @unique @map("device_id") @db.VarChar(128)
  oui                  String?  @db.VarChar(16)
  productClass         String?  @map("product_class") @db.VarChar(64)
  serialNumber         String?  @map("serial_number") @db.VarChar(64)
  manufacturer         String?  @db.VarChar(64)
  softwareVersion      String?  @map("software_version") @db.VarChar(32)
  connectionRequestUrl String?  @map("connection_request_url") @db.VarChar(255)
  parametersSnapshot   Json?    @map("parameters_snapshot")
  informCount          Int      @default(1) @map("inform_count")
  firstSeenAt          DateTime @default(now()) @map("first_seen_at")
  lastSeenAt           DateTime @default(now()) @map("last_seen_at")

  @@index([lastSeenAt])
  @@map("tr069_pending_devices")
}

// =============================================================================
// IA (@netx/ai) — config do motor por tenant + log de uso.
// Motor aberto (Ollama) self-hosted por padrão, com fallback de nuvem opcional.
// A IA é CONSELHEIRA: resume/explica, NUNCA aplica config nem executa ação.
// =============================================================================
enum AiProviderKind {
  OLLAMA
  OPENAI_COMPAT
  ANTHROPIC
}

model AiConfig {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @unique @map("tenant_id") @db.Uuid

  enabled           Boolean        @default(false)

  // Provider primário (motor aberto por padrão).
  provider          AiProviderKind @default(OLLAMA)
  baseUrl           String?        @map("base_url") @db.VarChar(500)
  model             String         @default("qwen2.5:3b-instruct") @db.VarChar(120)
  // Credencial do provider primário (só quando nuvem). Cifrada v1:iv:tag:ct.
  apiKeyEnc         String?        @map("api_key_enc") @db.Text

  // Fallback de nuvem (híbrido). Desligado por padrão.
  fallbackEnabled   Boolean        @default(false) @map("fallback_enabled")
  fallbackProvider  AiProviderKind @default(ANTHROPIC) @map("fallback_provider")
  fallbackModel     String         @default("claude-haiku-4-5") @map("fallback_model") @db.VarChar(120)
  fallbackBaseUrl   String?        @map("fallback_base_url") @db.VarChar(500)
  fallbackApiKeyEnc String?        @map("fallback_api_key_enc") @db.Text

  // Limites/comportamento
  maxTokens         Int            @default(1024) @map("max_tokens")
  timeoutMs         Int            @default(120000) @map("timeout_ms")
  redactPii         Boolean        @default(true) @map("redact_pii")

  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model AiUsageLog {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid

  feature      String         @db.VarChar(80) // rótulo: alarm.summary, copilot.ask...
  provider     AiProviderKind
  model        String         @db.VarChar(120)
  usedFallback Boolean        @default(false) @map("used_fallback")
  ok           Boolean        @default(true)
  latencyMs    Int            @default(0) @map("latency_ms")
  inputTokens  Int?           @map("input_tokens")
  outputTokens Int?           @map("output_tokens")
  error        String?        @db.VarChar(500)

  createdAt    DateTime       @default(now()) @map("created_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, feature, createdAt])
  @@index([tenantId, createdAt])
  @@map("ai_usage_logs")
}

// =============================================================================
// IA — insights proativos (detectores por cron empurram alertas pro Nexus).
// Determinístico (thresholds); a IA é conselheira: alerta, humano decide.
// =============================================================================
enum AiInsightSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AiInsightStatus {
  NEW
  DISMISSED
}

model AiInsight {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  kind        String            @db.VarChar(60) // inadimplencia-alta, churn-alto, incidente, os-atrasadas
  severity    AiInsightSeverity @default(WARNING)
  status      AiInsightStatus   @default(NEW)
  title       String            @db.VarChar(200)
  body        String            @db.Text
  // Chave de deduplicação (ex.: "inadimplencia-alta:2026-06") — um por condição/período.
  dedupeKey   String            @map("dedupe_key") @db.VarChar(140)
  createdAt   DateTime          @default(now()) @map("created_at")
  dismissedAt DateTime?         @map("dismissed_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status, createdAt])
  @@map("ai_insights")
}

// =============================================================================
// FiberMap — documentação de planta externa OSP v2 (FIBERMAP-SPEC.md)
// =============================================================================
// Grafo de conectividade óptica georreferenciado: catálogo de produtos,
// elementos (POP/CEO/CTO/poste), cabos → tubos → fibras, fusões/conectores,
// splitters, cortes, OTDR e medições de potência. Substitui gradualmente o
// OSP embutido no módulo optical (Optical*/Fiber* acima) — os dois convivem
// até a migração de dados.
//
// Decisões de arquitetura (desvios da spec documentados no README do módulo):
//  - Namespace por PREFIXO de tabela `fibermap_` no schema public, não schema
//    Postgres dedicado (multiSchema do Prisma exigiria @@schema em ~150 models
//    existentes; precedente `radius` é SQL-only e perderia o client).
//  - Geometrias PostGIS: colunas `geom` são `Unsupported(...)` mantidas por
//    TRIGGER a partir de latitude/longitude (elementos) e `path` Json
//    (segmentos) — CRUD via Prisma permanece simples; consultas espaciais
//    (bbox, interpolação OTDR) usam $queryRaw com ST_*.
//  - `geometric_length_m` também é mantido pela trigger (ST_Length::geography).
//  - Auditoria de mutação via AuditService (audit_logs global), não tabela
//    fibermap_audit_log dedicada.
//  - tenant_id em TODAS as tabelas (regra do repo); FK+relation Prisma só nos
//    agregados-raiz pra conter a explosão de relations em Tenant/User — filhos
//    (tubos, fibras, segmentos, portas…) carregam tenant_id escalar indexado.

enum FibermapProductType {
  CABLE
  SPLICE_CLOSURE // CEO — caixa de emenda
  TERMINATION_BOX // CTO — caixa de atendimento
  DIO
  CABINET // armário de rua
  INDOOR_RACK
  SPLITTER
}

enum FibermapColorStandard {
  ABNT // NBR 14700: Verde, Amarela, Branca, Azul, …
  EIA598 // TIA-598: Azul, Laranja, Verde, Marrom, …
}

enum FibermapTubeScheme {
  STANDARD_CYCLE // ciclo de 12 cores do padrão
  PILOT_DIRECTIONAL // tubo 1 verde (piloto), 2 amarela (direcional), demais brancos
  CUSTOM // lista explícita em fibermap_cable_model_tubes
}

enum FibermapElementType {
  POP
  CABINET
  CEO
  CTO
  POLE // poste — snapping de rota e reservas; fora do grafo lógico
  SLACK_COIL // reserva técnica standalone marcada no mapa
  CUSTOMER_PREMISE // opcional no MVP (fase 7)
}

enum FibermapFiberStatus {
  DARK
  ACTIVE
  RESERVED
  BROKEN
}

enum FibermapDeviceType {
  SPLITTER
  DIO
  OLT
  ONU_SHELF
  RACK // container físico — não tem portas ópticas
}

enum FibermapPortRole {
  IN
  OUT
  BIDI
}

enum FibermapConnectionKind {
  FUSION
  CONNECTOR
  SPLITTER_PATH // reservado — NÃO usar no MVP (spec §3.5)
}

enum FibermapEndpointType {
  FIBER_END
  PORT
}

// Lado de uma ponta de fibra: A/B = extremidades do cabo; U/D = lado
// upstream/downstream de um CORTE (fibermap_fiber_cuts) — spec §4.
enum FibermapFiberSide {
  A
  B
  U
  D
}

enum FibermapOtdrReferenceKind {
  ELEMENT
  PORT
}

enum FibermapOtdrEventType {
  BREAK
  HIGH_LOSS
  REFLECTIVE
  END
}

// -----------------------------------------------------------------------------
// FiberMap — organização (pastas)
// -----------------------------------------------------------------------------
model FibermapFolder {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  parentId    String?          @map("parent_id") @db.Uuid
  name        String           @db.VarChar(120)
  sortOrder   Int              @default(0) @map("sort_order")
  notes       String?          @db.Text

  createdById String?          @map("created_by_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      FibermapFolder?  @relation("FibermapFolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    FibermapFolder[] @relation("FibermapFolderChildren")
  createdBy   User?            @relation("FibermapFolderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  elements    FibermapElement[]
  cables      FibermapCable[]

  @@index([tenantId, parentId])
  @@map("fibermap_folders")
}

// -----------------------------------------------------------------------------
// FiberMap — catálogo de produtos (spec §3.2)
// -----------------------------------------------------------------------------
// Fonte de verdade das características físicas. Instâncias no mapa copiam
// SNAPSHOT na criação — editar produto NÃO propaga (spec §14.8). Produto com
// instâncias nunca é excluído, só desativado (service impõe).
model FibermapProduct {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  type         FibermapProductType
  manufacturer String              @default("Padrão") @db.VarChar(120)
  name         String              @db.VarChar(160)
  description  String?             @db.Text
  // Chaves documentadas por tipo (spec §3.2) — validação leve no DTO.
  specs        Json                @default("{}")
  isActive     Boolean             @default(true) @map("is_active")

  createdById  String?             @map("created_by_id") @db.Uuid
  updatedById  String?             @map("updated_by_id") @db.Uuid
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  deletedAt    DateTime?           @map("deleted_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy    User?               @relation("FibermapProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?               @relation("FibermapProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  cableModel   FibermapCableModel?
  elements     FibermapElement[]
  cables       FibermapCable[]
  devices      FibermapDevice[]

  @@unique([tenantId, type, manufacturer, name])
  @@index([tenantId, type, isActive])
  @@map("fibermap_products")
}

// Extensão estruturada APENAS para cabos — a estrutura tubos/fibras dirige
// os algoritmos de instanciação e o preview da Tela 3.
model FibermapCableModel {
  productId     String                   @id @map("product_id") @db.Uuid
  tenantId      String                   @map("tenant_id") @db.Uuid
  fiberCount    Int                      @map("fiber_count")
  tubeCount     Int                      @map("tube_count")
  // Invariante fiber_count = tube_count × fibers_per_tube (DTO + CHECK no SQL).
  fibersPerTube Int                      @map("fibers_per_tube")
  colorStandard FibermapColorStandard    @default(ABNT) @map("color_standard")
  tubeScheme    FibermapTubeScheme       @default(STANDARD_CYCLE) @map("tube_scheme")
  // Fator de excesso (catenária + hélice): óptico ≈ geométrico × fator.
  excessFactor  Decimal                  @default(1.0200) @map("excess_factor") @db.Decimal(5, 4)
  // Informativo: 'ASU80', 'ASU120', 'DROP', 'SUBTERRANEO'…
  cableClass    String?                  @map("cable_class") @db.VarChar(40)

  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       FibermapProduct          @relation(fields: [productId], references: [id], onDelete: Cascade)
  tubes         FibermapCableModelTube[]

  @@index([tenantId])
  @@map("fibermap_cable_models")
}

// Cores de tubo do modelo — populada pelo service conforme tubeScheme.
model FibermapCableModelTube {
  cableModelId String             @map("cable_model_id") @db.Uuid
  tubeNumber   Int                @map("tube_number")
  color        String             @db.VarChar(20)

  cableModel   FibermapCableModel @relation(fields: [cableModelId], references: [productId], onDelete: Cascade)

  @@id([cableModelId, tubeNumber])
  @@map("fibermap_cable_model_tubes")
}

// -----------------------------------------------------------------------------
// FiberMap — elementos físicos (nós geográficos, spec §3.3)
// -----------------------------------------------------------------------------
model FibermapElement {
  id          String                    @id @default(uuid()) @db.Uuid
  tenantId    String                    @map("tenant_id") @db.Uuid
  folderId    String                    @map("folder_id") @db.Uuid
  type        FibermapElementType
  // Modelo do catálogo — obrigatório na UI pra CEO/CTO/CABINET; null permitido
  // pra POLE, import KML e legado (spec §3.3).
  productId   String?                   @map("product_id") @db.Uuid
  // POP: vínculo com a planta de rede (Técnico > Planta de rede). Mesmo
  // contrato do FibermapDevice.netxOltId — coluna real (não metadata) pra FK +
  // índice único parcial (WHERE deleted_at IS NULL, no SQL da migration)
  // travarem "um POP do inventário = UM lugar na planta". Só faz sentido em
  // type=POP; a validação mora no service, não no banco.
  netxPopId   String?                   @map("netx_pop_id") @db.Uuid
  name        String                    @db.VarChar(120)
  latitude    Decimal                   @db.Decimal(9, 6)
  longitude   Decimal                   @db.Decimal(9, 6)
  // Mantida por trigger a partir de latitude/longitude; GiST no SQL. Consultas
  // bbox/vizinhança usam $queryRaw — nunca selecionada pelo client.
  geom        Unsupported("geometry(Point, 4326)")?
  address     String?                   @db.VarChar(255)
  description String?                   @db.Text
  // Ex.: posição no diagrama de emendas, capacidades snapshotadas do produto.
  metadata    Json                      @default("{}")

  createdById String?                   @map("created_by_id") @db.Uuid
  updatedById String?                   @map("updated_by_id") @db.Uuid
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  deletedAt   DateTime?                 @map("deleted_at")

  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folder      FibermapFolder            @relation(fields: [folderId], references: [id], onDelete: Restrict)
  product     FibermapProduct?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  // SetNull: apagar o POP do inventário não some com o elemento da planta —
  // vira POP "sem vínculo" e o operador re-vincula (mesma filosofia do R8.2 e
  // do netxOltId).
  netxPop     NetworkPop?               @relation(fields: [netxPopId], references: [id], onDelete: SetNull)
  createdBy   User?                     @relation("FibermapElementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?                     @relation("FibermapElementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  photos      FibermapElementPhoto[]
  devices     FibermapDevice[]
  segmentsFrom FibermapCableSegment[]   @relation("FibermapSegmentFrom")
  segmentsTo   FibermapCableSegment[]   @relation("FibermapSegmentTo")
  slacks      FibermapCableSlack[]
  fiberCuts   FibermapFiberCut[]
  connections FibermapOpticalConnection[]

  @@unique([folderId, name])
  @@index([tenantId, type])
  @@index([tenantId, folderId])
  @@index([tenantId, productId])
  // O único parcial (um POP do inventário em um só lugar da planta) é criado
  // no SQL da migration — Prisma não expressa índice parcial.
  @@index([netxPopId])
  @@map("fibermap_elements")
}

// Fotos via MinIO presigned (StorageService) — mesma mecânica de O.S/RH.
model FibermapElementPhoto {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  elementId   String          @map("element_id") @db.Uuid
  storageKey  String          @map("storage_key") @db.VarChar(512)
  fileName    String?         @map("file_name") @db.VarChar(255)
  caption     String?         @db.VarChar(255)
  takenAt     DateTime?       @map("taken_at")
  createdById String?         @map("created_by_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  element     FibermapElement @relation(fields: [elementId], references: [id], onDelete: Cascade)

  @@index([tenantId, elementId])
  @@map("fibermap_element_photos")
}

// -----------------------------------------------------------------------------
// FiberMap — cabos, tubos, fibras (spec §3.4)
// -----------------------------------------------------------------------------
// Criação parte SEMPRE de um cable_model; colunas estruturais são SNAPSHOT
// (preservam algoritmos/histórico se o produto mudar). productId null só em
// import KML/legado (badge "sem modelo" na UI, spec §14.9).
model FibermapCable {
  id            String                 @id @default(uuid()) @db.Uuid
  tenantId      String                 @map("tenant_id") @db.Uuid
  folderId      String                 @map("folder_id") @db.Uuid
  name          String                 @db.VarChar(160)
  productId     String?                @map("product_id") @db.Uuid
  fiberCount    Int                    @map("fiber_count")
  tubeCount     Int                    @map("tube_count")
  fibersPerTube Int                    @map("fibers_per_tube")
  colorStandard FibermapColorStandard  @map("color_standard")
  // Editável por instância — calibração OTDR ajusta AQUI, nunca no produto
  // (spec §14.10).
  excessFactor  Decimal                @map("excess_factor") @db.Decimal(5, 4)
  // Cor da polyline no mapa (hex #rrggbb); default derivado do nome no service.
  displayColor  String?                @map("display_color") @db.VarChar(7)
  notes         String?                @db.Text

  createdById   String?                @map("created_by_id") @db.Uuid
  updatedById   String?                @map("updated_by_id") @db.Uuid
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  deletedAt     DateTime?              @map("deleted_at")

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folder        FibermapFolder         @relation(fields: [folderId], references: [id], onDelete: Restrict)
  product       FibermapProduct?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdBy     User?                  @relation("FibermapCableCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                  @relation("FibermapCableUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  tubes         FibermapCableTube[]
  fibers        FibermapFiber[]
  segments      FibermapCableSegment[]
  slacks        FibermapCableSlack[]

  @@index([tenantId, folderId])
  @@index([tenantId, productId])
  @@map("fibermap_cables")
}

// Snapshot das cores de tubo do modelo no momento da criação.
model FibermapCableTube {
  cableId    String        @map("cable_id") @db.Uuid
  tubeNumber Int           @map("tube_number")
  color      String        @db.VarChar(20)

  cable      FibermapCable @relation(fields: [cableId], references: [id], onDelete: Cascade)

  @@id([cableId, tubeNumber])
  @@map("fibermap_cable_tubes")
}

// Um cabo é uma sequência ordenada de segmentos entre elementos; a cadeia
// deve ser contígua (to do seq N = from do seq N+1 — service, spec §14.4).
model FibermapCableSegment {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  cableId           String          @map("cable_id") @db.Uuid
  seq               Int
  fromElementId     String          @map("from_element_id") @db.Uuid
  toElementId       String          @map("to_element_id") @db.Uuid
  // Rota real (postes/ruas) como coordenadas GeoJSON [[lng,lat], ...] — mesma
  // convenção do FiberCable.path legado. API trafega {latitude, longitude}.
  path              Json
  // Mantidas por trigger: geom ← path; geometric_length_m ← ST_Length(geog).
  geom              Unsupported("geometry(LineString, 4326)")?
  geometricLengthM  Decimal         @default(0) @map("geometric_length_m") @db.Decimal(10, 2)
  // Override do técnico: metragem de bobina/OTDR (spec §3.4).
  measuredLengthM   Decimal?        @map("measured_length_m") @db.Decimal(10, 2)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cable             FibermapCable   @relation(fields: [cableId], references: [id], onDelete: Cascade)
  fromElement       FibermapElement @relation("FibermapSegmentFrom", fields: [fromElementId], references: [id], onDelete: Restrict)
  toElement         FibermapElement @relation("FibermapSegmentTo", fields: [toElementId], references: [id], onDelete: Restrict)
  slacks            FibermapCableSlack[]

  @@unique([cableId, seq])
  @@index([tenantId, cableId])
  @@index([fromElementId])
  @@index([toElementId])
  @@map("fibermap_cable_segments")
}

// Fibra individual — criada automaticamente ao instanciar o cabo do modelo.
// fiber_number é GLOBAL no cabo (1..N) e IMUTÁVEL (spec §14.3).
model FibermapFiber {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  cableId       String              @map("cable_id") @db.Uuid
  tubeNumber    Int                 @map("tube_number")
  fiberNumber   Int                 @map("fiber_number")
  color         String              @db.VarChar(20)
  status        FibermapFiberStatus @default(DARK)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cable         FibermapCable       @relation(fields: [cableId], references: [id], onDelete: Cascade)
  cuts          FibermapFiberCut[]
  connectionsA  FibermapOpticalConnection[] @relation("FibermapConnFiberA")
  connectionsB  FibermapOpticalConnection[] @relation("FibermapConnFiberB")

  @@unique([cableId, fiberNumber])
  @@index([cableId, tubeNumber])
  @@index([tenantId])
  @@map("fibermap_fibers")
}

// Reserva técnica (sobra enrolada) — conta na distância ÓPTICA, não na
// geográfica (spec §2). MVP: sempre na caixa/poste (AT_ELEMENT).
model FibermapCableSlack {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  cableId     String               @map("cable_id") @db.Uuid
  elementId   String               @map("element_id") @db.Uuid
  segmentId   String               @map("segment_id") @db.Uuid
  position    String               @default("AT_ELEMENT") @db.VarChar(20)
  lengthM     Decimal              @map("length_m") @db.Decimal(10, 2)
  createdById String?              @map("created_by_id") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cable       FibermapCable        @relation(fields: [cableId], references: [id], onDelete: Cascade)
  element     FibermapElement      @relation(fields: [elementId], references: [id], onDelete: Restrict)
  segment     FibermapCableSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, cableId])
  @@index([elementId])
  @@map("fibermap_cable_slacks")
}

// -----------------------------------------------------------------------------
// FiberMap — grafo lógico: devices, portas, cortes, conexões (spec §3.5, §4)
// -----------------------------------------------------------------------------
model FibermapDevice {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  elementId      String              @map("element_id") @db.Uuid
  // Hierarquia física: DIO/OLT montados num RACK (metadata.rack_position).
  parentDeviceId String?             @map("parent_device_id") @db.Uuid
  productId      String?             @map("product_id") @db.Uuid
  type           FibermapDeviceType
  name           String              @db.VarChar(120)
  // OLT: vínculo com o inventário (/olts, spec §11). Coluna real (não
  // metadata) pra FK + índice único parcial (WHERE deleted_at IS NULL, no
  // SQL da migration) travarem "uma OLT do inventário = UM lugar na planta".
  netxOltId      String?             @map("netx_olt_id") @db.Uuid
  // SPLITTER: { ratio, topology, tap_percent } · RACK: { rack_units }
  // OLT: { pon_ports }
  metadata       Json                @default("{}")

  createdById    String?             @map("created_by_id") @db.Uuid
  updatedById    String?             @map("updated_by_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  element        FibermapElement     @relation(fields: [elementId], references: [id], onDelete: Restrict)
  parentDevice   FibermapDevice?     @relation("FibermapDeviceChildren", fields: [parentDeviceId], references: [id], onDelete: SetNull)
  childDevices   FibermapDevice[]    @relation("FibermapDeviceChildren")
  product        FibermapProduct?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  // SetNull: apagar a OLT do inventário não some com o device da planta —
  // vira OLT "sem vínculo" e o operador re-vincula (mesma filosofia do R8.2).
  netxOlt        Olt?                @relation(fields: [netxOltId], references: [id], onDelete: SetNull)
  createdBy      User?               @relation("FibermapDeviceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?               @relation("FibermapDeviceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  ports          FibermapOpticalPort[]

  @@index([tenantId, elementId])
  @@index([elementId, type])
  @@map("fibermap_devices")
}

// Tudo que pode receber luz é uma porta (modelo porta-cêntrico). RACK não tem.
model FibermapOpticalPort {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  deviceId   String           @map("device_id") @db.Uuid
  role       FibermapPortRole
  portNumber Int              @map("port_number")
  label      String?          @db.VarChar(80)
  createdAt  DateTime         @default(now()) @map("created_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device     FibermapDevice   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  connectionsA FibermapOpticalConnection[] @relation("FibermapConnPortA")
  connectionsB FibermapOpticalConnection[] @relation("FibermapConnPortB")
  // Contrato atendido por esta porta de drop (FK vive em Contract.fibermapPortId).
  contract   Contract?

  @@unique([deviceId, role, portNumber])
  @@index([tenantId])
  @@map("fibermap_optical_ports")
}

// Corte ("tesoura") — fibra expressa cortada num elemento intermediário vira
// duas pontas conectáveis (lados U/D). Spec §4 (ponto crítico da sangria).
model FibermapFiberCut {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  fiberId     String          @map("fiber_id") @db.Uuid
  elementId   String          @map("element_id") @db.Uuid
  createdById String?         @map("created_by_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiber       FibermapFiber   @relation(fields: [fiberId], references: [id], onDelete: Cascade)
  element     FibermapElement @relation(fields: [elementId], references: [id], onDelete: Restrict)
  connectionsA FibermapOpticalConnection[] @relation("FibermapConnCutA")
  connectionsB FibermapOpticalConnection[] @relation("FibermapConnCutB")

  @@unique([fiberId, elementId])
  @@index([tenantId, elementId])
  @@map("fibermap_fiber_cuts")
}

// Conexão física entre dois endpoints (fusão/conector) DENTRO de um elemento.
// Endpoints polimórficos controlados por CHECKs no SQL:
//   FIBER_END → fiberId + fiberSide (A/B, ou U/D quando cutId preenchido)
//   PORT      → portId
// Caminho interno IN→OUT de splitter NÃO é conexão — é implícito no device
// (o traçador ramifica, spec §3.5). Unicidade de ponta sob concorrência é
// garantida por fibermap_connection_endpoints (endpoint_key UNIQUE).
model FibermapOpticalConnection {
  id            String                       @id @default(uuid()) @db.Uuid
  tenantId      String                       @map("tenant_id") @db.Uuid
  elementId     String                       @map("element_id") @db.Uuid
  kind          FibermapConnectionKind
  aType         FibermapEndpointType         @map("a_type")
  aFiberId      String?                      @map("a_fiber_id") @db.Uuid
  aFiberSide    FibermapFiberSide?           @map("a_fiber_side")
  aCutId        String?                      @map("a_cut_id") @db.Uuid
  aPortId       String?                      @map("a_port_id") @db.Uuid
  bType         FibermapEndpointType         @map("b_type")
  bFiberId      String?                      @map("b_fiber_id") @db.Uuid
  bFiberSide    FibermapFiberSide?           @map("b_fiber_side")
  bCutId        String?                      @map("b_cut_id") @db.Uuid
  bPortId       String?                      @map("b_port_id") @db.Uuid
  // Perda medida; null = usa default do tipo (fibermap_attenuation_defaults).
  lossDb        Decimal?                     @map("loss_db") @db.Decimal(5, 2)
  notes         String?                      @db.Text

  createdById   String?                      @map("created_by_id") @db.Uuid
  updatedById   String?                      @map("updated_by_id") @db.Uuid
  createdAt     DateTime                     @default(now()) @map("created_at")
  updatedAt     DateTime                     @updatedAt @map("updated_at")
  deletedAt     DateTime?                    @map("deleted_at")

  tenant        Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  element       FibermapElement              @relation(fields: [elementId], references: [id], onDelete: Restrict)
  aFiber        FibermapFiber?               @relation("FibermapConnFiberA", fields: [aFiberId], references: [id], onDelete: Restrict)
  bFiber        FibermapFiber?               @relation("FibermapConnFiberB", fields: [bFiberId], references: [id], onDelete: Restrict)
  aCut          FibermapFiberCut?            @relation("FibermapConnCutA", fields: [aCutId], references: [id], onDelete: Restrict)
  bCut          FibermapFiberCut?            @relation("FibermapConnCutB", fields: [bCutId], references: [id], onDelete: Restrict)
  aPort         FibermapOpticalPort?         @relation("FibermapConnPortA", fields: [aPortId], references: [id], onDelete: Restrict)
  bPort         FibermapOpticalPort?         @relation("FibermapConnPortB", fields: [bPortId], references: [id], onDelete: Restrict)
  createdBy     User?                        @relation("FibermapConnCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                        @relation("FibermapConnUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  endpoints     FibermapConnectionEndpoint[]

  @@index([tenantId, elementId])
  @@index([aFiberId])
  @@index([bFiberId])
  @@index([aPortId])
  @@index([bPortId])
  @@map("fibermap_optical_connections")
}

// Chave de ocupação de endpoint — 2 linhas por conexão ativa, escritas na
// mesma transação. endpoint_key UNIQUE garante, mesmo sob concorrência, que
// uma ponta só participa de UMA conexão (aceite FM-0/FM-3):
//   'FIBER:{fiberId}:{A|B}' · 'CUT:{cutId}:{U|D}' · 'PORT:{portId}:{C|F}'
// Porta tem 2 faces independentes (C=adaptador frontal p/ CONNECTOR,
// F=pigtail traseiro p/ FUSION) — necessário pra DIO de passagem; a face
// deriva do kind da conexão (helpers em @netx/shared fibermap/endpoint-key).
// Ao desfazer a fusão, as linhas são HARD-deletadas (a conexão fica soft) —
// libera a ponta preservando histórico.
model FibermapConnectionEndpoint {
  id           String                    @id @default(uuid()) @db.Uuid
  tenantId     String                    @map("tenant_id") @db.Uuid
  connectionId String                    @map("connection_id") @db.Uuid
  endpointKey  String                    @unique @map("endpoint_key") @db.VarChar(120)

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection   FibermapOpticalConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@map("fibermap_connection_endpoints")
}

// -----------------------------------------------------------------------------
// FiberMap — medições (spec §3.6)
// -----------------------------------------------------------------------------
model FibermapOtdrReading {
  id                 String                    @id @default(uuid()) @db.Uuid
  tenantId           String                    @map("tenant_id") @db.Uuid
  referenceKind      FibermapOtdrReferenceKind @map("reference_kind")
  // Escalares de propósito (sem FK): leitura é log histórico — sobrevive à
  // remoção do elemento/porta; service valida existência na criação.
  referenceElementId String?                   @map("reference_element_id") @db.Uuid
  referencePortId    String?                   @map("reference_port_id") @db.Uuid
  cableId            String                    @map("cable_id") @db.Uuid
  fiberNumber        Int                       @map("fiber_number")
  directionElementId String                    @map("direction_element_id") @db.Uuid
  distanceM          Decimal                   @map("distance_m") @db.Decimal(10, 2)
  wavelengthNm       Int                       @default(1550) @map("wavelength_nm")
  eventType          FibermapOtdrEventType     @default(BREAK) @map("event_type")
  // Snapshot do resultado calculado (coordenada, incerteza, segmento, flags).
  result             Json?
  createdById        String?                   @map("created_by_id") @db.Uuid
  createdAt          DateTime                  @default(now()) @map("created_at")

  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, cableId])
  @@index([tenantId, createdAt])
  @@map("fibermap_otdr_readings")
}

model FibermapPowerMeasurement {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  portId       String?  @map("port_id") @db.Uuid
  fiberId      String?  @map("fiber_id") @db.Uuid
  elementId    String?  @map("element_id") @db.Uuid
  wavelengthNm Int      @default(1490) @map("wavelength_nm")
  dbm          Decimal  @db.Decimal(6, 2)
  measuredAt   DateTime @default(now()) @map("measured_at")
  // 'MANUAL' hoje; 'SNMP' quando o Pilar 2 alimentar (spec §11).
  source       String   @default("MANUAL") @db.VarChar(20)
  createdById  String?  @map("created_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, portId])
  @@index([tenantId, elementId])
  @@map("fibermap_power_measurements")
}

// Defaults de atenuação por tenant (spec §5.3) — só linhas EDITADAS existem;
// valor vigente = override ?? default de fábrica (FIBERMAP_ATTENUATION_DEFAULTS
// no @netx/shared). itemKey: FIBER_1310, FUSION, SPLITTER_1_8, UNBALANCED_10_TAP…
model FibermapAttenuationDefault {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  itemKey     String   @map("item_key") @db.VarChar(40)
  valueDb     Decimal  @map("value_db") @db.Decimal(6, 3)
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, itemKey])
  @@map("fibermap_attenuation_defaults")
}
