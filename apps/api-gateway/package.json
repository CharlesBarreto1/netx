    "@netx/config": "*",
    "@netx/logger": "*",
    "@netx/shared": "*",
    "axios": "^1.7.9",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.3",
    "nestjs-cls": "^5.4.2",
