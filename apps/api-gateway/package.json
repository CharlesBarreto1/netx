    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@netx/config": "*",
    "@netx/logger": "*",
    "@netx/shared": "*",
    "axios": "^1.8.4",
    "express": "^5.0.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "nestjs-cls": "^6.0.0",
