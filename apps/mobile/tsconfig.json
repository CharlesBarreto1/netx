{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // WatermelonDB usa decorators legados (@field/@date/@readonly). O Babel já
    // transforma em runtime (plugin-proposal-decorators { legacy: true }); estes
    // dois alinham o tsc: decorators legados + campos que NÃO sobrescrevem os
    // accessors criados pelos decorators.
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@netx/shared": ["../../packages/shared/src/index.ts"],
      "@netx/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "app.json",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
